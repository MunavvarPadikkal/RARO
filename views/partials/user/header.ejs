            <div class="header-middle sticky-header">
                <div class="container">
                    <div class="header-left">
                        <button class="mobile-menu-toggler">
                            <span class="sr-only">Toggle mobile menu</span>
                            <i class="icon-bars"></i>
                        </button>

                        <a href="/" class="logo">
                            <img src="/assets/images/RARO Logo.png" alt="RARO Logo" width="135" height="25">
                        </a>

                        <nav class="main-nav">
                            <ul class="menu sf-arrows">
                                <li class="<%= path === '/' ? 'active' : '' %>">
                                    <a href="/">Home</a>


                                </li>
                                <li class="<%= path === '/shop' || path.startsWith('/product') ? 'active' : '' %>">
                                    <a href="/shop">Shop</a>


                                </li>
                                <li class="<%= path === '/cart' ? 'active' : '' %>">
                                    <a href="/cart">Cart</a>

                                </li>
                                <li class="<%= path === '/wishlist' ? 'active' : '' %>">
                                    <a href="/wishlist">Wishlist</a>

                                </li>
                                <li class="<%= path === '/orders' ? 'active' : '' %>">
                                    <a href="/orders">Orders</a>

                                </li>
                                

                        </nav><!-- End .main-nav -->
                    </div><!-- End .header-left -->

                    <div class="header-right">
                        <div class="header-search">
                            <a href="#" class="search-toggle" role="button" title="Search"><i
                                    class="icon-search"></i></a>
                            <form action="/shop" method="get">
                                <div class="header-search-wrapper">
                                    <label for="search" class="sr-only">Search</label>
                                    <input type="search" class="form-control" name="search" id="search" placeholder="Search in..."
                                        required>
                                </div><!-- End .header-search-wrapper -->
                            </form>
                        </div><!-- End .header-search -->

                        <% if (user) { %>
                            <div class="dropdown cart-dropdown" style="margin-right: 1.5rem;">
                                <a href="/wallet" class="dropdown-toggle" title="My Wallet" role="button" style="display: flex; align-items: center; text-decoration: none;">
                                    <i class="icon-wallet" style="font-size: 3.2rem; color: #333;"></i>
                                </a>
                            </div>
                        <% } %>

                        <div class="dropdown cart-dropdown">
                            <a href="/wishlist" class="dropdown-toggle" title="Wishlist" role="button" style="display: flex; align-items: center; text-decoration: none;">
                                <i class="fa-regular fa-heart" style="font-size: 2.3rem; color: #333; margin-top: 2px;"></i>
                                <span class="cart-count" style="right: -8px; top: -2px; <%= (wishlistCount && wishlistCount > 0) ? '' : 'display: none;' %>"><%= wishlistCount || 0 %></span>
                            </a>
                        </div>

                        <div class="dropdown cart-dropdown">
                            <a href="/cart" class="dropdown-toggle" role="button" style="display: flex; align-items: center; text-decoration: none;">
                                <i class="icon-shopping-cart" style="font-size: 3.2rem; margin-right: -5px; color: #333;"></i>
                                <span class="cart-count" style="right: -2px; top: 0; <%= (cartCount && cartCount > 0) ? '' : 'display: none;' %>"><%= cartCount || 0 %></span>
                            </a>
                        </div>
                    </div><!-- End .header-right -->
                </div><!-- End .container -->
            </div><!-- End .header-middle -->
