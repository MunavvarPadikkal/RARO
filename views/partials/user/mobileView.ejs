<!-- Mobile Menu -->
    <style>
        /* Force mobile menu to the left and fix positioning */
        .mobile-menu-container {
            left: 0 !important;
            transform: translateX(-101%) !important;
            transition: transform 0.4s ease, visibility 0.4s !important;
            visibility: hidden !important;
            position: fixed !important;
            top: 0 !important;
            bottom: 0 !important;
            width: 280px !important;
            z-index: 3001 !important; /* Higher than header */
            background-color: #333 !important;
        }

        .mmenu-active .mobile-menu-container {
            transform: translateX(0) !important;
            visibility: visible !important;
        }

        /* Ensure overlay is on top of everything except the menu */
        .mobile-menu-overlay {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            bottom: 0 !important;
            background-color: rgba(0, 0, 0, 0.5) !important;
            z-index: 3000 !important;
            visibility: hidden !important;
            opacity: 0 !important;
            transition: all 0.4s !important;
        }

        .mmenu-active .mobile-menu-overlay {
            visibility: visible !important;
            opacity: 1 !important;
        }

        /* Prevent page wrapper from shifting too much or looking weird */
        .mmenu-active .page-wrapper {
            transform: none !important; /* Disable default theme shift if it causes issues */
        }
        
        body.mmenu-active {
            overflow: hidden !important;
        }
    </style>
    <div class="mobile-menu-overlay"></div><!-- End .mobil-menu-overlay -->

    <div class="mobile-menu-container">
        <div class="mobile-menu-wrapper">
            <span class="mobile-menu-close"><i class="icon-close"></i></span>

            <form action="/shop" method="get" class="mobile-search">
                <label for="mobile-search" class="sr-only">Search</label>
                <input type="search" class="form-control" name="search" id="mobile-search" placeholder="Search in..." required>
                <button class="btn btn-primary" type="submit"><i class="icon-search"></i></button>
            </form>
            
            <nav class="mobile-nav">
                <ul class="mobile-menu">
                    <li class="<%= path === '/' ? 'active' : '' %>">
                        <a href="/">Home</a>
                    </li>
                     <li class="<%= path === '/shop' || path.startsWith('/product') ? 'active' : '' %>">
                        <a href="/shop">Shop</a>
                    </li>
                     <li class="<%= path === '/cart' ? 'active' : '' %>">
                        <a href="/cart">Cart</a>
                    </li>
                     <li class="<%= path === '/wishlist' ? 'active' : '' %>">
                        <a href="/wishlist">Wishlist</a>
                    </li>
                     <li class="<%= path === '/orders' ? 'active' : '' %>">
                        <a href="/orders">Orders</a>
                    </li>
                    
                    
                    
            </nav><!-- End .mobile-nav -->

            <div class="social-icons">
                <a href="#" class="social-icon" target="_blank" title="Facebook"><i class="icon-facebook-f"></i></a>
                <a href="#" class="social-icon" target="_blank" title="Twitter"><i class="icon-twitter"></i></a>
                <a href="#" class="social-icon" target="_blank" title="Instagram"><i class="icon-instagram"></i></a>
                <a href="#" class="social-icon" target="_blank" title="Youtube"><i class="icon-youtube"></i></a>
            </div><!-- End .social-icons -->
        </div><!-- End .mobile-menu-wrapper -->
    </div><!-- End .mobile-menu-container -->