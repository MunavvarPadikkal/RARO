<%
  // activeTab is passed by the including page via locals or a var assignment:
  // 'dashboard' | 'orders' | 'addresses' | 'wallet' | 'edit-profile' | 'coupons'
  var _activeTab = (typeof activeTab !== 'undefined') ? activeTab : 'dashboard';
%>

<style>
  .profile-sidebar-nav {
    margin-bottom: 2rem;
    transition: all 0.3s ease;
  }
  .profile-sidebar-nav .nav-item {
    border-bottom: .1rem solid #ebebeb;
  }
  .profile-sidebar-nav .nav-item:last-child {
    border-bottom: none;
  }
  .profile-sidebar-nav .nav-link {
    position: relative;
    padding: 1.4rem .5rem;
    font-weight: 300;
    font-size: 1.35rem;
    color: #333333;
    text-transform: none;
    transition: all .3s;
    display: block;
  }
  .profile-sidebar-nav .nav-link.active {
    color: #c96;
    font-weight: 400;
  }
  .profile-sidebar-nav .nav-link::before {
    content: '\203A'; /* Prettier chevron-right › */
    position: absolute;
    left: -1.5rem;
    top: 50%;
    transform: translateY(-50%);
    font-weight: 600;
    font-size: 1.8rem;
    opacity: 0;
    transition: all 0.3s;
  }
  .profile-sidebar-nav .nav-link.active::before {
    opacity: 1;
    left: -1rem;
  }

  /* Mobile Toggle Styles */
  .profile-toggle-btn {
    display: none;
    width: 100%;
    padding: 1rem 0;
    background: none;
    border: none;
    margin-bottom: 1rem;
    text-align: left;
    align-items: center;
    font-weight: 500;
    font-size: 1.6rem;
    color: #333;
    cursor: pointer;
    transition: all 0.3s;
  }

  .profile-toggle-btn:hover {
    color: #c96;
  }

  .profile-toggle-btn i {
    font-size: 1.8rem;
    margin-right: 1rem;
  }

  @media screen and (max-width: 767px) {
    .profile-toggle-btn {
      display: flex;
    }
    .profile-sidebar-nav {
      display: none;
      background: #fff;
      border: 1px solid #ebebeb;
      border-radius: 0.4rem;
      padding: 0 1rem;
      margin-bottom: 2rem;
    }
    .profile-sidebar-nav.show {
      display: block;
      animation: slideDown 0.3s ease-out;
    }
    .profile-sidebar-nav .nav-link::before {
        display: none;
    }
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<aside class="col-md-4 col-lg-3">
  <!-- Mobile Toggle Button -->
  <div class="profile-toggle-btn" id="profileMenuToggle">
    <i class="icon-bars"></i>
    <span>Account Menu</span>
  </div>

  <ul class="nav profile-sidebar-nav flex-column" id="profileSidebarMenu" role="tablist">
    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'dashboard' ? 'active' : '' %>" href="/profile">
        Dashboard
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'orders' ? 'active' : '' %>" href="/orders">
        Orders
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'addresses' ? 'active' : '' %>" href="/address">
        Addresses
      </a>
    </li>
  
    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'edit-profile' ? 'active' : '' %>" href="/edit-profile">
        Account Details
      </a>
    </li>
    
    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'wallet' ? 'active' : '' %>" href="/wallet">
        Wallet
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link <%= _activeTab === 'invite' ? 'active' : '' %>" href="/referrals">
        Invite & earn
      </a>
    </li>

    <li class="nav-item">
      <a class="nav-link signout-link" href="javascript:void(0);" onclick="confirmSignOut()">
        Sign Out
      </a>
    </li>
  </ul>
</aside>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function confirmSignOut() {
    Swal.fire({
      title: 'Sign Out?',
      text: "Are you sure you want to log out of your account?",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#d33',
      cancelButtonColor: '#3085d6',
      confirmButtonText: 'Yes, Sign Out',
      cancelButtonText: 'Cancel',
      reverseButtons: true
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = '/logout';
      }
    });
  }

  // Toggle Profile Menu on Mobile
  document.addEventListener('DOMContentLoaded', function() {
    const toggleBtn = document.getElementById('profileMenuToggle');
    const sidebarMenu = document.getElementById('profileSidebarMenu');

    if (toggleBtn && sidebarMenu) {
      toggleBtn.addEventListener('click', function() {
        sidebarMenu.classList.toggle('show');
        toggleBtn.classList.toggle('active');
        
        // Change icon based on state
        const icon = toggleBtn.querySelector('i');
        if (sidebarMenu.classList.contains('show')) {
          icon.classList.remove('icon-bars');
          icon.classList.add('icon-close');
        } else {
          icon.classList.remove('icon-close');
          icon.classList.add('icon-bars');
        }
      });
    }
  });
</script>


