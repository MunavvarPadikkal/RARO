<%- include("./partials/adminHeader") %>
<!-- Cropper.js CSS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"/>

<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50/50">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 p-8 max-w-5xl mx-auto">
      
      <div class="flex items-center gap-4 border-b border-gray-100 pb-6 mb-6">
        <a href="/admin/products" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-50 text-gray-500 hover:bg-gray-100 transition-colors">
          <i class="fa-solid fa-arrow-left"></i>
        </a>
        <h2 class="text-2xl font-semibold text-gray-900">Add New Product</h2>
      </div>

      <form id="addProductForm" enctype="multipart/form-data">
        
        <!-- Basic Information -->
        <h3 class="text-lg font-medium text-gray-900 mb-4 border-b pb-2">Basic Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Product Name *</label>
            <input type="text" id="productName" name="productName" required
                   class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors">
            <span class="text-xs text-red-500 hidden mt-1" id="err-productName"></span>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Category *</label>
            <select id="category" name="category" required
                    class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors">
              <option value="" disabled selected>Select a category</option>
              <% categories.forEach(cat => { %>
                <option value="<%= cat._id %>"><%= cat.name %></option>
              <% }) %>
            </select>
            <span class="text-xs text-red-500 hidden mt-1" id="err-category"></span>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Description *</label>
            <textarea id="description" name="description" rows="4" required
                      class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors resize-none"></textarea>
            <span class="text-xs text-red-500 hidden mt-1" id="err-description"></span>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Highlights (Optional - separating by new lines)</label>
            <textarea id="highlights" name="highlights" rows="3" placeholder="Bullet point 1&#10;Bullet point 2"
                      class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors resize-none"></textarea>
          </div>
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Additional Information (Optional)</label>
            <textarea id="additionalInfo" name="additionalInfo" rows="3" placeholder="Model is 5'9&quot; and wears size S... Fabric: 100% Cotton"
                      class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors resize-none"></textarea>
          </div>
        </div>

        <!-- Pricing & Details -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <div class="md:col-span-2">
            <h3 class="text-lg font-medium text-gray-900 mb-4 border-b pb-2">Pricing</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Regular Price *</label>
                <input type="number" id="regularPrice" name="regularPrice" step="0.01" min="1" required
                       class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors">
                <span class="text-xs text-red-500 hidden mt-1" id="err-regularPrice"></span>
              </div>
            </div>
          </div>
          <div>
            <h3 class="text-lg font-medium text-gray-900 mb-4 border-b pb-2">Color</h3>
            <label class="block text-sm font-medium text-gray-700 mb-1">Available Colors *</label>
            <input type="text" id="availableColors" name="color" placeholder="e.g. Red, Blue" required
                   class="w-full px-4 py-2 border border-gray-200 rounded-lg focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange outline-none transition-colors">
            <span class="text-xs text-red-500 hidden mt-1" id="err-availableColors"></span>
          </div>
        </div>

        <!-- Variants Section -->
        <h3 class="text-lg font-medium text-gray-900 mb-4 border-b pb-2">Product Variants (Color, Size, Stock)</h3>
        <div class="mb-8 overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-500 border border-gray-100 rounded-lg overflow-hidden" id="variantsTable">
                <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                    <tr>
                        <th class="px-4 py-3">Color *</th>
                        <th class="px-4 py-3">Size *</th>
                        <th class="px-4 py-3">Stock *</th>
                        <th class="px-4 py-3">SKU *</th>
                        <th class="px-4 py-3 text-center">Action</th>
                    </tr>
                </thead>
                <tbody id="variantsBody">
                    <tr class="variant-row border-b border-gray-50">
                        <td class="px-4 py-2">
                            <select name="variantColor" required
                                    class="variant-color-select px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                                <option value="" disabled selected>Select Color</option>
                            </select>
                        </td>
                        <td class="px-4 py-2">
                            <select name="variantSize" required
                                    class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                                <option value="S">S</option>
                                <option value="M">M</option>
                                <option value="L" selected>L</option>
                            </select>
                        </td>
                        <td class="px-4 py-2">
                            <input type="number" name="variantStock" min="0" value="0" required
                                   class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                        </td>
                        <td class="px-4 py-2">
                            <input type="text" name="variantSku" placeholder="SKU-123" required
                                   class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                        </td>
                        <td class="px-4 py-2 text-center">
                            <button type="button" class="text-red-500 hover:text-red-700 remove-variant-btn">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
            <button type="button" id="addVariantBtn" class="mt-4 px-4 py-2 text-sm font-medium text-brand-orange bg-brand-orange/5 rounded-lg hover:bg-brand-orange/10 transition-colors">
                <i class="fa-solid fa-plus mr-2"></i> Add Another Variant
            </button>
            <span class="text-xs text-red-500 hidden mt-2" id="err-variants"></span>
        </div>

        <!-- Images -->
        <h3 class="text-lg font-medium text-gray-900 mb-4 border-b pb-2">Product Images *</h3>
        <p class="text-sm text-gray-500 mb-4">Upload minimum 3 to maximum 4 images. Images will be cropped to square (1:1).</p>
        
        <div class="mb-8">
            <div class="flex flex-wrap gap-4" id="imagePreviewContainer">
                <!-- Preview items will go here -->
                
                <!-- Add Image Button -->
                <label id="uploadTriggerLabel" class="w-32 h-32 flex flex-col items-center justify-center border-2 border-dashed border-gray-300 rounded-xl cursor-pointer hover:bg-gray-50 hover:border-brand-orange transition-all">
                    <i class="fa-solid fa-cloud-arrow-up text-2xl text-gray-400 mb-2"></i>
                    <span class="text-xs text-gray-500 font-medium">Add Image</span>
                    <input type="file" id="imageInput" class="hidden" accept="image/png, image/jpeg, image/jpg, image/webp">
                </label>
            </div>
            <span class="text-xs text-red-500 hidden mt-2" id="err-images"></span>
        </div>

        <div class="flex items-center justify-end gap-4 pt-6 border-t border-gray-100">
          <button type="button" onclick="window.history.back()" class="px-6 py-2.5 rounded-xl border border-gray-200 text-gray-700 font-medium hover:bg-gray-50 transition-colors">Cancel</button>
          <button type="submit" id="submitBtn" class="px-6 py-2.5 rounded-xl bg-brand-orange text-white font-medium hover:bg-opacity-90 transition-colors">Save Product</button>
        </div>
      </form>
    </div>
  </main>
</div>

<!-- Cropper Modal -->
<div id="cropperModal" class="fixed inset-0 z-50 hidden bg-black/80 items-center justify-center">
  <div class="bg-white rounded-xl p-4 w-full max-w-2xl max-h-[90vh] flex flex-col">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-semibold">Crop Image</h3>
      <button type="button" id="closeCropModal" class="text-gray-500 hover:text-gray-800"><i class="fa-solid fa-xmark text-xl"></i></button>
    </div>
    <div class="flex-1 w-full bg-gray-100 overflow-hidden relative" style="min-height: 400px;">
      <img id="cropperImage" src="" class="block max-w-full">
    </div>
    <div class="mt-4 flex justify-end gap-3">
      <button type="button" id="cancelCrop" class="px-4 py-2 border border-gray-200 rounded-lg hover:bg-gray-50">Cancel</button>
      <button type="button" id="saveCrop" class="px-4 py-2 bg-brand-orange text-white rounded-lg hover:bg-opacity-90">Save Crop</button>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // --- Dynamic Variants Logic ---
    const variantsBody = document.getElementById('variantsBody');
    const addVariantBtn = document.getElementById('addVariantBtn');
    const productNameInput = document.getElementById('productName');
    const availableColorsInput = document.getElementById('availableColors');

    function getSelectedColors() {
        return availableColorsInput.value.split(',')
            .map(c => c.trim())
            .filter(c => c.length > 0);
    }

    function updateColorDropdowns() {
        const colors = getSelectedColors();
        document.querySelectorAll('.variant-color-select').forEach(select => {
            const currentValue = select.value;
            select.innerHTML = '<option value="" disabled ' + (currentValue === "" ? 'selected' : '') + '>Select Color</option>';
            colors.forEach(color => {
                const option = document.createElement('option');
                option.value = color;
                option.textContent = color;
                if (color === currentValue) option.selected = true;
                select.appendChild(option);
            });
        });
    }

    availableColorsInput.addEventListener('input', updateColorDropdowns);

    function generateSKU(name, color, size) {
        if (!name || !color || !size) return '';
        const productCode = name
            .split(' ')
            .map(word => word[0])
            .join('')
            .toUpperCase();
        const colorCode = color.slice(0, 3).toUpperCase();
        return `${productCode}-${colorCode}-${size.toUpperCase()}`;
    }

    function updateRowSKU(row) {
        const name = productNameInput.value.trim();
        const color = row.querySelector('[name="variantColor"]').value.trim();
        const size = row.querySelector('[name="variantSize"]').value;
        const skuInput = row.querySelector('[name="variantSku"]');
        if (name && color && size) {
            skuInput.value = generateSKU(name, color, size);
        }
    }

    function updateAllSKUs() {
        document.querySelectorAll('.variant-row').forEach(row => updateRowSKU(row));
    }

    productNameInput.addEventListener('input', updateAllSKUs);

    addVariantBtn.addEventListener('click', () => {
        const colors = getSelectedColors();
        let colorOptions = '<option value="" disabled selected>Select Color</option>';
        colors.forEach(c => {
            colorOptions += `<option value="${c}">${c}</option>`;
        });

        const tr = document.createElement('tr');
        tr.className = "variant-row border-b border-gray-50";
        tr.innerHTML = `
            <td class="px-4 py-2">
                <select name="variantColor" required
                        class="variant-color-select px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                    ${colorOptions}
                </select>
            </td>
            <td class="px-4 py-2">
                <select name="variantSize" required
                        class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
                    <option value="S">S</option>
                    <option value="M">M</option>
                    <option value="L" selected>L</option>
                </select>
            </td>
            <td class="px-4 py-2">
                <input type="number" name="variantStock" min="0" value="0" required
                       class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
            </td>
            <td class="px-4 py-2">
                <input type="text" name="variantSku" placeholder="SKU-XXX" required
                       class="px-3 py-1 border border-gray-200 rounded-md focus:ring-1 focus:ring-brand-orange/50 focus:border-brand-orange outline-none w-full">
            </td>
            <td class="px-4 py-2 text-center">
                <button type="button" class="text-red-500 hover:text-red-700 remove-variant-btn">
                    <i class="fa-solid fa-trash-can"></i>
                </button>
            </td>
        `;
        variantsBody.appendChild(tr);
        updateRowSKU(tr); // Initial SKU if name is present
    });

    variantsBody.addEventListener('input', (e) => {
        if (e.target.name === 'variantColor' || e.target.name === 'variantSize' || e.target.classList.contains('variant-color-select')) {
            updateRowSKU(e.target.closest('tr'));
        }
    });

    variantsBody.addEventListener('change', (e) => {
        if (e.target.name === 'variantSize' || e.target.name === 'variantColor') {
            updateRowSKU(e.target.closest('tr'));
        }
    });

    variantsBody.addEventListener('click', (e) => {
        if (e.target.closest('.remove-variant-btn')) {
            const rows = document.querySelectorAll('.variant-row');
            if (rows.length > 1) {
                e.target.closest('tr').remove();
            } else {
                Swal.fire("Required", "Product must have at least one variant.", "warning");
            }
        }
    });

    // Initialize SKUs
    updateAllSKUs();

    let croppedFiles = []; // Array of { id, file_blob }
    let currentCropper = null;
    let generateIdCounter = 0;

    const imageInput = document.getElementById('imageInput');
    const cropperModal = document.getElementById('cropperModal');
    const cropperImage = document.getElementById('cropperImage');
    const previewContainer = document.getElementById('imagePreviewContainer');
    const uploadTriggerLabel = document.getElementById('uploadTriggerLabel');

    // Handle file selection
    imageInput.addEventListener('change', function(e) {
        if (croppedFiles.length >= 4) {
            Swal.fire("Limit Reached", "You can only upload a maximum of 4 images.", "warning");
            this.value = '';
            return;
        }

        const files = e.target.files;
        if (files && files.length > 0) {
            const file = files[0];
            const reader = new FileReader();
            reader.onload = function(event) {
                cropperImage.src = event.target.result;
                cropperModal.classList.remove('hidden');
                cropperModal.classList.add('flex');
                
                if (currentCropper) currentCropper.destroy();
                
                currentCropper = new Cropper(cropperImage, {
                    aspectRatio: 1, // 1:1 square crop
                    viewMode: 1,
                    autoCropArea: 1,
                    background: false
                });
            };
            reader.readAsDataURL(file);
        }
        // clear input so same file can be selected again
        this.value = '';
    });

    // Cancel crop
    document.getElementById('cancelCrop').addEventListener('click', closeCrop);
    document.getElementById('closeCropModal').addEventListener('click', closeCrop);

    function closeCrop() {
        cropperModal.classList.add('hidden');
        cropperModal.classList.remove('flex');
        if (currentCropper) {
            currentCropper.destroy();
            currentCropper = null;
        }
    }

    // Save Crop
    document.getElementById('saveCrop').addEventListener('click', function() {
        if (!currentCropper) return;
        
        currentCropper.getCroppedCanvas({
            width: 800,
            height: 800
        }).toBlob((blob) => {
            const id = 'img_' + generateIdCounter++;
            const file = new File([blob], id + '.webp', { type: 'image/webp' });
            
            croppedFiles.push({ id, file });
            renderPreviews();
            closeCrop();
        }, 'image/webp', 0.9);
    });

    // Render preview thumbnails
    function renderPreviews() {
        // Clear existing previews
        document.querySelectorAll('.img-preview-item').forEach(el => el.remove());
        
        croppedFiles.forEach(item => {
            const url = URL.createObjectURL(item.file);
            const div = document.createElement('div');
            div.className = "img-preview-item relative w-32 h-32 rounded-xl border border-gray-200 overflow-hidden shadow-sm group";
            div.innerHTML = `
                <img src="${url}" class="w-full h-full object-cover">
                <button type="button" onclick="removeImage('${item.id}')" class="absolute top-1 right-1 w-6 h-6 bg-white rounded-full flex items-center justify-center text-red-500 shadow hover:bg-red-50 opacity-0 group-hover:opacity-100 transition-opacity">
                    <i class="fa-solid fa-xmark text-xs"></i>
                </button>
            `;
            previewContainer.insertBefore(div, uploadTriggerLabel);
        });

        // Hide upload button if 4 images
        if (croppedFiles.length >= 4) {
            uploadTriggerLabel.style.display = 'none';
        } else {
            uploadTriggerLabel.style.display = 'flex';
        }
    }

    // Remove image
    window.removeImage = function(id) {
        croppedFiles = croppedFiles.filter(item => item.id !== id);
        renderPreviews();
    };

    // Main Form Submit
    document.getElementById('addProductForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Reset errors
        document.querySelectorAll('[id^="err-"]').forEach(el => {
            el.classList.add('hidden');
            el.textContent = '';
        });

        const name = document.getElementById('productName').value.trim();
        const category = document.getElementById('category').value;
        const desc = document.getElementById('description').value.trim();
        const regPrice = parseFloat(document.getElementById('regularPrice').value);
        const availableColors = getSelectedColors();

        // Collect Variants
        const variantRows = document.querySelectorAll('.variant-row');
        const variants = [];
        let variantErr = '';

        variantRows.forEach(row => {
            const col = row.querySelector('[name="variantColor"]').value;
            const sz = row.querySelector('[name="variantSize"]').value;
            const stk = parseInt(row.querySelector('[name="variantStock"]').value);
            const sk = row.querySelector('[name="variantSku"]').value.trim();

            if (!col || !sz || isNaN(stk) || !sk) {
                variantErr = 'All variant fields are required';
            }
            
            // Check for duplicate color+size combination
            const duplicate = variants.find(v => v.color.toLowerCase() === col.toLowerCase() && v.size === sz);
            if (duplicate) {
                variantErr = `Duplicate variant combination: ${col} - ${sz}`;
            }

            variants.push({ color: col, size: sz, stock: stk, sku: sk });
        });

        let hasError = false;

        const showError = (id, msg) => {
            const el = document.getElementById('err-' + id);
            if (el) {
                el.textContent = msg;
                el.classList.remove('hidden');
            }
            hasError = true;
        }

        if (name.length < 3) showError('productName', 'Name must be at least 3 characters');
        if (!category) showError('category', 'Category is required');
        if (desc.length < 10) showError('description', 'Description minimum 10 characters');
        if (isNaN(regPrice) || regPrice <= 0) showError('regularPrice', 'Please enter a valid price');
        if (availableColors.length === 0) showError('availableColors', 'At least one color is required');
        
        if (variants.length === 0) showError('variants', 'At least one variant is required');
        if (variantErr) showError('variants', variantErr);

        if (croppedFiles.length < 3) {
            showError('images', 'Minimum 3 images required');
        }

        if (hasError) return;

        const formData = new FormData();
        formData.append('productName', name);
        formData.append('category', category);
        formData.append('description', desc);
        formData.append('highlights', document.getElementById('highlights').value.trim());
        formData.append('additionalInfo', document.getElementById('additionalInfo').value.trim());
        formData.append('regularPrice', regPrice);
        formData.append('salePrice', regPrice); // Initial salePrice is same as regularPrice
        formData.append('color', availableColors.join(','));
        formData.append('variants', JSON.stringify(variants));

        croppedFiles.forEach(item => {
            formData.append('productImages', item.file);
        });

        const submitBtn = document.getElementById('submitBtn');
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Saving...';
        submitBtn.disabled = true;

        try {
            const res = await fetch('/admin/addProduct', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json'
                },
                body: formData
            });
            let data;
            const text = await res.text();
            try {
                data = JSON.parse(text);
            } catch (e) {
                console.error("Non-JSON response:", text);
                throw new Error(`Server returned non-JSON response (${res.status})`);
            }
            
            if (res.ok) {
                Swal.fire({
                    icon: 'success',
                    title: 'Success',
                    text: data.message || "Product added successfully",
                    timer: 1500,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '/admin/products';
                });
            } else {
                Swal.fire('Error', data.error || data.message || 'Failed to add product', 'error');
                submitBtn.innerHTML = 'Save Product';
                submitBtn.disabled = false;
            }
        } catch (err) {
            console.error("Add Product Error:", err);
            Swal.fire('Error', err.message || 'Network error occurred', 'error');
            submitBtn.innerHTML = 'Save Product';
            submitBtn.disabled = false;
        }
    });
</script>

<%- include("./partials/adminFooter") %>
