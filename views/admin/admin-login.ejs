<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login | RARO</title>

  <!-- Main shop theme + bootstrap (same assets as user side) -->
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

  <style>
    :root {
      --rar-gold: #cc9966;
      --rar-dark: #333333;
      --rar-bg: #fdfbf8;
      --rar-text: #2d2d2d;
      --rar-text-muted: #7a7a7a;
    }

    body {
      min-height: 100vh;
      margin: 0;
      font-family: "Outfit", "Poppins", sans-serif;
      background: #ffffff;
      color: var(--rar-text);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .admin-login-shell {
      width: 100%;
      max-width: 450px;
      padding: 20px;
    }

    .admin-login-card {
      background: #ffffff;
      border-radius: 24px;
      padding: 45px 40px;
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.08);
      border: 1px solid rgba(204, 153, 102, 0.15);
      text-align: center;
    }

    .admin-login-logo {
      margin-bottom: 35px;
      display: flex;
      justify-content: center;
    }

    .admin-login-logo img {
      height: 120px;
      object-fit: contain;
    }

    .admin-login-title {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 3px;
      letter-spacing: -0.5px;
      color: var(--rar-dark);
      margin-top: -41px;
    }

    .admin-login-sub {
      font-size: 1.1rem;
      color: var(--rar-text-muted);
      margin-bottom: 35px;
      font-weight: 300;
    }

    .form-group {
      text-align: left;
      margin-bottom: 22px;
    }

    .form-label {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 8px;
      display: block;
      color: #8c6d4a;
    }

    .form-control {
      background: #fcfcfc !important;
      border: 1.5px solid #ececec !important;
      border-radius: 12px !important;
      padding: 14px 18px !important;
      font-size: 1.1rem !important;
      color: var(--rar-text) !important;
      transition: all 0.3s ease;
    }

    .form-control::placeholder {
      color: #bdbdbd;
    }

    .form-control:focus {
      background: #ffffff !important;
      border-color: #cc9966 !important;
      box-shadow: 0 0 15px rgba(204, 153, 102, 0.1) !important;
      outline: none;
    }

    .btn-rar {
      background: linear-gradient(135deg, #cc9966 0%, #b38659 100%);
      border: none;
      color: #fff;
      border-radius: 12px;
      font-weight: 600;
      width: 100%;
      padding: 16px;
      font-size: 1.15rem;
      margin-top: 10px;
      cursor: pointer;
      transition: all 0.3s ease;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .btn-rar:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(204, 153, 102, 0.25);
      background: linear-gradient(135deg, #b38659 0%, #cc9966 100%);
      color: #fff;
    }

    .btn-rar:active {
      transform: translateY(0);
    }

    .admin-login-footer {
      margin-top: 30px;
      font-size: 1rem;
      color: var(--rar-text-muted);
    }

    .admin-login-footer a {
      color: #cc9966;
      text-decoration: none;
      font-weight: 600;
      transition: color 0.2s;
    }

    .admin-login-footer a:hover {
      color: #8c6d4a;
      text-decoration: underline;
    }

    .error-msg {
      color: #e53935;
      font-size: 0.95rem;
      margin-top: 6px;
      display: none;
      font-weight: 500;
    }

    .alert-danger {
      background: #fff8f8;
      border: 1px solid #ffebeb;
      color: #e53935;
      border-radius: 12px;
      margin-bottom: 25px;
      font-size: 1.05rem;
      padding: 14px;
      font-weight: 500;
    }
  </style>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
  <div class="admin-login-shell">
    <div class="admin-login-card">
      <div class="admin-login-logo">
        <img src="/assets/images/RARO Logo.png" alt="RARO Logo" />
      </div>

      <h1 class="admin-login-title">Admin Login</h1>
      <p class="admin-login-sub">Secure access to your dashboard</p>

      <% if (locals.message) { %>
        <div class="alert alert-danger" style="background: rgba(255, 77, 77, 0.1); border: 1px solid rgba(255, 77, 77, 0.2); color: #ff4d4d; border-radius: 12px; margin-bottom: 20px; font-size: 1rem; padding: 12px;">
          <%= message %>
        </div>
      <% } %>

      <form method="post" action="/admin/login" id="adminLoginForm">
        <div class="form-group">
          <label class="form-label" for="admin-email">Email Address</label>
          <input type="text" class="form-control" id="admin-email" name="email" placeholder="admin@raro.com" />
          <div id="email-error" class="error-msg"></div>
        </div>

        <div class="form-group">
          <label class="form-label" for="admin-password">Password</label>
          <input type="password" class="form-control" id="admin-password" name="password" placeholder="Enter your password" />
          <div id="password-error" class="error-msg"></div>
        </div>

        <button type="submit" class="btn btn-rar">
          Login to Dashboard
        </button>
      </form>

      <div class="admin-login-footer">
        <span>Need to return? <a href="/">Go to Store</a></span>
      </div>
    </div>
  </div>

  <script src="/assets/js/jquery.min.js"></script>
  <script src="/assets/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('adminLoginForm').addEventListener('submit', function(e) {
      const email = document.getElementById('admin-email').value.trim();
      const password = document.getElementById('admin-password').value.trim();
      
      const emailError = document.getElementById('email-error');
      const passwordError = document.getElementById('password-error');
      
      let isValid = true;
      
      // Reset errors
      emailError.style.display = 'none';
      passwordError.style.display = 'none';
      
      // Basic Email Regex
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      
      if (!email) {
        emailError.textContent = 'Email is required';
        emailError.style.display = 'block';
        isValid = false;
      } else if (!emailPattern.test(email)) {
        emailError.textContent = 'Please enter a valid email address';
        emailError.style.display = 'block';
        isValid = false;
      }
      
      if (!password) {
        passwordError.textContent = 'Password is required';
        passwordError.style.display = 'block';
        isValid = false;
      }
      
      if (!isValid) {
        e.preventDefault();
      }
    });
  </script>
</body>

</html>