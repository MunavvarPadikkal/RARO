<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login | RARO</title>

    <!-- Main shop theme + bootstrap (same assets as user side) -->
    <link rel="stylesheet" href="/assets/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/assets/css/style.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />

    <style>
      :root {
        --rar-primary: #cc9966; /* gold accent, same as site */
        --rar-bg: #f6f7fb;
        --rar-text: #222;
      }

      body {
        min-height: 100vh;
        margin: 0;
        font-family: "Poppins", sans-serif;
        background: var(--rar-bg);
        color: var(--rar-text);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .admin-login-shell {
        width: 100%;
        max-width: 420px;
        padding: 16px;
      }

      .admin-login-card {
        background: #ffffff;
        border-radius: 18px;
        padding: 20px 22px 18px;
        box-shadow: 0 18px 45px rgba(0, 0, 0, 0.09);
        border: 1px solid rgba(0, 0, 0, 0.04);
      }

      .admin-login-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 18px;
      }

      .admin-login-logo img {
        height: 88px; /* big RARO logo */
        object-fit: contain;
      }

      .admin-login-title {
        font-size: 1.8rem;
        font-weight: 600;
        margin-bottom: 4px;
        text-align: center;
      }

      .admin-login-sub {
        font-size: 1rem;
        color: #6c757d;
        margin-bottom: 12px;
        text-align: center;
      }

      .form-label {
        font-size: 1rem;
        font-weight: 500;
        margin-bottom: 0; /* no extra gap under label */
      }

      .form-control {
        border-radius: 999px;
        padding: 0.8rem 1.1rem; /* bigger, neat inputs */
        font-size: 1rem;
        background-color: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.16);
        color: var(--rar-text);
      }

      .form-control::placeholder {
        color: #b0b5bd;
      }

      /* remove vertical gap between the two fields */
      .admin-login-card .mb-3 {
        margin-bottom: 0;
      }

      .btn-rar {
        background-color: #000; /* black button like user login */
        border-color: #000;
        color: #fff;
        border-radius: 999px;
        font-weight: 500;
        width: 100%;
        padding: 0.7rem 1rem;
        font-size: 0.98rem;
        margin-top: 6px;
      }

      .btn-rar:hover {
        background-color: #111;
        border-color: #111;
        color: #fff;
      }

      .admin-login-footer {
        margin-top: 12px;
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #6c757d;
      }

      .admin-login-footer a {
        color: var(--rar-primary);
        text-decoration: none;
      }
    </style>
  </head>

  <body>
    <div class="admin-login-shell">
      <div class="admin-login-card">
        <div class="admin-login-logo">
          <!-- Big RARO logo from user side assets -->
          <img src="/assets/images/RARO Logo.png" alt="RARO Logo" />
        </div>

        <h1 class="admin-login-title">Admin login</h1>
        <p class="admin-login-sub">
          Use your admin credentials to access the dashboard.
        </p>

        <!-- You will wire this action + method yourself -->
        <form method="post" action="/admin/login">
          <div class="mb-3">
            <label class="form-label" for="admin-email">Email</label>
            <input
              type="email"
              class="form-control"
              id="admin-email"
              name="email"
              placeholder="admin@raro.com"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label" for="admin-password">Password</label>
            <input
              type="password"
              class="form-control"
              id="admin-password"
              name="password"
              placeholder="Enter password"
              required
            />
          </div>

          <button type="submit" class="btn btn-rar">
            <span>Login to dashboard</span>
          </button>
        </form>

        <div class="admin-login-footer">
          <span>Back to store? <a href="/">Go to RARO</a></span>
        </div>
      </div>
    </div>

    <script src="/assets/js/jquery.min.js"></script>
    <script src="/assets/js/bootstrap.bundle.min.js"></script>
  </body>
</html>

