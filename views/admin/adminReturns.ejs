<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="admin-main flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>
  <main class="px-8 pb-8">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900">Return Requests</h2>
      <div class="flex items-center gap-3">
        <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-semibold"><%= totalItems %> total item returns</span>
      </div>
    </div>

    <!-- Filters -->
    <form method="GET" action="/admin/return-requests" class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 mb-6">
      <div class="flex gap-4 items-end flex-wrap">
        <div class="flex-1 min-w-[200px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
          <div class="relative">
            <input type="text" name="search" value="<%= search %>" placeholder="Order ID, Product or Customer..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-orange-300">
            <% if (search) { %>
              <a href="/admin/return-requests" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-orange-500 transition-colors">
                <i class="fa-solid fa-xmark"></i>
              </a>
            <% } %>
          </div>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1">Status</label>
          <select name="returnStatus" class="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-300">
            <option value="">All</option>
            <option value="Return Requested" <%= returnStatus === 'Return Requested' ? 'selected' : '' %>>Requested</option>
            <option value="Return Approved" <%= returnStatus === 'Return Approved' ? 'selected' : '' %>>Approved</option>
            <option value="Return Rejected" <%= returnStatus === 'Return Rejected' ? 'selected' : '' %>>Rejected</option>
            <option value="Returned" <%= returnStatus === 'Returned' ? 'selected' : '' %>>Returned</option>
          </select>
        </div>
        <button type="submit" class="px-4 py-2 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-800">
          <i class="fa-solid fa-search mr-1"></i> Filter
        </button>
        <a href="/admin/return-requests" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-200">Clear</a>
      </div>
    </form>

    <!-- Return Requests Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <% if (returnItems && returnItems.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 text-gray-600 text-xs uppercase tracking-wider">
                <th class="px-4 py-3 text-left">#</th>
                <th class="px-4 py-3 text-left">Product</th>
                <th class="px-4 py-3 text-left">Order ID</th>
                <th class="px-4 py-3 text-left">Customer</th>
                <th class="px-4 py-3 text-left">Reason</th>
                <th class="px-4 py-3 text-center">Status</th>
                <th class="px-4 py-3 text-center">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% returnItems.forEach((row, idx) => { %>
                <%
                  const item = row.orderedItems;
                  const user = row.userDetails;
                  let retBadge = 'bg-yellow-100 text-yellow-700';
                  if (item.itemStatus === 'Return Approved') retBadge = 'bg-emerald-100 text-emerald-700';
                  else if (item.itemStatus === 'Return Rejected') retBadge = 'bg-rose-100 text-rose-700';
                  else if (item.itemStatus === 'Returned') retBadge = 'bg-purple-100 text-purple-700';
                %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3 text-gray-500"><%= (currentPage - 1) * 10 + idx + 1 %></td>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded overflow-hidden border border-gray-100 flex-shrink-0">
                        <img src="/uploads/productImages/<%= item.productImage %>" alt="" class="w-full h-full object-cover">
                      </div>
                      <div class="min-w-0">
                        <div class="font-medium text-gray-900 truncate max-w-[150px]"><%= item.productName %></div>
                        <div class="text-[10px] text-gray-400">Size: <%= item.size %> <%= item.color ? '· ' + item.color : '' %></div>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 font-mono font-semibold text-orange-600 text-xs">
                    <a href="/admin/orders/<%= row._id %>" class="hover:underline"><%= row.orderId %></a>
                  </td>
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900"><%= user ? user.name : 'N/A' %></div>
                    <div class="text-xs text-gray-400"><%= user ? user.email : '' %></div>
                  </td>
                  <td class="px-4 py-3 text-gray-600 max-w-[200px] truncate" title="<%= item.returnReason || '' %>">
                    <%= item.returnReason || 'N/A' %>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <span class="inline-block px-2 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= retBadge %>"><%= item.itemStatus %></span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <div class="flex gap-2 justify-center">
                      <% if (item.itemStatus === 'Return Requested') { %>
                        <button onclick="approveItemReturn('<%= row._id %>', '<%= item._id %>')" class="w-8 h-8 bg-emerald-500 text-white rounded-lg flex items-center justify-center hover:bg-emerald-600 transition-colors" title="Approve">
                          <i class="fa-solid fa-check text-xs"></i>
                        </button>
                        <button onclick="rejectItemReturn('<%= row._id %>', '<%= item._id %>')" class="w-8 h-8 bg-rose-500 text-white rounded-lg flex items-center justify-center hover:bg-rose-600 transition-colors" title="Reject">
                          <i class="fa-solid fa-xmark text-xs"></i>
                        </button>
                      <% } else if (item.itemStatus === 'Return Approved') { %>
                        <button onclick="completeItemReturn('<%= row._id %>', '<%= item._id %>')" class="px-2 py-1 bg-purple-500 text-white rounded-lg text-[10px] font-bold hover:bg-purple-600 transition-colors uppercase" title="Mark as Returned">
                          Returned
                        </button>
                      <% } %>
                      <a href="/admin/orders/<%= row._id %>" class="w-8 h-8 bg-gray-900 text-white rounded-lg flex items-center justify-center hover:bg-gray-700 transition-colors" title="View Order">
                        <i class="fa-solid fa-eye text-xs"></i>
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div class="flex justify-center items-center gap-2 p-4 border-t border-gray-100">
            <% if (currentPage > 1) { %>
              <a href="/admin/return-requests?page=<%= currentPage - 1 %>&search=<%= search %>&returnStatus=<%= returnStatus %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 text-gray-600 hover:bg-gray-200">‹ Prev</a>
            <% } %>
            <% 
                const delta = 2;
                const left = parseInt(currentPage) - delta;
                const right = parseInt(currentPage) + delta + 1;
                const range = [];
                const rangeWithDots = [];
                let l;

                for (let i = 1; i <= totalPages; i++) {
                    if (i == 1 || i == totalPages || (i >= left && i < right)) {
                        range.push(i);
                    }
                }

                for (let i of range) {
                    if (l) {
                        if (i - l === 2) {
                            rangeWithDots.push(l + 1);
                        } else if (i - l !== 1) {
                            rangeWithDots.push('...');
                        }
                    }
                    rangeWithDots.push(i);
                    l = i;
                }
            %>

            <% rangeWithDots.forEach(i => { %>
                <% if (i === '...') { %>
                    <span class="px-3 py-1.5 text-gray-400">...</span>
                <% } else { %>
                    <a href="/admin/return-requests?page=<%= i %>&search=<%= search %>&returnStatus=<%= returnStatus %>" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= i === currentPage ? 'bg-orange-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>"><%= i %></a>
                <% } %>
            <% }) %>
            <% if (currentPage < totalPages) { %>
              <a href="/admin/return-requests?page=<%= currentPage + 1 %>&search=<%= search %>&returnStatus=<%= returnStatus %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 text-gray-600 hover:bg-gray-200">Next ›</a>
            <% } %>
          </div>
        <% } %>
      <% } else { %>
        <div class="text-center py-16">
          <i class="fa-solid fa-rotate-left text-5xl text-gray-300 mb-4"></i>
          <h3 class="text-lg font-semibold text-gray-500 mb-2">No return requests</h3>
          <p class="text-sm text-gray-400">
            <% if (search || returnStatus) { %>
              Try adjusting your filters or <a href="/admin/return-requests" class="text-orange-500 underline">clear all filters</a>
            <% } else { %>
              No return requests have been submitted yet.
            <% } %>
          </p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  async function approveItemReturn(orderId, itemId) {
    const result = await Swal.fire({ title: 'Approve Item Return?', text: 'Stock will be restored.', icon: 'question', showCancelButton: true, confirmButtonColor: '#10b981', confirmButtonText: 'Approve', reverseButtons: true });
    if (result.isConfirmed) {
      try {
        const res = await fetch(`/admin/returns/${orderId}/items/${itemId}/approve`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) Swal.fire('Approved!', data.message, 'success').then(() => location.reload());
        else Swal.fire('Error', data.message, 'error');
      } catch (err) { Swal.fire('Error', 'Something went wrong', 'error'); }
    }
  }

  async function rejectItemReturn(orderId, itemId) {
    const result = await Swal.fire({ title: 'Reject Item Return?', text: 'Return request will be rejected.', icon: 'warning', showCancelButton: true, confirmButtonColor: '#f43f5e', confirmButtonText: 'Reject', reverseButtons: true });
    if (result.isConfirmed) {
      try {
        const res = await fetch(`/admin/returns/${orderId}/items/${itemId}/reject`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) Swal.fire('Rejected', data.message, 'success').then(() => location.reload());
        else Swal.fire('Error', data.message, 'error');
      } catch (err) { Swal.fire('Error', 'Something went wrong', 'error'); }
    }
  }

  async function completeItemReturn(orderId, itemId) {
    const result = await Swal.fire({ title: 'Mark as Returned?', text: 'Confirm that product has been received.', icon: 'question', showCancelButton: true, confirmButtonColor: '#a855f7', confirmButtonText: 'Yes, Returned', reverseButtons: true });
    if (result.isConfirmed) {
      try {
        const res = await fetch(`/admin/returns/${orderId}/items/${itemId}/complete`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
        const data = await res.json();
        if (data.success) Swal.fire('Success!', data.message, 'success').then(() => location.reload());
        else Swal.fire('Error', data.message, 'error');
      } catch (err) { Swal.fire('Error', 'Something went wrong', 'error'); }
    }
  }
</script>

<%- include("./partials/adminFooter") %>
