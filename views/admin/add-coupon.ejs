<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="max-w-4xl mx-auto">
        <div class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold text-gray-900">Create Coupon</h2>
                <p class="text-sm text-gray-500 mt-1">Set up a new discount coupon for your store.</p>
            </div>
            <a href="/admin/coupons" class="px-4 py-2 text-sm font-medium text-gray-600 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 transition-all flex items-center gap-2">
                <i class="fa-solid fa-arrow-left text-xs"></i>
                Back to List
            </a>
        </div>

        <div class="bg-white rounded-[24px] shadow-sm border border-gray-100 overflow-hidden">
            <form id="couponForm" class="p-8 space-y-8" novalidate>
                <!-- Section 1: Basic Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-50 pb-2 flex items-center gap-2">
                            <i class="fa-solid fa-tag text-brand-orange text-sm"></i>
                            Coupon Identification
                        </h3>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Coupon Code <span class="text-red-500">*</span></label>
                            <input type="text" name="code" id="code" required placeholder="e.g. SUMMER50" 
                                   class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all uppercase font-bold tracking-wider">
                            <span id="codeError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            <p class="text-[11px] text-gray-400 mt-1.5 italic">Must be unique and uppercase. e.g. FESTIVE2024</p>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-50 pb-2 flex items-center gap-2">
                            <i class="fa-solid fa-percent text-brand-orange text-sm"></i>
                            Discount Rules
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Type <span class="text-red-500">*</span></label>
                                <select name="discountType" id="discountType" required
                                        class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                    <option value="percentage">Percentage (%)</option>
                                    <option value="fixed">Fixed Amount (₹)</option>
                                </select>
                                <span id="discountTypeError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Value <span class="text-red-500">*</span></label>
                                <input type="number" name="discountValue" id="discountValue" required min="1" placeholder="Value" 
                                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                <span id="discountValueError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Limits & Conditions -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="space-y-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-50 pb-2 flex items-center gap-2">
                            <i class="fa-solid fa-sliders text-brand-orange text-sm"></i>
                            Thresholds
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Min Purchase (₹) <span class="text-red-500">*</span></label>
                                <input type="number" name="minPurchase" id="minPurchase" required min="0" value="0"
                                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                <span id="minPurchaseError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                            <div id="maxDiscountField">
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Max Discount (₹)</label>
                                <input type="number" name="maxDiscount" id="maxDiscount" min="0" value="0"
                                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                <span id="maxDiscountError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-4">
                        <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-50 pb-2 flex items-center gap-2">
                            <i class="fa-solid fa-users text-brand-orange text-sm"></i>
                            Usage Limits
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Total Limit <span class="text-red-500">*</span></label>
                                <input type="number" name="totalUsageLimit" id="totalUsageLimit" required min="1" value="100"
                                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                <span id="totalUsageLimitError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1.5">Limit Per User <span class="text-red-500">*</span></label>
                                <input type="number" name="perUserLimit" id="perUserLimit" required min="1" value="1"
                                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                                <span id="perUserLimitError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Section 3: Duration -->
                <div class="space-y-4">
                    <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-50 pb-2 flex items-center gap-2">
                        <i class="fa-solid fa-calendar-days text-brand-orange text-sm"></i>
                        Validity Period
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Start Date <span class="text-red-500">*</span></label>
                            <input type="date" name="startDate" required id="startDate"
                                   class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                            <span id="startDateError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1.5">Expiry Date <span class="text-red-500">*</span></label>
                            <input type="date" name="expiryDate" required id="expiryDate"
                                   class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                            <span id="expiryDateError" class="text-red-500 text-[11px] mt-1 hidden"></span>
                        </div>
                    </div>
                </div>

                <!-- Submit Button -->
                <div class="pt-6 border-t border-gray-50 flex items-center justify-end gap-4">
                    <button type="button" onclick="window.history.back()" class="px-8 py-3 text-sm font-medium text-gray-600 bg-gray-100 rounded-xl hover:bg-gray-200 transition-all">
                        Cancel
                    </button>
                    <button type="submit" class="px-10 py-3 bg-brand-orange text-white rounded-xl text-sm font-semibold shadow-lg shadow-brand-orange/20 hover:bg-opacity-90 transition-all flex items-center gap-2">
                        <i class="fa-solid fa-rocket text-xs"></i>
                        Publish Coupon
                    </button>
                </div>
            </form>
        </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // Set default dates
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('startDate').value = today;
    document.getElementById('startDate').min = today;
    document.getElementById('expiryDate').min = today;

    // Toggle Max Discount field based on type
    document.getElementById('discountType').addEventListener('change', function() {
        const field = document.getElementById('maxDiscountField');
        if (this.value === 'percentage') {
            field.style.opacity = '1';
            field.style.pointerEvents = 'auto';
        } else {
            field.style.opacity = '0.5';
            field.style.pointerEvents = 'none';
            field.querySelector('input').value = 0;
        }
    });

    document.getElementById('couponForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // Clear previous errors
        document.querySelectorAll('[id$="Error"]').forEach(el => {
            el.textContent = '';
            el.classList.add('hidden');
        });

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());
        let isValid = true;

        const showError = (id, msg) => {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.classList.remove('hidden');
            isValid = false;
        };

        // 1. Code Validation
        const codeRegex = /^[A-Z0-9]+$/;
        if (!data.code || data.code.trim().length < 3) {
            showError('codeError', 'Code must be at least 3 characters.');
        } else if (!codeRegex.test(data.code.toUpperCase())) {
            showError('codeError', 'Code must be alphanumeric and uppercase.');
        }

        // 2. Discount Value Validation
        const discountVal = parseFloat(data.discountValue);
        if (isNaN(discountVal) || discountVal <= 0) {
            showError('discountValueError', 'Value must be greater than 0.');
        } else if (data.discountType === 'percentage' && discountVal > 100) {
            showError('discountValueError', 'Percentage cannot exceed 100%.');
        }

        // 3. Min Purchase Validation
        const minPur = parseFloat(data.minPurchase);
        if (isNaN(minPur) || minPur < 0) {
            showError('minPurchaseError', 'Min purchase cannot be negative.');
        }

        // 4. Max Discount Validation (for percentage)
        if (data.discountType === 'percentage') {
            const maxDisc = parseFloat(data.maxDiscount);
            if (isNaN(maxDisc) || maxDisc < 0) {
                showError('maxDiscountError', 'Max discount cannot be negative.');
            }
        }

        // 5. Usage Limits
        const totalLimit = parseInt(data.totalUsageLimit);
        const perUserLimit = parseInt(data.perUserLimit);
        if (isNaN(totalLimit) || totalLimit < 1) {
            showError('totalUsageLimitError', 'Total limit must be at least 1.');
        }
        if (isNaN(perUserLimit) || perUserLimit < 1) {
            showError('perUserLimitError', 'Per user limit must be at least 1.');
        } else if (perUserLimit > totalLimit) {
            showError('perUserLimitError', 'Per user limit cannot exceed total limit.');
        }

        // 6. Date Validation
        const start = new Date(data.startDate);
        const expiry = new Date(data.expiryDate);
        const todayDate = new Date();
        todayDate.setHours(0,0,0,0);

        if (!data.startDate) {
            showError('startDateError', 'Start date is required.');
        } else if (start < todayDate) {
            showError('startDateError', 'Start date cannot be in the past.');
        }

        if (!data.expiryDate) {
            showError('expiryDateError', 'Expiry date is required.');
        } else if (expiry <= start) {
            showError('expiryDateError', 'Expiry date must be after start date.');
        }

        if (!isValid) return;

        try {
            const response = await fetch('/admin/addCoupon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            
            if (result.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Created!',
                    text: result.message,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => window.location.href = '/admin/coupons');
            } else {
                Swal.fire('Error', result.message, 'error');
            }
        } catch (error) {
            Swal.fire('Error', 'Something went wrong', 'error');
        }
    });
</script>

<%- include("./partials/adminFooter") %>
