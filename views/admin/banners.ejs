<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 p-6">

      <!-- Card Header & Actions -->
      <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h2 class="text-xl font-semibold text-gray-900">Banners <span class="text-sm font-normal text-gray-400 ml-2">Management</span></h2>
        
        <div class="flex items-center gap-3 w-full md:w-auto">
          <!-- Search -->
          <form action="/admin/banners" method="get" class="relative flex items-center">
            <div class="relative flex items-center">
              <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
              <input type="text" name="search" placeholder="Search title..." value="<%= search %>" 
                     class="w-full md:w-56 pl-10 <%= search ? 'pr-10' : 'pr-4' %> py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
              
              <% if (search) { %>
                <a href="/admin/banners?status=<%= status %>" 
                   class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors p-1"
                   title="Clear search">
                  <i class="fa-solid fa-circle-xmark"></i>
                </a>
              <% } %>
            </div>
            
            <select name="status" onchange="this.form.submit()" class="ml-2 px-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                <option value="">All Status</option>
                <option value="active" <%= status === 'active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= status === 'inactive' ? 'selected' : '' %>>Inactive</option>
            </select>
          </form>
          
          <!-- Add Banner Button -->
          <a href="/admin/addBanner" class="px-5 py-2 bg-brand-orange text-white rounded-full text-sm font-medium hover:bg-opacity-90 transition-all flex items-center gap-2 whitespace-nowrap">
            <i class="fa-solid fa-plus text-xs"></i>
            Add Banner
          </a>
        </div>
      </div>

      <!-- Table Section -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50/50 border-b border-gray-100">
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Image</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Title</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Priority</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Start Date</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Expiry Date</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">Status</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100" id="bannerTableBody">
            <% if(banners && banners.length > 0) { %>
              <% banners.forEach((banner) => { %>
                <tr class="hover:bg-gray-50/50 transition-colors" data-id="<%= banner._id %>">
                  <td class="py-4 px-4">
                    <div class="w-28 h-16 rounded-xl overflow-hidden bg-gray-100 border border-gray-200 shadow-sm">
                      <img src="/uploads/bannerImages/<%= banner.imageUrl %>" alt="<%= banner.title %>" 
                           class="w-full h-full object-cover" loading="lazy">
                    </div>
                  </td>
                  <td class="py-4 px-4">
                    <div class="text-sm font-semibold text-gray-900"><%= banner.title %></div>
                    <% if (banner.subtitle) { %>
                      <div class="text-xs text-gray-400 mt-0.5"><%= banner.subtitle %></div>
                    <% } %>
                  </td>
                  <td class="py-4 px-4">
                    <span class="inline-flex items-center justify-center w-8 h-8 bg-gray-100 text-gray-700 rounded-lg text-sm font-bold">
                      <%= banner.priority %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-sm text-gray-500">
                    <%= banner.startDate ? new Date(banner.startDate).toLocaleDateString('en-IN') : '—' %>
                  </td>
                  <td class="py-4 px-4 text-sm text-gray-500">
                    <%
                      const now = new Date();
                      const isExpired = banner.expiryDate && new Date(banner.expiryDate) < now;
                    %>
                    <span class="<%= isExpired ? 'text-red-400' : '' %>">
                      <%= banner.expiryDate ? new Date(banner.expiryDate).toLocaleDateString('en-IN') : '—' %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-sm text-center">
                    <% if(isExpired) { %>
                      <span class="inline-block px-3 py-1 bg-gray-100 text-gray-500 rounded-full text-xs font-medium">Expired</span>
                    <% } else if(banner.isActive) { %>
                      <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-medium">Active</span>
                    <% } else { %>
                      <span class="inline-block px-3 py-1 bg-red-50 text-red-500 rounded-full text-xs font-medium">Inactive</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-sm text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a href="/admin/editBanner?id=<%= banner._id %>" class="p-2 text-blue-600 hover:bg-blue-50 rounded-lg transition-colors" title="Edit">
                        <i class="fa-solid fa-pen"></i>
                      </a>
                      
                      <% if(banner.isActive) { %>
                        <button onclick="confirmToggleStatus('<%= banner._id %>', false)" class="p-2 text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Disable">
                          <i class="fa-solid fa-ban"></i>
                        </button>
                      <% } else { %>
                        <button onclick="confirmToggleStatus('<%= banner._id %>', true)" class="p-2 text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors" title="Enable">
                          <i class="fa-solid fa-check"></i>
                        </button>
                      <% } %>

                      <button onclick="confirmDelete('<%= banner._id %>')" class="p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors" title="Delete">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="py-12 text-center text-sm text-gray-500">
                  <div class="flex flex-col items-center justify-center">
                    <i class="fa-regular fa-image text-5xl text-gray-100 mb-4"></i>
                    <p class="text-lg font-medium text-gray-400">No banners found</p>
                    <p class="text-gray-300">Create your first banner to get started</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination Section -->
      <% if(totalPages > 1) { %>
        <div class="mt-8 flex justify-center">
          <nav aria-label="Page navigation" class="flex items-center gap-2">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= status ? '&status=' + status : '' %>" 
                 class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-medium transition-all
                        <%= (i === parseInt(currentPage)) ? 'bg-brand-orange text-white shadow-md shadow-brand-orange/20' : 'bg-gray-50 text-gray-500 hover:bg-gray-100' %>">
                <%= i %>
              </a>
            <% } %>
          </nav>
        </div>
      <% } %>

    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    async function confirmToggleStatus(id, enable) {
        const result = await Swal.fire({
            title: enable ? 'Enable Banner?' : 'Disable Banner?',
            text: enable ? "This banner will be visible on the storefront." : "This banner will be hidden from the storefront.",
            icon: enable ? 'question' : 'warning',
            showCancelButton: true,
            confirmButtonColor: enable ? '#10b981' : '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: enable ? 'Yes, Enable' : 'Yes, Disable'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch('/admin/toggleBannerStatus', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Updated!', text: data.message, showConfirmButton: false, timer: 1500 })
                    .then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong' });
            }
        }
    }

    async function confirmDelete(id) {
        const result = await Swal.fire({
            title: 'Delete Banner?',
            text: "This banner will be removed from display.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Yes, Delete it'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch('/admin/deleteBanner', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const data = await response.json();
                if (data.success) {
                    Swal.fire({ icon: 'success', title: 'Deleted!', text: data.message, showConfirmButton: false, timer: 1500 })
                    .then(() => window.location.reload());
                } else {
                    Swal.fire({ icon: 'error', title: 'Error', text: data.message });
                }
            } catch (error) {
                Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong' });
            }
        }
    }
</script>

<%- include("./partials/adminFooter") %>
