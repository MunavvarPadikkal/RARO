<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="admin-main flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>
  <main class="px-8 pb-8">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Order Management</h2>
        <p class="text-sm text-gray-500 mt-1">View and manage all customer orders and their statuses.</p>
      </div>
      <div class="flex items-center gap-3">
        <span class="px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-semibold"><%= totalOrders %> Total Orders</span>
      </div>
    </div>

    <!-- Filters -->
    <form method="GET" action="/admin/orders" class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 mb-6">
      <div class="flex gap-4 items-end flex-wrap">
        <!-- Search -->
        <div class="flex-1 min-w-[250px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">Search</label>
          <div class="relative">
            <input type="text" name="search" value="<%= search %>" placeholder="Order ID or customer name..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-orange-300">
            <% if (search) { %>
              <a href="/admin/orders" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-orange-500 transition-colors">
                <i class="fa-solid fa-xmark"></i>
              </a>
            <% } %>
          </div>
        </div>
        <!-- Status Filter -->
        <div class="min-w-[140px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">Status</label>
          <select name="status" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-300">
            <option value="">All Statuses</option>
            <% const statuses = ["Placed","Pending","Shipped","Out for Delivery","Delivered","Cancelled","Return Requested","Return Approved","Return Rejected","Returned"]; %>
            <% statuses.forEach(s => { %>
              <option value="<%= s %>" <%= status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
        </div>
        <!-- Sort -->
        <div class="min-w-[120px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">Sort By</label>
          <select name="sortBy" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-300">
            <option value="createdOn" <%= sortBy === 'createdOn' ? 'selected' : '' %>>Date</option>
            <option value="finalAmount" <%= sortBy === 'finalAmount' ? 'selected' : '' %>>Amount</option>
          </select>
        </div>
        <!-- Sort Order -->
        <div class="min-w-[140px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">Order</label>
          <select name="sortOrder" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-300">
            <option value="desc" <%= sortOrder === 'desc' ? 'selected' : '' %>>Newest / Highest</option>
            <option value="asc" <%= sortOrder === 'asc' ? 'selected' : '' %>>Oldest / Lowest</option>
          </select>
        </div>
        <!-- Actions -->
        <button type="submit" class="px-4 py-2 bg-gray-900 text-white rounded-lg text-sm font-medium hover:bg-gray-800">
          <i class="fa-solid fa-search mr-1"></i> Filter
        </button>
        <a href="/admin/orders" class="px-4 py-2 bg-gray-100 text-gray-600 rounded-lg text-sm font-medium hover:bg-gray-200">Clear</a>
      </div>
      <!-- Date Range (second row) -->
      <div class="flex gap-4 mt-3 flex-wrap">
        <div class="min-w-[180px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">From Date</label>
          <input type="date" name="dateFrom" value="<%= dateFrom %>" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-orange-300">
        </div>
        <div class="min-w-[180px]">
          <label class="block text-xs font-medium text-gray-500 mb-1">To Date</label>
          <input type="date" name="dateTo" value="<%= dateTo %>" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-orange-300">
        </div>
      </div>
    </form>

    <!-- Orders Table -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      <% if (orders && orders.length > 0) { %>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 text-gray-600 text-xs uppercase tracking-wider">
                <th class="px-4 py-3 text-left">#</th>
                <th class="px-4 py-3 text-left">Order ID</th>
                <th class="px-4 py-3 text-left">Customer</th>
                <th class="px-4 py-3 text-left">Date</th>
                <th class="px-4 py-3 text-center">Items</th>
                <th class="px-4 py-3 text-right">Total</th>
                <th class="px-4 py-3 text-center">Payment</th>
                <th class="px-4 py-3 text-center">Status</th>
                <th class="px-4 py-3 text-center">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% orders.forEach((order, idx) => { %>
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="px-4 py-3 text-gray-500"><%= (currentPage - 1) * 10 + idx + 1 %></td>
                  <td class="px-4 py-3 font-mono font-semibold text-orange-600 text-xs"><%= order.orderId %></td>
                  <td class="px-4 py-3">
                    <div class="font-medium text-gray-900"><%= order.userId ? order.userId.name : 'N/A' %></div>
                    <div class="text-xs text-gray-400"><%= order.userId ? order.userId.email : '' %></div>
                  </td>
                  <td class="px-4 py-3 text-gray-600"><%= new Date(order.createdOn).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
                  <td class="px-4 py-3 text-center"><%= order.orderedItems.length %></td>
                  <%
                    const originalSubtotal = order.orderedItems.reduce((acc, item) => acc + item.itemTotal, 0);
                    const originalDiscount = order.orderedItems.reduce((acc, item) => acc + (item.totalCouponDiscount || 0), 0);
                    const originalFinalAmount = originalSubtotal - originalDiscount + (order.shippingCharge || 0);
                  %>
                  <td class="px-4 py-3 text-right font-semibold">₹<%= originalFinalAmount.toLocaleString() %></td>
                  <td class="px-4 py-3 text-center text-xs"><%= order.paymentMethod %></td>
                  <td class="px-4 py-3 text-center">
                    <%
                      let badgeClasses = 'bg-gray-100 text-gray-700';
                      if (order.orderStatus === 'Delivered') badgeClasses = 'bg-green-100 text-green-700';
                      else if (order.orderStatus === 'Cancelled') badgeClasses = 'bg-red-100 text-red-700';
                      else if (order.orderStatus === 'Shipped' || order.orderStatus === 'Out for Delivery') badgeClasses = 'bg-blue-100 text-blue-700';
                      else if (order.orderStatus === 'Pending') badgeClasses = 'bg-yellow-100 text-yellow-700';
                      else if (order.orderStatus === 'Placed') badgeClasses = 'bg-purple-100 text-purple-700';
                      else if (order.orderStatus.includes('Return')) badgeClasses = 'bg-orange-100 text-orange-700';
                    %>
                    <span class="inline-block px-2 py-1 rounded-full text-xs font-semibold <%= badgeClasses %>"><%= order.orderStatus %></span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <a href="/admin/orders/<%= order._id %>" class="px-3 py-1.5 bg-gray-900 text-white rounded-lg text-xs font-medium hover:bg-gray-700 transition-colors inline-block">
                      View
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <% if (totalPages > 1) { %>
          <div class="flex justify-center items-center gap-2 p-4 border-t border-gray-100">
            <% if (currentPage > 1) { %>
              <a href="/admin/orders?page=<%= currentPage - 1 %>&search=<%= search %>&status=<%= status %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 text-gray-600 hover:bg-gray-200">‹ Prev</a>
            <% } %>
            <% 
                const delta = 2;
                const left = parseInt(currentPage) - delta;
                const right = parseInt(currentPage) + delta + 1;
                const range = [];
                const rangeWithDots = [];
                let l;

                for (let i = 1; i <= totalPages; i++) {
                    if (i == 1 || i == totalPages || (i >= left && i < right)) {
                        range.push(i);
                    }
                }

                for (let i of range) {
                    if (l) {
                        if (i - l === 2) {
                            rangeWithDots.push(l + 1);
                        } else if (i - l !== 1) {
                            rangeWithDots.push('...');
                        }
                    }
                    rangeWithDots.push(i);
                    l = i;
                }
            %>

            <% rangeWithDots.forEach(i => { %>
                <% if (i === '...') { %>
                    <span class="px-3 py-1.5 text-gray-400">...</span>
                <% } else { %>
                    <a href="/admin/orders?page=<%= i %>&search=<%= search %>&status=<%= status %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>" class="px-3 py-1.5 rounded-lg text-sm font-medium <%= i === currentPage ? 'bg-orange-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' %>"><%= i %></a>
                <% } %>
            <% }) %>
            <% if (currentPage < totalPages) { %>
              <a href="/admin/orders?page=<%= currentPage + 1 %>&search=<%= search %>&status=<%= status %>&sortBy=<%= sortBy %>&sortOrder=<%= sortOrder %>&dateFrom=<%= dateFrom %>&dateTo=<%= dateTo %>" class="px-3 py-1.5 rounded-lg text-sm bg-gray-100 text-gray-600 hover:bg-gray-200">Next ›</a>
            <% } %>
          </div>
        <% } %>

      <% } else { %>
        <div class="text-center py-16">
          <i class="fa-solid fa-box-open text-5xl text-gray-300 mb-4"></i>
          <h3 class="text-lg font-semibold text-gray-500 mb-2">No orders found</h3>
          <p class="text-sm text-gray-400">
            <% if (search || status || dateFrom || dateTo) { %>
              Try adjusting your filters or <a href="/admin/orders" class="text-orange-500 underline">clear all filters</a>
            <% } else { %>
              No orders have been placed yet.
            <% } %>
          </p>
        </div>
      <% } %>
    </div>
  </main>
</div>

<%- include("./partials/adminFooter") %>
