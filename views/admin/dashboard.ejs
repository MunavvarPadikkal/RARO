<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <!-- Top Metrics Row -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">
      
      <!-- Total Sales (Gross) -->
      <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-500 text-sm font-medium">Gross Sales</h3>
          <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-500">
            <i class="fa-solid fa-chart-line text-sm"></i>
          </div>
        </div>
        <div class="text-2xl font-bold text-gray-900 leading-tight">₹<%= metrics.totalSales.toLocaleString() %></div>
        <div class="text-xs text-gray-400 mt-1">Before discounts</div>
      </div>

      <!-- Total Revenue (Net) -->
      <div class="bg-brand-peach rounded-[20px] p-6 border border-transparent shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-900 font-medium">Net Revenue</h3>
          <div class="w-8 h-8 rounded-lg bg-brand-orange bg-opacity-20 flex items-center justify-center text-brand-orange">
            <i class="fa-solid fa-wallet text-sm"></i>
          </div>
        </div>
        <div class="text-2xl font-bold text-gray-900 leading-tight">₹<%= metrics.totalRevenue.toLocaleString() %></div>
        <div class="text-xs text-gray-600 mt-1">After all discounts</div>
      </div>

      <!-- Orders Count -->
      <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-500 text-sm font-medium">Total Orders</h3>
          <div class="w-8 h-8 rounded-lg bg-green-50 flex items-center justify-center text-green-500">
            <i class="fa-solid fa-bag-shopping text-sm"></i>
          </div>
        </div>
        <div class="text-2xl font-bold text-gray-900 leading-tight"><%= metrics.totalOrders %></div>
        <div class="text-xs text-gray-400 mt-1">Completed orders</div>
      </div>

      <!-- Discounts -->
      <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-500 text-sm font-medium">Total Discounts</h3>
          <div class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center text-red-500">
            <i class="fa-solid fa-tag text-sm"></i>
          </div>
        </div>
        <div class="text-2xl font-bold text-gray-900 leading-tight">₹<%= (metrics.totalOfferDiscount + metrics.totalCouponDiscount).toLocaleString() %></div>
        <div class="text-xs text-gray-400 mt-1">Offer + Coupon</div>
      </div>
    </div>

    <!-- Chart Row -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- Sales Chart -->
      <div class="lg:col-span-2 bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm min-h-[400px] flex flex-col">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-gray-900 font-medium text-lg">Sales Analytics</h3>
          <div class="flex items-center gap-2">
            <select id="chartFilter" class="bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-lg focus:ring-brand-orange focus:border-brand-orange block p-2 outline-none cursor-pointer">
              <option value="weekly">Weekly</option>
              <option value="monthly" selected>Monthly</option>
              <option value="yearly">Yearly</option>
            </select>
          </div>
        </div>
        <div class="flex-1 relative">
          <canvas id="salesChart"></canvas>
        </div>
      </div>

      <!-- Category Distribution (Optional or Best Sellers) -->
      <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm flex flex-col">
        <h3 class="text-gray-900 font-medium text-lg mb-6">Top Categories</h3>
        <div class="space-y-4 flex-1">
          <% topCategories.forEach((cat, index) => { %>
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="w-6 h-6 rounded-full bg-gray-50 text-gray-400 text-[10px] flex items-center justify-center font-bold"><%= index + 1 %></span>
                <span class="text-sm text-gray-700 font-medium"><%= cat.name %></span>
              </div>
              <div class="text-right">
                <div class="text-sm font-bold text-gray-900"><%= cat.quantity %> sold</div>
                <div class="text-[10px] text-gray-400">₹<%= cat.revenue.toLocaleString() %></div>
              </div>
            </div>
          <% }) %>
          <% if (topCategories.length === 0) { %>
            <div class="text-center text-gray-400 py-10">No data available</div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Best Selling Products -->
    <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm">
      <h3 class="text-gray-900 font-medium text-lg mb-6">Top 10 Best Selling Products</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-gray-50">
              <th class="pb-4 font-medium text-gray-500 text-sm">Product Name</th>
              <th class="pb-4 font-medium text-gray-500 text-sm text-center">Quantity Sold</th>
              <th class="pb-4 font-medium text-gray-500 text-sm text-right">Revenue</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            <% topProducts.forEach(product => { %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="py-4 text-sm font-medium text-gray-800"><%= product.name %></td>
                <td class="py-4 text-sm text-gray-600 text-center"><%= product.quantity %></td>
                <td class="py-4 text-sm font-bold text-gray-900 text-right">₹<%= product.revenue.toLocaleString() %></td>
              </tr>
            <% }) %>
            <% if (topProducts.length === 0) { %>
              <tr>
                <td colspan="3" class="py-10 text-center text-gray-400">No data available</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </main>

  <script>
    let salesChart;

    const initChart = (data, filter) => {
      const ctx = document.getElementById('salesChart').getContext('2d');
      
      const labels = data.map(item => {
        if (filter === 'yearly') {
          const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
          return months[item._id - 1];
        }
        if (filter === 'weekly') {
          const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
          return days[item._id - 1];
        }
        return `Day ${item._id}`;
      });

      const values = data.map(item => item.sales);

      if (salesChart) {
        salesChart.destroy();
      }

      salesChart = new Chart(ctx, {
        type: 'line',
        data: {
          labels: labels,
          datasets: [{
            label: 'Sales (INR)',
            data: values,
            borderColor: '#d38c64',
            backgroundColor: 'rgba(211, 140, 100, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#d38c64'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false }
          },
          scales: {
            y: {
              beginAtZero: true,
              grid: { color: '#f3f4f6' },
              ticks: { font: { size: 10 } }
            },
            x: {
              grid: { display: false },
              ticks: { font: { size: 10 } }
            }
          }
        }
      });
    };

    const updateChart = async () => {
      const filter = document.getElementById('chartFilter').value;
      try {
        const response = await fetch(`/admin/dashboard/chart-data?filter=${filter}`);
        const data = await response.json();
        if (data.success) {
          initChart(data.chartData, filter);
        }
      } catch (error) {
        console.error("Failed to update chart:", error);
      }
    };

    document.getElementById('chartFilter').addEventListener('change', updateChart);
    
    // Initial chart load
    updateChart();
  </script>
</div>

<%- include("./partials/adminFooter") %>

