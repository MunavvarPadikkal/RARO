<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <!-- Top Metrics Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      
      <!-- Income Card (Peach bg) -->
      <div class="bg-brand-peach rounded-[20px] p-6 relative">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-900 font-medium">Income</h3>
          <div class="w-8 h-8 rounded-lg bg-brand-orange bg-opacity-20 flex items-center justify-center text-brand-orange">
            <i class="fa-solid fa-wallet text-sm"></i>
          </div>
        </div>
        <div class="text-[28px] font-bold text-gray-900 leading-tight">160,050 <span class="text-lg">INR</span></div>
        <div class="text-brand-orange text-xs mt-2 flex items-center gap-1 font-medium">
          <i class="fa-solid fa-arrow-up"></i> 20% compared to last week
        </div>
      </div>

      <!-- Orders Card (White bg) -->
      <div class="bg-white rounded-[20px] p-6 relative border border-gray-100 shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-900 font-medium">Orders</h3>
          <div class="w-8 h-8 rounded-lg bg-brand-orange bg-opacity-20 flex items-center justify-center text-brand-orange">
            <i class="fa-solid fa-bag-shopping text-sm"></i>
          </div>
        </div>
        <div class="text-[28px] font-bold text-gray-900 leading-tight">1,680</div>
        <div class="text-brand-orange text-xs mt-2 flex items-center gap-1 font-medium">
          <i class="fa-solid fa-arrow-up"></i> 7% compared to last week
        </div>
      </div>

      <!-- Average Check Card (White bg) -->
      <div class="bg-white rounded-[20px] p-6 relative border border-gray-100 shadow-sm">
        <div class="flex justify-between items-start mb-4">
          <h3 class="text-gray-900 font-medium">Average check</h3>
          <div class="w-8 h-8 rounded-lg bg-brand-orange bg-opacity-20 flex items-center justify-center text-brand-orange">
            <i class="fa-regular fa-credit-card text-sm"></i>
          </div>
        </div>
        <div class="text-[28px] font-bold text-gray-900 leading-tight">2,590 <span class="text-lg">INR</span></div>
        <div class="text-brand-orange text-xs mt-2 flex items-center gap-1 font-medium">
          <i class="fa-solid fa-arrow-up"></i> 5% compared to last week
        </div>
      </div>
    </div>

    <!-- Secondary Row (Product Sales & Categories) -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      
      <!-- Graph Area (Placeholder) -->
      <div class="lg:col-span-2 bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm min-h-[300px] flex flex-col">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-gray-900 font-medium text-lg">Product sales</h3>
          <select class="bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-lg focus:ring-brand-orange focus:border-brand-orange block p-2 outline-none">
            <option>week</option>
            <option>month</option>
            <option>year</option>
          </select>
        </div>
        <!-- Graph Placeholder -->
        <div class="flex-1 flex items-center justify-center border-2 border-dashed border-gray-100 rounded-xl bg-gray-50 text-gray-400">
           <i class="fa-solid fa-chart-line text-4xl mb-2 mr-3 opacity-50"></i> Chart will be implemented here
        </div>
      </div>

      <!-- Categories Pie Chart Area -->
      <div class="bg-white rounded-[20px] p-6 border border-gray-100 shadow-sm min-h-[300px] flex flex-col">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-gray-900 font-medium text-lg">Categories</h3>
          <select class="bg-gray-50 border border-gray-200 text-gray-700 text-sm rounded-lg focus:ring-brand-orange focus:border-brand-orange block p-2 outline-none">
            <option>week</option>
            <option>month</option>
          </select>
        </div>
         <!-- Graph Placeholder -->
         <div class="flex-1 flex items-center justify-center border-2 border-dashed border-gray-100 rounded-xl bg-gray-50 text-gray-400">
           <i class="fa-solid fa-chart-pie text-4xl mb-2 mr-3 opacity-50"></i> Chart will be implemented here
        </div>
      </div>

    </div>

  </main>
</div>

<%- include("./partials/adminFooter") %>

