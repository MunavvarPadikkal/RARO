<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="admin-main flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>
  <main class="px-8 pb-8">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-6">
      <a href="/admin/orders" class="w-10 h-10 rounded-xl bg-gray-100 flex items-center justify-center text-gray-600 hover:bg-gray-200 transition-colors">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <div>
        <h2 class="text-2xl font-bold text-gray-900">Order #<%= order.orderId %></h2>
        <p class="text-sm text-gray-500">Placed on <%= new Date(order.createdOn).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
      </div>
      <div class="ml-auto">
        <%
          let statusClasses = 'bg-gray-100 text-gray-700';
          if (order.orderStatus === 'Delivered') statusClasses = 'bg-green-100 text-green-700';
          else if (order.orderStatus === 'Cancelled') statusClasses = 'bg-red-100 text-red-700';
          else if (order.orderStatus === 'Shipped' || order.orderStatus === 'Out for Delivery') statusClasses = 'bg-blue-100 text-blue-700';
          else if (order.orderStatus === 'Pending') statusClasses = 'bg-yellow-100 text-yellow-700';
          else if (order.orderStatus === 'Placed') statusClasses = 'bg-purple-100 text-purple-700';
          else if (order.orderStatus.includes('Return')) statusClasses = 'bg-orange-100 text-orange-700';
        %>
        <span class="px-4 py-2 rounded-full text-sm font-bold <%= statusClasses %>"><%= order.orderStatus %></span>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Left Column (2/3) -->
      <div class="lg:col-span-2 space-y-6">
        
        <!-- Status Update -->
        <% if (nextStatuses.length > 0) { %>
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
            <h3 class="font-semibold text-gray-900 mb-3">Update Status</h3>
            <div class="flex gap-3 items-center flex-wrap">
              <select id="newStatusSelect" class="px-3 py-2 border border-gray-200 rounded-lg text-sm bg-white focus:outline-none focus:ring-2 focus:ring-orange-300">
                <option value="">Select new status...</option>
                <% nextStatuses.forEach(s => { %>
                  <option value="<%= s %>"><%= s %></option>
                <% }) %>
              </select>
              <button onclick="updateStatus()" class="px-4 py-2 bg-orange-500 text-white rounded-lg text-sm font-medium hover:bg-orange-600 transition-colors">
                <i class="fa-solid fa-check mr-1"></i> Update Status
              </button>
            </div>
          </div>
        <% } %>

        <!-- Items -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-4">Ordered Items (<%= order.orderedItems.length %>)</h3>
          <div class="space-y-3">
            <% order.orderedItems.forEach(item => { %>
              <%
                let itemBadge = 'bg-green-100 text-green-700';
                if (item.itemStatus === 'Cancelled') itemBadge = 'bg-red-100 text-red-700';
                else if (item.itemStatus.includes('Return')) itemBadge = 'bg-orange-100 text-orange-700';
                else if (item.itemStatus === 'Returned') itemBadge = 'bg-purple-100 text-purple-700';
              %>
              <div class="flex items-center gap-4 p-3 bg-gray-50 rounded-xl">
                <div class="w-14 h-14 rounded-lg overflow-hidden border border-gray-200 flex-shrink-0">
                  <% if (item.productImage) { %>
                    <img src="/uploads/productImages/<%= item.productImage %>" alt="<%= item.productName %>" class="w-full h-full object-cover">
                  <% } else { %>
                    <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400"><i class="fa-solid fa-image"></i></div>
                  <% } %>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-gray-900 text-sm truncate"><%= item.productName %></div>
                  <div class="text-xs text-gray-500">Size: <%= item.size %> <% if (item.color) { %> · Color: <%= item.color %><% } %> · Qty: <%= item.quantity %></div>
                  <div class="text-xs text-gray-400 mt-0.5">₹<%= item.price %> × <%= item.quantity %></div>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="font-semibold text-gray-900">₹<%= item.itemTotal.toLocaleString() %></div>
                  <span class="inline-block mt-1 px-2 py-0.5 rounded-full text-xs font-semibold <%= itemBadge %>"><%= item.itemStatus %></span>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Price Breakdown -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-3">Price Breakdown</h3>
          <table class="w-full text-sm">
            <tr><td class="py-2 text-gray-500">Subtotal</td><td class="py-2 text-right font-medium">₹<%= (order.subtotal + order.discount).toLocaleString() %></td></tr>
            <% if (order.discount > 0) { %>
              <tr><td class="py-2 text-green-600">Discount</td><td class="py-2 text-right text-green-600 font-medium">− ₹<%= order.discount.toLocaleString() %></td></tr>
            <% } %>
            <tr><td class="py-2 text-gray-500">Shipping</td><td class="py-2 text-right"><%= order.shippingCharge === 0 ? 'Free' : '₹' + order.shippingCharge %></td></tr>
            <tr class="border-t-2 border-orange-400"><td class="py-3 font-bold text-lg text-gray-900">Grand Total</td><td class="py-3 text-right font-bold text-lg text-orange-500">₹<%= order.finalAmount.toLocaleString() %></td></tr>
          </table>
        </div>

        <!-- Status History Timeline -->
        <% if (order.statusHistory && order.statusHistory.length > 0) { %>
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
            <h3 class="font-semibold text-gray-900 mb-4">Status History</h3>
            <div class="space-y-4">
              <% order.statusHistory.slice().reverse().forEach((sh, idx) => { %>
                <%
                  let dotColor = 'bg-gray-400';
                  let displayStatus = sh.status;
                  
                  if (sh.status === 'Delivered') dotColor = 'bg-green-500';
                  else if (sh.status === 'Cancelled' || sh.status === 'Item Cancelled' || (sh.note && sh.note.includes('cancelled'))) {
                      dotColor = 'bg-red-500';
                      if (sh.status === 'Placed') displayStatus = 'Item Cancelled';
                  }
                  else if (sh.status === 'Shipped' || sh.status === 'Out for Delivery') dotColor = 'bg-blue-500';
                  else if (sh.status === 'Pending') dotColor = 'bg-yellow-500';
                  else if (sh.status === 'Placed') dotColor = 'bg-purple-500';
                  else if (sh.status.includes('Return')) dotColor = 'bg-orange-500';
                %>
                <div class="flex gap-3 items-start">
                  <div class="w-2.5 h-2.5 rounded-full <%= dotColor %> mt-1.5 flex-shrink-0"></div>
                  <div>
                    <div class="text-sm font-semibold text-gray-900"><%= displayStatus %></div>
                    <div class="text-xs text-gray-400"><%= new Date(sh.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></div>
                    <% if (sh.note) { %>
                      <div class="text-xs text-gray-500 mt-0.5"><%= sh.note %></div>
                    <% } %>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Right Column (1/3) -->
      <div class="space-y-6">
        <!-- Customer Info -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-3">Customer</h3>
          <div class="space-y-2 text-sm">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-600 font-bold">
                <%= order.userId ? order.userId.name.charAt(0).toUpperCase() : '?' %>
              </div>
              <div>
                <div class="font-medium text-gray-900"><%= order.userId ? order.userId.name : 'Unknown' %></div>
                <div class="text-xs text-gray-400"><%= order.userId ? order.userId.email : '' %></div>
              </div>
            </div>
            <% if (order.userId && order.userId.phone) { %>
              <div class="text-gray-500"><i class="fa-solid fa-phone text-xs mr-2"></i> <%= order.userId.phone %></div>
            <% } %>
          </div>
        </div>

        <!-- Delivery Address -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-3">Delivery Address</h3>
          <div class="text-sm space-y-1">
            <span class="inline-block px-2 py-0.5 bg-orange-100 text-orange-700 text-xs font-semibold rounded-full mb-2"><%= order.shippingAddress.addressType %></span>
            <div class="font-medium text-gray-900"><%= order.shippingAddress.name %></div>
            <div class="text-gray-600 leading-relaxed">
              <%= order.shippingAddress.landMark ? order.shippingAddress.landMark + ', ' : '' %>
              <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %><br>
              PIN: <%= order.shippingAddress.pincode %>
            </div>
            <div class="text-gray-500 mt-2"><i class="fa-solid fa-phone text-xs mr-1"></i> <%= order.shippingAddress.phone %></div>
          </div>
        </div>

        <!-- Payment -->
        <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100">
          <h3 class="font-semibold text-gray-900 mb-3">Payment</h3>
          <div class="text-sm space-y-2">
            <div class="flex justify-between"><span class="text-gray-500">Method</span><span class="font-medium"><%= order.paymentMethod %></span></div>
            <div class="flex justify-between">
              <span class="text-gray-500">Status</span>
              <span class="px-2 py-0.5 rounded-full text-xs font-semibold <%= order.paymentStatus === 'Paid' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>"><%= order.paymentStatus %></span>
            </div>
            <% if (order.invoiceNumber) { %>
              <div class="flex justify-between"><span class="text-gray-500">Invoice</span><span class="font-mono text-xs font-medium"><%= order.invoiceNumber %></span></div>
            <% } %>
          </div>
        </div>

        <!-- Cancellation/Return Info -->
        <% if (order.cancellationReason) { %>
          <div class="bg-red-50 rounded-2xl p-5 border border-red-100">
            <h3 class="font-semibold text-red-700 mb-2 text-sm">Cancellation Reason</h3>
            <p class="text-sm text-red-600"><%= order.cancellationReason %></p>
          </div>
        <% } %>
        <% if (order.returnReason) { %>
          <div class="bg-orange-50 rounded-2xl p-5 border border-orange-100">
            <h3 class="font-semibold text-orange-700 mb-2 text-sm">Return Reason</h3>
            <p class="text-sm text-orange-600"><%= order.returnReason %></p>
          </div>
        <% } %>
      </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  async function updateStatus() {
    const newStatus = document.getElementById('newStatusSelect').value;
    if (!newStatus) {
      Swal.fire('Error', 'Please select a status', 'warning');
      return;
    }

    const result = await Swal.fire({
      title: 'Update Order Status?',
      text: `Change status to "${newStatus}"?`,
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#f97316',
      confirmButtonText: 'Yes, Update',
      reverseButtons: true
    });

    if (result.isConfirmed) {
      try {
        const res = await fetch('/admin/orders/<%= order._id %>/status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ newStatus })
        });
        const data = await res.json();
        if (data.success) {
          Swal.fire('Updated!', data.message, 'success').then(() => location.reload());
        } else {
          Swal.fire('Error', data.message, 'error');
        }
      } catch (err) {
        Swal.fire('Error', 'Something went wrong', 'error');
      }
    }
  }
</script>

<%- include("./partials/adminFooter") %>
