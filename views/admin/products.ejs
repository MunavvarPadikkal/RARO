<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 p-6">

      <!-- Card Header & Actions -->
      <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <h2 class="text-xl font-semibold text-gray-900">Products <span class="text-sm font-normal text-gray-400 ml-2">Management</span></h2>
        
        <div class="flex items-center gap-3 w-full md:w-auto">
          <!-- Search -->
          <form action="/admin/products" method="get" class="relative flex items-center">
            <div class="relative">
              <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
              <input type="text" name="search" placeholder="Search products..." value="<%= typeof search !== 'undefined' ? search : '' %>" 
                     class="w-full md:w-64 pl-10 <%= typeof search !== 'undefined' && search !== '' ? 'pr-10' : 'pr-4' %> py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
              <% if (typeof search !== 'undefined' && search !== "") { %>
                <a href="/admin/products" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-red-500 transition-colors flex items-center justify-center w-6 h-6 rounded-full hover:bg-red-50" title="Clear search">
                  <i class="fa-solid fa-xmark text-sm"></i>
                </a>
              <% } %>
            </div>
            <button type="submit" class="hidden">Search</button>
          </form>
          
          <!-- Add Product Button -->
          <a href="/admin/addProduct" class="px-5 py-2 bg-brand-orange text-white rounded-full text-sm font-medium hover:bg-opacity-90 transition-all flex items-center gap-2 whitespace-nowrap">
            <i class="fa-solid fa-plus text-xs"></i>
            Add Product
          </a>
        </div>
      </div>

      <!-- Table Section -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50/50 border-b border-gray-100">
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 w-16">Image</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Product Name</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Category</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Price</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">Stock</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">Status</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if(products && products.length > 0) { %>
              <% products.forEach(product => { %>
                <tr class="hover:bg-gray-50/50 transition-colors <%= product.isDeleted ? 'opacity-50 grayscale' : '' %>">
                  <td class="py-3 px-4">
                    <div class="w-12 h-12 rounded-lg border border-gray-200 overflow-hidden bg-gray-50">
                      <% if (product.productImage && product.productImage.length > 0) { %>
                        <img src="/uploads/productImages/<%= product.productImage[0] %>" alt="<%= product.productName %>" class="w-full h-full object-cover">
                      <% } else { %>
                        <div class="w-full h-full flex items-center justify-center text-gray-400">
                          <i class="fa-regular fa-image text-xl"></i>
                        </div>
                      <% } %>
                    </div>
                  </td>
                  <td class="py-4 px-4 text-sm text-gray-800 font-medium">
                    <%= product.productName %>
                    <% if (product.isDeleted) { %>
                      <span class="ml-2 text-xs text-red-500 font-medium tracking-wider uppercase">(Deleted)</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-sm text-gray-500"><%= product.category ? product.category.name : 'Uncategorized' %></td>
                  <td class="py-4 px-4 text-sm">
                    <% if (product.salePrice < product.regularPrice) { %>
                      <div class="flex flex-col">
                        <span class="text-green-600 font-semibold">₹<%= product.salePrice %></span>
                        <span class="text-gray-400 line-through text-xs">₹<%= product.regularPrice %></span>
                      </div>
                    <% } else { %>
                      <span class="text-gray-800 font-semibold">₹<%= product.regularPrice %></span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-sm text-center">
                    <% 
                      let totalQty = 0;
                      if (product.sizes && product.sizes.length > 0) {
                        totalQty = product.sizes.reduce((sum, s) => sum + s.quantity, 0);
                      }
                    %>
                    <div class="flex flex-col items-center">
                      <span class="font-medium <%= totalQty > 0 ? 'text-gray-800' : 'text-red-500' %>"><%= totalQty %></span>
                      <div class="text-[10px] text-gray-400 mt-0.5 flex gap-1">
                        <% if (product.sizes) { %>
                          <% product.sizes.forEach(s => { %>
                            <span><%= s.size %>:<%= s.quantity %></span>
                          <% }) %>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td class="py-4 px-4 text-sm text-center">
                    <% if(totalQty > 0) { %>
                      <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-medium">Available</span>
                    <% } else { %>
                      <span class="inline-block px-3 py-1 bg-red-50 text-red-500 rounded-full text-xs font-medium">Out of stock</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-sm text-right">
                    <div class="flex items-center justify-end gap-2">
                       <% if(!product.isDeleted) { %>
                          <a href="/admin/editProduct?id=<%= product._id %>" class="inline-flex items-center justify-center w-8 h-8 bg-blue-50 text-blue-600 rounded-lg hover:bg-blue-100 transition-colors" title="Edit">
                            <i class="fa-solid fa-pen-to-square text-[13px]"></i>
                          </a>
                          
                          <% if(product.isBlocked) { %>
                            <button onclick="unblockProduct('<%= product._id %>')" class="inline-flex items-center justify-center w-8 h-8 bg-green-50 text-green-600 rounded-lg hover:bg-green-100 transition-colors" title="Unblock">
                              <i class="fa-solid fa-unlock text-[13px]"></i>
                            </button>
                          <% } else { %>
                            <button onclick="blockProduct('<%= product._id %>')" class="inline-flex items-center justify-center w-8 h-8 bg-orange-50 text-orange-600 rounded-lg hover:bg-orange-100 transition-colors" title="Block">
                              <i class="fa-solid fa-lock text-[13px]"></i>
                            </button>
                          <% } %>

                          <button onclick="deleteProduct('<%= product._id %>')" class="inline-flex items-center justify-center w-8 h-8 bg-red-50 text-red-600 rounded-lg hover:bg-red-100 transition-colors" title="Delete">
                            <i class="fa-regular fa-trash-can text-[13px]"></i>
                          </button>
                      <% } else { %>
                          <button onclick="restoreProduct('<%= product._id %>')" class="inline-flex items-center justify-center px-3 py-1.5 bg-gray-100 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-200 transition-colors">
                            <i class="fa-solid fa-rotate-left mr-1.5"></i> Restore
                          </button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="7" class="py-12 text-center text-sm text-gray-500">
                  <div class="flex flex-col items-center justify-center">
                    <i class="fa-solid fa-box-open text-4xl text-gray-200 mb-3"></i>
                    <p class="text-base font-medium text-gray-600 mb-1">No products found</p>
                    <p class="text-xs text-gray-400">Click "Add Product" to create your first product.</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination Section -->
      <% if(totalPages > 1) { %>
        <div class="mt-8 flex justify-center">
          <nav aria-label="Page navigation" class="flex items-center gap-2">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" 
                 class="w-8 h-8 flex items-center justify-center rounded-lg text-sm font-medium transition-colors
                        <%= (i === parseInt(currentPage)) ? 'bg-brand-orange text-white' : 'bg-gray-50 text-gray-500 hover:bg-gray-100' %>">
                <%= i %>
              </a>
            <% } %>
          </nav>
        </div>
      <% } %>

    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function blockProduct(id) {
    Swal.fire({
      title: 'Block Product?',
      text: "Users won't be able to purchase or view this product.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#ff9800',
      cancelButtonColor: '#cbd5e1',
      confirmButtonText: 'Yes, block it'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const res = await fetch('/admin/blockProduct', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          const data = await res.json();
          if (res.ok) window.location.reload();
          else Swal.fire('Error', data.error || 'Something went wrong', 'error');
        } catch (err) {
          Swal.fire('Error', 'Network request failed', 'error');
        }
      }
    });
  }

  function unblockProduct(id) {
    Swal.fire({
      title: 'Unblock Product?',
      text: "Product will be visible to users again.",
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#22c55e',
      cancelButtonColor: '#cbd5e1',
      confirmButtonText: 'Yes, unblock it'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const res = await fetch('/admin/unblockProduct', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          const data = await res.json();
          if (res.ok) window.location.reload();
          else Swal.fire('Error', data.error || 'Something went wrong', 'error');
        } catch (err) {
          Swal.fire('Error', 'Network request failed', 'error');
        }
      }
    });
  }

  function deleteProduct(id) {
    Swal.fire({
      title: 'Delete Product?',
      text: "This will move the product to deleted state.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#ef4444',
      cancelButtonColor: '#cbd5e1',
      confirmButtonText: 'Yes, delete it'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const res = await fetch('/admin/deleteProduct', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          const data = await res.json();
          if (res.ok) window.location.reload();
          else Swal.fire('Error', data.error || 'Something went wrong', 'error');
        } catch (err) {
          Swal.fire('Error', 'Network request failed', 'error');
        }
      }
    });
  }

  function restoreProduct(id) {
    Swal.fire({
      title: 'Restore Product?',
      text: "This will restore the product to active state.",
      icon: 'question',
      showCancelButton: true,
      confirmButtonColor: '#3b82f6',
      cancelButtonColor: '#cbd5e1',
      confirmButtonText: 'Yes, restore it'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const res = await fetch('/admin/restoreProduct', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id })
          });
          const data = await res.json();
          if (res.ok) window.location.reload();
          else Swal.fire('Error', data.error || 'Something went wrong', 'error');
        } catch (err) {
          Swal.fire('Error', 'Network request failed', 'error');
        }
      }
    });
  }
</script>

<%- include("./partials/adminFooter") %>
