<!-- Sidebar Menu -->
<aside class="w-[260px] bg-brand-sidebar text-gray-400 flex flex-col min-h-screen sticky top-0 shrink-0">
  <!-- Brand Area -->
  <div class="px-6 py-8">
    <img src="\assets\images\RARO logo white.png" alt="RARO Logo" class="w-24">
  </div>

  <!-- User Profile block (matching screenshot) -->
  <div class="px-6 mb-8 flex items-center justify-between group cursor-pointer">
    <div class="flex items-center gap-3">
      <div
        class="w-10 h-10 rounded-full bg-gray-600 flex items-center justify-center text-white font-medium overflow-hidden">
        <img src="\assets\Photo_closeup.jpg" alt="Admin" class="w-full h-full object-cover" />
      </div>
      <div>
        <div class="text-white font-medium text-sm">Admin</div>
      </div>
    </div>
    <i class="fa-solid fa-chevron-down text-xs"></i>
  </div>

  <!-- Navigation Links -->
  <nav class="flex-1 px-4 space-y-1">
    <a href="/admin/dashboard"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/dashboard' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-chart-column w-5 text-center"></i>
      <span class="font-medium">Dashboard</span>
    </a>
    <a href="/admin/orders"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/orders' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-box w-5 text-center"></i>
      <span class="font-medium">Orders</span>
    </a>
    <a href="/admin/customers"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/customers' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-users w-5 text-center"></i>
      <span class="font-medium">Clients</span>
    </a>
    <a href="/admin/products"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= (path === '/admin/products' || path === '/admin/addProduct' || path === '/admin/editProduct') ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-cart-shopping w-5 text-center"></i>
      <span class="font-medium">Products</span>
    </a>
    <a href="/admin/categories"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= (path === '/admin/categories' || path === '/admin/editCategory') ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-layer-group w-5 text-center"></i>
      <span class="font-medium">Categories</span>
    </a>
    <a href="/admin/inventory"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/inventory' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-warehouse w-5 text-center"></i>
      <span class="font-medium">Inventory</span>
    </a>
    <a href="/admin/return-requests"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/return-requests' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-rotate-left w-5 text-center"></i>
      <span class="font-medium">Returns</span>
    </a>
    <a href="/admin/refunds"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/refunds' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-money-bill-transfer w-5 text-center"></i>
      <span class="font-medium">Refunds</span>
    </a>
    <a href="/admin/coupons"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/coupons' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-ticket w-5 text-center"></i>
      <span class="font-medium">Coupons</span>
    </a>
    <a href="/admin/referrals"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= (path === '/admin/referrals' || path === '/admin/referral-settings') ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-user-group w-5 text-center"></i>
      <span class="font-medium">Referrals</span>
    </a>
    <a href="/admin/offers"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/offers' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-tags w-5 text-center"></i>
      <span class="font-medium">Offers</span>
    </a>
    <a href="/admin/banners"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/banners' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-regular fa-image w-5 text-center"></i>
      <span class="font-medium">Banners</span>
    </a>
    <a href="/admin/sales-report"
      class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all <%= path === '/admin/sales-report' ? 'bg-brand-sidebarActive text-white' : 'hover:bg-brand-sidebarActive hover:text-white' %>">
      <i class="fa-solid fa-arrow-trend-up w-5 text-center"></i>
      <span class="font-medium">Report</span>
    </a>
  </nav>

  <!-- Bottom Settings/Logout -->
  <div class="px-4 py-6 space-y-1">
    <a href="/admin/logout"
      class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-brand-sidebarActive hover:text-white transition-all">
      <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center"></i>
      <span class="font-medium">Log out</span>
    </a>
  </div>
</aside>