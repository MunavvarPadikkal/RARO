<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 p-6">

      <!-- Card Header & Actions -->
      <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
        <div>
          <h2 class="text-xl font-semibold text-gray-900">Referrals <span class="text-sm font-normal text-gray-400 ml-2">Management</span></h2>
          <p class="text-sm text-gray-400 mt-1"><%= totalReferrals %> total referral<%= totalReferrals !== 1 ? 's' : '' %></p>
        </div>
        
        <div class="flex items-center gap-3 w-full md:w-auto">
          <!-- Search & Filter -->
          <form action="/admin/referrals" method="get" class="relative flex items-center gap-2">
            <div class="relative flex items-center">
              <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-sm"></i>
              <input type="text" name="search" placeholder="Search by name..." value="<%= search %>" 
                     class="w-full md:w-52 pl-10 <%= search ? 'pr-10' : 'pr-4' %> py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
              
              <% if (search) { %>
                <a href="/admin/referrals?status=<%= status %>" 
                   class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors p-1"
                   title="Clear search">
                  <i class="fa-solid fa-circle-xmark"></i>
                </a>
              <% } %>
            </div>
            
            <select name="status" onchange="this.form.submit()" class="px-4 py-2 bg-gray-50 border border-gray-200 rounded-full text-sm focus:outline-none focus:ring-2 focus:ring-brand-orange/50 transition-all">
                <option value="">All Status</option>
                <option value="pending" <%= status === 'pending' ? 'selected' : '' %>>Pending</option>
                <option value="completed" <%= status === 'completed' ? 'selected' : '' %>>Completed</option>
            </select>
          </form>
          
          <!-- Settings Button -->
          <a href="/admin/referral-settings" class="px-5 py-2 bg-brand-orange text-white rounded-full text-sm font-medium hover:bg-opacity-90 transition-all flex items-center gap-2 whitespace-nowrap">
            <i class="fa-solid fa-gear text-xs"></i>
            Settings
          </a>
        </div>
      </div>

      <!-- Program Status Indicator -->
      <div class="mb-6 flex items-center gap-3 px-4 py-3 rounded-xl <%= settings.isEnabled ? 'bg-emerald-50' : 'bg-red-50' %>">
        <div class="w-2.5 h-2.5 rounded-full <%= settings.isEnabled ? 'bg-emerald-500' : 'bg-red-500' %> animate-pulse"></div>
        <span class="text-sm font-medium <%= settings.isEnabled ? 'text-emerald-700' : 'text-red-700' %>">
          Referral Program is <%= settings.isEnabled ? 'Active' : 'Disabled' %>
        </span>
        <span class="text-xs text-gray-400 ml-2">
          Referrer: ₹<%= settings.referrerReward %> | New User: ₹<%= settings.referredReward %>
          <% if (settings.minOrderAmount > 0) { %>
            | Min Order: ₹<%= settings.minOrderAmount %>
          <% } %>
        </span>
      </div>

      <!-- Table Section -->
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50/50 border-b border-gray-100">
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Referrer</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500">Referred User</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">Status</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">Referrer Reward</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-center">User Reward</th>
              <th scope="col" class="py-4 px-4 text-sm font-medium text-gray-500 text-right">Date</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% if(referrals && referrals.length > 0) { %>
              <% referrals.forEach((ref) => { %>
                <tr class="hover:bg-gray-50/50 transition-colors">
                  <td class="py-4 px-4">
                    <div class="text-sm font-medium text-gray-900"><%= ref.referrerName %></div>
                    <div class="text-xs text-gray-400"><%= ref.referrerEmail %></div>
                  </td>
                  <td class="py-4 px-4">
                    <div class="text-sm font-medium text-gray-900"><%= ref.referredName %></div>
                    <div class="text-xs text-gray-400"><%= ref.referredEmail %></div>
                  </td>
                  <td class="py-4 px-4 text-center">
                    <% if(ref.status === 'completed') { %>
                      <span class="inline-block px-3 py-1 bg-emerald-50 text-emerald-600 rounded-full text-xs font-medium">Completed</span>
                    <% } else { %>
                      <span class="inline-block px-3 py-1 bg-amber-50 text-amber-600 rounded-full text-xs font-medium">Pending</span>
                    <% } %>
                  </td>
                  <td class="py-4 px-4 text-center">
                    <span class="text-sm font-semibold <%= ref.status === 'completed' ? 'text-emerald-600' : 'text-gray-400' %>">
                      ₹<%= ref.rewardReferrer %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-center">
                    <span class="text-sm font-semibold <%= ref.status === 'completed' ? 'text-emerald-600' : 'text-gray-400' %>">
                      ₹<%= ref.rewardReferred %>
                    </span>
                  </td>
                  <td class="py-4 px-4 text-right">
                    <div class="text-sm text-gray-600"><%= new Date(ref.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                    <% if(ref.completedAt) { %>
                      <div class="text-xs text-emerald-500">Completed: <%= new Date(ref.completedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %></div>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="py-12 text-center text-sm text-gray-500">
                  <div class="flex flex-col items-center justify-center">
                    <i class="fa-solid fa-user-group text-5xl text-gray-100 mb-4"></i>
                    <p class="text-lg font-medium text-gray-400">No referrals found</p>
                    <p class="text-gray-300">Try adjusting your search or filters</p>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <!-- Pagination Section -->
      <% if(totalPages > 1) { %>
        <div class="mt-8 flex justify-center">
          <nav aria-label="Page navigation" class="flex items-center gap-2">
            <% for(let i = 1; i <= totalPages; i++) { %>
              <a href="?page=<%= i %><%= search ? '&search=' + search : '' %><%= status ? '&status=' + status : '' %>" 
                 class="w-10 h-10 flex items-center justify-center rounded-xl text-sm font-medium transition-all
                        <%= (i === parseInt(currentPage)) ? 'bg-brand-orange text-white shadow-md shadow-brand-orange/20' : 'bg-gray-50 text-gray-500 hover:bg-gray-100' %>">
                <%= i %>
              </a>
            <% } %>
          </nav>
        </div>
      <% } %>

    </div>
  </main>
</div>

<%- include("./partials/adminFooter") %>
