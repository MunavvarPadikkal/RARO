<%- include("./partials/adminHeader") %>
<%- include("./partials/adminSidebar") %>

<div class="flex-1 overflow-x-hidden overflow-y-auto">
  <%- include("./partials/adminTopbar") %>

  <main class="px-8 pb-8">
    <div class="max-w-2xl mx-auto">

      <!-- Back link -->
      <a href="/admin/referrals" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-brand-orange transition-colors mb-6">
        <i class="fa-solid fa-arrow-left text-xs"></i>
        Back to Referrals
      </a>

      <div class="bg-white rounded-[20px] shadow-sm border border-gray-100 p-8">
        <div class="mb-8">
          <h2 class="text-xl font-semibold text-gray-900">Referral Program Settings</h2>
          <p class="text-sm text-gray-400 mt-1">Configure reward amounts and program status</p>
        </div>

        <form id="settingsForm" class="space-y-8">
          
          <!-- Program Status Toggle -->
          <div class="flex items-center justify-between p-5 rounded-2xl border border-gray-100 bg-gray-50/50">
            <div>
              <h3 class="text-sm font-semibold text-gray-900">Program Status</h3>
              <p class="text-xs text-gray-400 mt-1">Enable or disable the referral program globally</p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="isEnabled" class="sr-only peer" <%= settings.isEnabled ? 'checked' : '' %>>
              <div class="w-14 h-7 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-0.5 after:left-[4px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-brand-orange"></div>
            </label>
          </div>

          <!-- Reward Amounts -->
          <div class="space-y-5">
            <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
              <i class="fa-solid fa-gift text-brand-orange"></i>
              Reward Configuration
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <!-- Referrer Reward -->
              <div class="p-5 rounded-2xl border border-gray-100 bg-gray-50/50">
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Referrer Reward</label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₹</span>
                  <input type="number" id="referrerReward" value="<%= settings.referrerReward %>" min="0" max="10000" step="1"
                         class="w-full pl-8 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-lg font-bold text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
                </div>
                <p class="text-xs text-gray-400 mt-2">Amount credited to the person who shared</p>
              </div>

              <!-- Referred User Reward -->
              <div class="p-5 rounded-2xl border border-gray-100 bg-gray-50/50">
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">New User Reward</label>
                <div class="relative">
                  <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₹</span>
                  <input type="number" id="referredReward" value="<%= settings.referredReward %>" min="0" max="10000" step="1"
                         class="w-full pl-8 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-lg font-bold text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
                </div>
                <p class="text-xs text-gray-400 mt-2">Amount credited to the new user (referred)</p>
              </div>
            </div>
          </div>

          <!-- Minimum Order Amount -->
          <div class="space-y-3">
            <h3 class="text-sm font-semibold text-gray-900 flex items-center gap-2">
              <i class="fa-solid fa-receipt text-brand-orange"></i>
              Order Conditions
            </h3>
            <div class="p-5 rounded-2xl border border-gray-100 bg-gray-50/50">
              <label class="block text-xs font-medium text-gray-500 uppercase tracking-wide mb-3">Minimum Order Amount</label>
              <div class="relative">
                <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-semibold">₹</span>
                <input type="number" id="minOrderAmount" value="<%= settings.minOrderAmount %>" min="0" max="100000" step="1"
                       class="w-full pl-8 pr-4 py-3 bg-white border border-gray-200 rounded-xl text-lg font-bold text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-orange/50 focus:border-brand-orange transition-all">
              </div>
              <p class="text-xs text-gray-400 mt-2">Set to 0 for no minimum requirement. Referral reward is only credited if the first order meets this threshold.</p>
            </div>
          </div>

          <!-- Save Button -->
          <div class="pt-4 flex justify-end">
            <button type="submit" id="saveBtn" class="px-8 py-3 bg-brand-orange text-white rounded-xl text-sm font-semibold hover:bg-opacity-90 transition-all flex items-center gap-2 shadow-lg shadow-brand-orange/20">
              <i class="fa-solid fa-check"></i>
              Save Settings
            </button>
          </div>
        </form>

      </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  document.getElementById('settingsForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const isEnabled = document.getElementById('isEnabled').checked;
    const referrerReward = document.getElementById('referrerReward').value;
    const referredReward = document.getElementById('referredReward').value;
    const minOrderAmount = document.getElementById('minOrderAmount').value;

    // Validation
    if (referrerReward < 0 || referredReward < 0 || minOrderAmount < 0) {
      Swal.fire({ icon: 'error', title: 'Invalid Input', text: 'Values cannot be negative.' });
      return;
    }

    const saveBtn = document.getElementById('saveBtn');
    const originalText = saveBtn.innerHTML;
    saveBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
    saveBtn.disabled = true;

    try {
      const response = await fetch('/admin/referral-settings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          isEnabled: isEnabled.toString(),
          referrerReward,
          referredReward,
          minOrderAmount
        })
      });

      const data = await response.json();
      if (data.success) {
        Swal.fire({
          icon: 'success',
          title: 'Saved!',
          text: data.message,
          showConfirmButton: false,
          timer: 1500
        });
      } else {
        Swal.fire({ icon: 'error', title: 'Error', text: data.message });
      }
    } catch (error) {
      Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.' });
    } finally {
      saveBtn.innerHTML = originalText;
      saveBtn.disabled = false;
    }
  });
</script>

<%- include("./partials/adminFooter") %>
