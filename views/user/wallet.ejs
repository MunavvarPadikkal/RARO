<%- include("../../views/partials/user/header.ejs") %>

<main class="main">
    <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
        <div class="container">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/profile">My Account</a></li>
                <li class="breadcrumb-item active" aria-current="page">Wallet</li>
            </ol>
        </div>
    </nav>

    <div class="page-content">
        <div class="dashboard">
            <div class="container">
                <div class="row">
                    <%- include("../../views/partials/user/profileSidebar.ejs", { activeTab: 'wallet' }) %>

                    <div class="col-md-8 col-lg-9">
                        <div class="tab-content">
                            <!-- Wallet Card -->
                            <div class="wallet-card mb-4" style="background: linear-gradient(135deg, #cc9966 0%, #a67c52 100%); border-radius: 20px; padding: 40px; color: white; box-shadow: 0 10px 25px rgba(204, 153, 102, 0.3);">
                                <div class="row align-items-center">
                                    <div class="col-sm-7">
                                        <h5 class="text-white opacity-75 mb-1" style="font-size: 1.4rem; text-transform: uppercase; letter-spacing: 2px;">Wallet Balance</h5>
                                        <h2 class="text-white mb-0" style="font-size: 4rem; font-weight: 800;">₹<%= wallet.balance.toLocaleString('en-IN') %></h2>
                                    </div>
                                    <div class="col-sm-5 text-right d-none d-sm-block">
                                        <i class="icon-wallet" style="font-size: 8rem; opacity: 0.2;"></i>
                                    </div>
                                </div>
                            </div>

                            <!-- Transaction History -->
                            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                                <div class="card-header bg-transparent border-0 pt-4 px-4">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h5 class="card-title mb-0" style="font-weight: 700;">Transaction History</h5>
                                        <!-- Add Font Awesome for the icon -->
                                        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
                                        <button class="btn btn-outline-primary-2 btn-round btn-sm" onclick="downloadStatement()">
                                            <i class="fa-solid fa-download mr-1"></i> Download Statement
                                        </button>
                                    </div>
                                </div>
                                <div class="card-body px-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th class="px-4 border-0 text-muted small text-uppercase">Date</th>
                                                    <th class="border-0 text-muted small text-uppercase">Reason</th>
                                                    <th class="border-0 text-muted small text-uppercase">Order ID</th>
                                                    <th class="border-0 text-muted small text-uppercase text-right px-4">Amount</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (wallet.transactions && wallet.transactions.length > 0) { %>
                                                    <% wallet.transactions.forEach(tx => { %>
                                                        <tr>
                                                            <td class="px-4 py-3 align-middle">
                                                                <span class="text-dark font-weight-medium">
                                                                    <%= new Date(tx.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                                                </span>
                                                                <br>
                                                                <small class="text-muted"><%= new Date(tx.date).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %></small>
                                                            </td>
                                                            <td class="py-3 align-middle">
                                                                <div class="d-flex align-items-center">
                                                                    <div class="mr-3 p-2 rounded-circle <%= tx.type === 'credit' ? 'bg-success-light' : 'bg-danger-light' %>">
                                                                        <i class="icon-<%= tx.type === 'credit' ? 'arrow-down' : 'arrow-up' %>" style="color: <%= tx.type === 'credit' ? '#2e7d32' : '#d32f2f' %>;"></i>
                                                                    </div>
                                                                    <span class="text-dark"><%= tx.reason %></span>
                                                                </div>
                                                            </td>
                                                            <td class="py-3 align-middle">
                                                                <% if (tx.orderId) { %>
                                                                    <span class="badge badge-light font-weight-normal px-3 py-2">#<%= tx.orderId %></span>
                                                                <% } else { %>
                                                                    <span class="text-muted">-</span>
                                                                <% } %>
                                                            </td>
                                                            <td class="py-3 align-middle text-right px-4">
                                                                <span class="font-weight-bold" style="font-size: 1.6rem; color: <%= tx.type === 'credit' ? '#2e7d32' : '#d32f2f' %>;">
                                                                    <%= tx.type === 'credit' ? '+' : '-' %> ₹<%= tx.amount.toLocaleString('en-IN') %>
                                                                </span>
                                                            </td>
                                                        </tr>
                                                    <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="4" class="text-center py-5">
                                                            <div class="py-4">
                                                                <i class="icon-info-circle" style="font-size: 4rem; color: #ddd;"></i>
                                                                <p class="mt-2 text-muted">No transactions found.</p>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Pagination -->
                            <% if (totalPages > 1) { %>
                                <nav aria-label="Page navigation" class="mt-4">
                                    <ul class="pagination justify-content-center">
                                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                            <a class="page-link page-link-prev" href="?page=<%= currentPage - 1 %>" aria-label="Previous">
                                                <span aria-hidden="true"><i class="icon-long-arrow-left"></i></span>Prev
                                            </a>
                                        </li>
                                        <% for(let i = 1; i <= totalPages; i++) { %>
                                            <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                                <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                            </li>
                                        <% } %>
                                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                            <a class="page-link page-link-next" href="?page=<%= currentPage + 1 %>" aria-label="Next">
                                                Next <span aria-hidden="true"><i class="icon-long-arrow-right"></i></span>
                                            </a>
                                        </li>
                                    </ul>
                                </nav>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .bg-success-light { background-color: rgba(46, 125, 50, 0.1); }
    .bg-danger-light { background-color: rgba(211, 47, 47, 0.1); }
    .wallet-card {
        position: relative;
        overflow: hidden;
    }
    .wallet-card::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
    }
</style>

</div><!-- End .page-wrapper -->

<button id="scroll-top" title="Back to Top">
    <i class="icon-arrow-up"></i>
</button>

<%- include("../../views/partials/user/footer.ejs") %>
<%- include("../../views/partials/user/mobileView.ejs") %>

<!-- PDF Generation Libraries -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>

<script>
    async function downloadStatement() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();

        // Add Title
        doc.setFontSize(20);
        doc.setTextColor(204, 153, 102); // Brand Color
        doc.text("RARO Wallet Statement", 14, 22);

        // Add User Info / Date
        doc.setFontSize(11);
        doc.setTextColor(100);
        doc.text(`Generated on: ${new Date().toLocaleString('en-IN')}`, 14, 30);
        doc.text(`Wallet Balance: ₹<%= wallet.balance.toLocaleString('en-IN') %>`, 14, 38);

        // Extract table data
        const table = document.querySelector(".table");
        
        doc.autoTable({
            html: table,
            startY: 45,
            theme: 'striped',
            headStyles: { fillColor: [204, 153, 102], textColor: [255, 255, 255] },
            alternateRowStyles: { fillColor: [250, 250, 250] },
            margin: { top: 45 },
            didDrawPage: function (data) {
                // Footer
                doc.setFontSize(10);
                doc.setTextColor(150);
                doc.text("Thank you for shopping with RARO!", 14, doc.internal.pageSize.height - 10);
            }
        });

        // Save PDF
        doc.save(`RARO_Wallet_Statement_${new Date().getTime()}.pdf`);
    }
</script>

<%- include("../../views/partials/user/scripts.ejs") %>
