<%- include("../partials/user/header.ejs") %>

	<main class="main">
		<div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
			<div class="container">
				<h1 class="page-title">My Account<span>Profile</span></h1>
			</div><!-- End .container -->
		</div><!-- End .page-header -->
		<nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
			<div class="container">
				<ol class="breadcrumb">
					<li class="breadcrumb-item"><a href="/">Home</a></li>
					<li class="breadcrumb-item active" aria-current="page">Profile</li>
				</ol>
			</div><!-- End .container -->
		</nav><!-- End .breadcrumb-nav -->

		<div class="page-content">
			<div class="dashboard">
				<div class="container">
					<div class="row">
                        <% var activeTab = 'dashboard'; %>
                        <%- include("../../views/partials/user/profileSidebar.ejs", { activeTab: activeTab }) %>

						<div class="col-md-8 col-lg-9">
							<div class="tab-content">
								<div class="tab-pane fade show active" id="tab-dashboard" role="tabpanel"
									aria-labelledby="tab-dashboard-link">
									<!-- Greeting -->
									<div class="d-flex justify-content-between align-items-center mb-4">
										<h4 class="mb-0" style="font-weight: 600; color: #333;">Welcome back, <strong>
												<%= user ? user.name : 'Unknown' %>
											</strong> 👋</h4>
									</div>

									<!-- DASHBOARD 2-COLUMN LAYOUT -->
									<div class="row">
										<!-- LEFT COLUMN: OVERVIEW CARDS (STACKED) -->
										<div class="col-md-4 mb-4">
											<div class="row">
												<div class="col-12 mb-2">
													<div class="card shadow-sm border-0 overview-card">
														<div class="card-body d-flex align-items-center p-3">
															<div class="icon-wrap shadow-sm" style="width: 48px; height: 48px; border-radius: 12px; background: #eef2ff; display: flex; align-items: center; justify-content: center;">
																<i class="fa-solid fa-bag-shopping" style="color: #4f46e5; font-size: 20px;"></i>
															</div>
															<div class="ml-3">
																<p class="text-muted mb-0" style="font-size: 13px; font-weight: 500;">Orders</p>
																<h3 class="mb-0" style="font-weight: 700; color: #222;"><%= stats ? stats.totalOrders : 0 %></h3>
															</div>
														</div>
													</div>
												</div>
									
												<div class="col-12 mb-2">
													<div class="card shadow-sm border-0 overview-card">
														<div class="card-body d-flex align-items-center p-3">
															<div class="icon-wrap shadow-sm" style="width: 48px; height: 48px; border-radius: 12px; background: #fff7ed; display: flex; align-items: center; justify-content: center;">
																<i class="fa-solid fa-clock" style="color: #f59e0b; font-size: 20px;"></i>
															</div>
															<div class="ml-3">
																<p class="text-muted mb-0" style="font-size: 13px; font-weight: 500;">Pending</p>
																<h3 class="mb-0" style="font-weight: 700; color: #222;"><%= stats ? stats.pendingOrders : 0 %></h3>
															</div>
														</div>
													</div>
												</div>

												<div class="col-12 mb-2">
													<div class="card shadow-sm border-0 overview-card">
														<div class="card-body d-flex align-items-center p-3">
															<div class="icon-wrap shadow-sm" style="width: 48px; height: 48px; border-radius: 12px; background: #f0fdf4; display: flex; align-items: center; justify-content: center;">
																<i class="fa-solid fa-ticket" style="color: #10b981; font-size: 20px;"></i>
															</div>
															<div class="ml-3">
																<p class="text-muted mb-0" style="font-size: 13px; font-weight: 500;">Coupons</p>
																<h3 class="mb-0" style="font-weight: 700; color: #222;"><%= stats ? stats.totalCoupons : 0 %></h3>
															</div>
														</div>
													</div>
												</div>

												<div class="col-12 mb-2">
													<div class="card shadow-sm border-0 overview-card">
														<div class="card-body d-flex align-items-center p-3">
															<div class="icon-wrap shadow-sm" style="width: 48px; height: 48px; border-radius: 12px; background: #faf5ff; display: flex; align-items: center; justify-content: center;">
																<i class="fa-solid fa-wallet" style="color: #8b5cf6; font-size: 20px;"></i>
															</div>
															<div class="ml-3">
																<p class="text-muted mb-0" style="font-size: 13px; font-weight: 500;">Wallet</p>
																<h3 class="mb-0" style="font-weight: 700; color: #222;">₹<%= stats ? stats.walletBalance : 0 %></h3>
															</div>
														</div>
													</div>
												</div>
											</div>
									
											<style>
												.overview-card {
													border-radius: 16px !important;
													background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%) !important;
													transition: transform 0.2s, box-shadow 0.2s !important;
												}
												.overview-card:hover {
													transform: translateY(-3px) !important;
													box-shadow: 0 8px 15px rgba(0, 0, 0, 0.08) !important;
												}
											</style>
										</div>
									
										<!-- RIGHT COLUMN: PROFILE CARD -->
										<div class="col-md-8 mb-4">
											<div class="card border-0 shadow-sm h-100" style="border-radius: 20px; overflow: hidden; background: #ffffff;">
												<div class="row g-0 h-100">
													<!-- AVATAR SIDE -->
													<div class="col-md-5 text-center p-4 d-flex flex-column justify-content-center align-items-center" style="background: linear-gradient(180deg, #fafafa 0%, #f4f4f4 100%); border-right: 1px solid #eaeaea;">
														<div class="position-relative d-inline-block shadow-sm" style="border-radius: 50%; padding: 4px; background: #fff;">
															<img id="userProfileImage"
																src="<%= user && user.profilePhoto ? user.profilePhoto : '/assets/images/user-avatar.png' %>"
																onerror="this.src='https://cdn-icons-png.flaticon.com/512/1077/1077114.png'"
																style="width: 110px; height: 110px; border-radius: 50%; object-fit: cover; border: 2px solid #eaeaea;">
										
															<label for="profileImgInput" class="shadow edit-avatar-btn"
																style="position: absolute; bottom: 0px; right: 0px; background: #222; color: #fff; border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s;">
																<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
																	<path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
																	<path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z" />
																</svg>
															</label>
															<input type="file" id="profileImgInput" style="display: none;" accept="image/*">
														</div>
														<style>
															.edit-avatar-btn:hover {
																background: #000 !important;
																transform: scale(1.1);
															}
														</style>
										
														<script>
															document.getElementById('profileImgInput').addEventListener('change', async function (e) {
																const file = e.target.files[0];
																if (!file) return;
																const formData = new FormData();
																formData.append('profilePhoto', file);
																try {
																	const response = await fetch('/updateProfilePhoto', {
																		method: 'POST',
																		body: formData
																	});
																	const result = await response.json();
																	if (result.success) {
																		document.getElementById('userProfileImage').src = result.imagePath;
																		if (typeof Swal !== 'undefined') {
																			Swal.fire('Success', 'Profile photo updated', 'success');
																		} else {
																			alert('Profile photo updated');
																		}
																	} else {
																		if (typeof Swal !== 'undefined') {
																			Swal.fire('Error', result.message || 'Failed to update photo', 'error');
																		} else {
																			alert(result.message || 'Error updating photo');
																		}
																	}
																} catch (error) {
																	console.error('Upload Error:', error);
																	alert('An error occurred during upload: ' + error.message);
																}
															});
														</script>
										
														<h5 class="mt-3 mb-1" style="font-weight: 700; color: #333;">
															<%= user ? user.name : 'User' %>
														</h5>
														<span class="badge badge-dark mb-1 px-3 py-1" style="border-radius: 20px; font-weight: 500;">
															Member since <%= user && user.createdOn ? new Date(user.createdOn).getFullYear() : '2024' %>
														</span>
													</div>

													<!-- DETAILS SIDE (SEQUENTIAL) -->
													<div class="col-md-7 p-4 d-flex flex-column justify-content-center">
														<h6 class="mb-3" style="font-weight: 600; color: #444; border-bottom: 2px solid #f0f0f0; padding-bottom: 8px;">
															Personal Details</h6>
									
														<div class="detail-list">
															<div class="mb-3">
																<div class="p-2 px-3 detail-box" style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s;">
																	<small class="text-muted text-uppercase" style="font-size: 10px; letter-spacing: 0.5px; display: block; margin-bottom: 2px;">Email Address</small>
																	<p class="mb-0 font-weight-medium" style="color: #222; font-size: 13px; word-break: break-all;">
																		<%= user ? user.email : '' %>
																	</p>
																</div>
															</div>
															<div class="mb-3">
																<div class="p-2 px-3 detail-box" style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s;">
																	<small class="text-muted text-uppercase" style="font-size: 10px; letter-spacing: 0.5px; display: block; margin-bottom: 2px;">Phone Number</small>
																	<p class="mb-0 font-weight-medium" style="color: #222; font-size: 13px;">
																		<%= user && user.phone ? user.phone : 'Not added' %>
																	</p>
																</div>
															</div>
															<div class="mb-3">
																<div class="p-2 px-3 detail-box" style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s;">
																	<div class="d-flex align-items-center justify-content-between">
																		<small class="text-muted text-uppercase" style="font-size: 10px; letter-spacing: 0.5px;">Default Address</small>
																		<a href="/address" style="font-size: 10px; color: #888; text-decoration: none;">Manage &rarr;</a>
																	</div>
																	<% const allAddresses=userAddress && userAddress.address ? userAddress.address : []; %>
																	<% const defaultAddr=allAddresses.find(a=> a.isDefault) || allAddresses[0] || null; %>
																	<% if(defaultAddr) { %>
																		<p class="mb-0 font-weight-medium" style="color: #222; font-size: 13px; line-height: 1.4;">
																			<strong><%= defaultAddr.name %></strong>, <%= defaultAddr.city %>
																		</p>
																	<% } else { %>
																		<p class="mb-0" style="color: #aaa; font-size: 12px;">No address added.</p>
																	<% } %>
																</div>
															</div>
														</div>
									
														<!-- BUTTON -->
														<div class="mt-2">
															<a href="/edit-profile" class="btn btn-dark px-4 py-2 shadow-sm d-inline-flex align-items-center justify-content-center edit-profile-btn" style="border-radius: 8px; font-weight: 500; font-size: 13px; transition: all 0.3s; gap: 8px; width: 100%;">
																<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
																	<path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
																</svg> Edit Profile
															</a>
														</div>
														<style>
															.detail-box:hover {
																background: #fff !important;
																box-shadow: 0 4px 10px rgba(0, 0, 0, 0.04) !important;
															}
															.edit-profile-btn:hover {
																background: #444 !important;
																transform: translateY(-1px);
																color: white !important;
															}
														</style>
													</div>
												</div>
											</div>
										</div>
									</div>

								</div><!-- .End .tab-pane -->


							</div>
						</div><!-- End .col-lg-9 -->
					</div><!-- End .row -->
				</div><!-- End .container -->
			</div><!-- End .dashboard -->
		</div><!-- End .page-content -->
	</main><!-- End .main -->


	

	</div><!-- End .page-wrapper -->

		<button id="scroll-top" title="Back to Top">
			<i class="icon-arrow-up"></i>
		</button>

<%-include("../../views/partials/user/mobileView.ejs")%>
<%-include("../../views/partials/user/footer.ejs")%>

	    <script src="assets/js/jquery.min.js"></script>
        <script src="assets/js/bootstrap.bundle.min.js"></script>
        <script src="assets/js/jquery.hoverIntent.min.js"></script>
        <script src="assets/js/jquery.waypoints.min.js"></script>
        <script src="assets/js/superfish.min.js"></script>
        <script src="assets/js/owl.carousel.min.js"></script>
        <script src="assets/js/jquery.magnific-popup.min.js"></script>
        <!-- Main JS File -->
        <script src="assets/js/main.js"></script>
	