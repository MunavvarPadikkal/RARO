<%- include("../partials/user/header.ejs") %>

	<main class="main">
		<div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
			<div class="container">
				<h1 class="page-title">My Account<span>Profile</span></h1>
			</div><!-- End .container -->
		</div><!-- End .page-header -->
		<nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
			<div class="container">
				<ol class="breadcrumb">
					<li class="breadcrumb-item"><a href="/">Home</a></li>
					<li class="breadcrumb-item active" aria-current="page">Profile</li>
				</ol>
			</div><!-- End .container -->
		</nav><!-- End .breadcrumb-nav -->

		<div class="page-content">
			<div class="dashboard">
				<div class="container">
					<div class="row">
						<aside class="col-md-4 col-lg-3">
							<ul class="nav nav-dashboard flex-column mb-3 mb-md-0" role="tablist">
								<li class="nav-item">
									<a class="nav-link active" id="tab-dashboard-link" data-toggle="tab"
										href="#tab-dashboard" role="tab" aria-controls="tab-dashboard"
										aria-selected="true">Dashboard</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="tab-orders-link" data-toggle="tab" href="#tab-orders"
										role="tab" aria-controls="tab-orders" aria-selected="false">Orders</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="tab-downloads-link" data-toggle="tab" href="#tab-downloads"
										role="tab" aria-controls="tab-downloads" aria-selected="false">Coupons</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" href="/address">Addresses</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="tab-wallet-link" data-toggle="tab" href="#tab-wallet"
										role="tab" aria-controls="tab-wallet" aria-selected="false">Wallet</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" id="tab-invite-link" data-toggle="tab" href="#tab-invite"
										role="tab" aria-controls="tab-invite" aria-selected="false">Invite & earn</a>
								</li>
								<li class="nav-item">
									<a class="nav-link" href="javascript:void(0);" onclick="confirmSignOut()">Sign
										Out</a>
								</li>
							</ul>

							<!-- SweetAlert2 CDN & Sign Out Logic -->
							<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
							<script>
								function confirmSignOut() {
									Swal.fire({
										title: 'Sign Out?',
										text: "Are you sure you want to log out of your account?",
										icon: 'warning',
										showCancelButton: true,
										confirmButtonColor: '#d33',
										cancelButtonColor: '#3085d6',
										confirmButtonText: 'Yes, Sign Out',
										cancelButtonText: 'Cancel',
										reverseButtons: true
									}).then((result) => {
										if (result.isConfirmed) {
											window.location.href = '/logout';
										}
									});
								}
							</script>
						</aside><!-- End .col-lg-3 -->

						<div class="col-md-8 col-lg-9">
							<div class="tab-content">
								<div class="tab-pane fade show active" id="tab-dashboard" role="tabpanel"
									aria-labelledby="tab-dashboard-link">
									<!-- Greeting -->
									<div class="d-flex justify-content-between align-items-center mb-4">
										<h4 class="mb-0" style="font-weight: 600; color: #333;">Welcome back, <strong>
												<%= user ? user.name : 'Unknown' %>
											</strong> 👋</h4>
									</div>

									<!-- PROFILE CARD (MOVED TO TOP) -->
									<div class="card border-0 shadow-sm mb-4"
										style="border-radius: 20px; overflow: hidden; background: #ffffff;">
										<div class="row g-0">

											<!-- LEFT PROFILE INFO -->
											<div class="col-md-4 text-center p-5 d-flex flex-column justify-content-center align-items-center"
												style="background: linear-gradient(180deg, #fafafa 0%, #f4f4f4 100%); border-right: 1px solid #eaeaea;">
												<div class="position-relative d-inline-block shadow-sm"
													style="border-radius: 50%; padding: 4px; background: #fff;">
													<img id="userProfileImage"
														src="<%= user && user.profilePhoto ? user.profilePhoto : '/assets/images/user-avatar.png' %>"
														onerror="this.src='https://cdn-icons-png.flaticon.com/512/1077/1077114.png'"
														style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 2px solid #eaeaea;">

													<label for="profileImgInput" class="shadow edit-avatar-btn"
														style="position: absolute; bottom: 5px; right: 5px; background: #222; color: #fff; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s;">
														<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
															fill="currentColor" viewBox="0 0 16 16">
															<path
																d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
															<path fill-rule="evenodd"
																d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5v11z" />
														</svg>
													</label>
													<input type="file" id="profileImgInput" style="display: none;"
														accept="image/*">
												</div>
												<style>
													.edit-avatar-btn:hover {
														background: #000 !important;
														transform: scale(1.1);
													}
												</style>

												<script>
													document.getElementById('profileImgInput').addEventListener('change', async function (e) {
														const file = e.target.files[0];
														if (!file) return;

														const formData = new FormData();
														formData.append('profilePhoto', file);

														try {
															const response = await fetch('/updateProfilePhoto', {
																method: 'POST',
																body: formData
															});
															const result = await response.json();

															if (result.success) {
																document.getElementById('userProfileImage').src = result.imagePath;
																if (typeof Swal !== 'undefined') {
																	Swal.fire('Success', 'Profile photo updated', 'success');
																} else {
																	alert('Profile photo updated');
																}
															} else {
																if (typeof Swal !== 'undefined') {
																	Swal.fire('Error', result.message || 'Failed to update photo', 'error');
																} else {
																	alert(result.message || 'Error updating photo');
																}
															}
														} catch (error) {
															console.error('Upload Error:', error);
															alert('An error occurred during upload: ' + error.message);
														}
													});
												</script>

												<h4 class="mt-4 mb-1" style="font-weight: 700; color: #333;">
													<%= user ? user.name : 'User' %>
												</h4>
												<span class="badge badge-dark mb-2 px-3 py-1"
													style="border-radius: 20px; font-weight: 500;">
													Member since <%= user && user.createdOn ? new
														Date(user.createdOn).getFullYear() : '2024' %>
												</span>
											</div>

											<!-- RIGHT DETAILS -->
											<div class="col-md-8 p-5 d-flex flex-column justify-content-center">
												<h5 class="mb-4"
													style="font-weight: 600; color: #444; border-bottom: 2px solid #f0f0f0; padding-bottom: 10px;">
													Personal Details</h5>

												<div class="row mb-4">
													<div class="col-md-6 mb-3 mb-md-0">
														<div class="p-3 detail-box"
															style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s; height: 100%;">
															<div class="d-flex align-items-center mb-1">
																<svg xmlns="http://www.w3.org/2000/svg" width="16"
																	height="16" fill="#888" class="mr-2"
																	viewBox="0 0 16 16">
																	<path
																		d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741zM1 11.105l4.708-2.897L1 5.383v5.722z" />
																</svg>
																<small class="text-muted text-uppercase"
																	style="font-size: 11px; letter-spacing: 0.5px;">Email
																	Address</small>
															</div>
															<p class="mb-0 font-weight-medium"
																style="color: #222; font-size: 15px; word-break: break-all;">
																<%= user ? user.email : '' %>
															</p>
														</div>
													</div>
													<div class="col-md-6">
														<div class="p-3 detail-box"
															style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s; height: 100%;">
															<div class="d-flex align-items-center mb-1">
																<svg xmlns="http://www.w3.org/2000/svg" width="16"
																	height="16" fill="#888" class="mr-2"
																	viewBox="0 0 16 16">
																	<path
																		d="M3.654 1.328a.678.678 0 0 0-1.015-.063L1.605 2.3c-.483.484-.661 1.169-.45 1.77a17.568 17.568 0 0 0 4.168 6.608 17.569 17.569 0 0 0 6.608 4.168c.601.211 1.286.033 1.77-.45l1.034-1.034a.678.678 0 0 0-.063-1.015l-2.307-1.794a.678.678 0 0 0-.58-.122l-2.19.547a1.745 1.745 0 0 1-1.657-.459L5.482 8.062a1.745 1.745 0 0 1-.46-1.657l.548-2.19a.678.678 0 0 0-.122-.58L3.654 1.328zM1.884.511a1.745 1.745 0 0 1 2.612.163L6.29 2.98c.329.423.445.974.315 1.494l-.547 2.19a.51.51 0 0 0 .146.518l2.951 2.951a.51.51 0 0 0 .518.146l2.19-.547a1.745 1.745 0 0 1 1.494.315l2.306 1.794c.829.645.905 1.87.163 2.611l-1.034 1.034c-.74.74-1.846 1.065-2.877.702a18.634 18.634 0 0 1-7.01-4.42 18.634 18.634 0 0 1-4.42-7.009c-.362-1.03-.037-2.137.703-2.877L1.885.511z" />
																</svg>
																<small class="text-muted text-uppercase"
																	style="font-size: 11px; letter-spacing: 0.5px;">Phone
																	Number</small>
															</div>
															<p class="mb-0 font-weight-medium"
																style="color: #222; font-size: 15px;">
																<%= user && user.phone ? user.phone : 'Not added' %>
															</p>
														</div>
													</div>
												</div>

												<div class="row mb-4">
													<div class="col-12">
														<div class="p-3 detail-box"
															style="background: #fdfdfd; border: 1px solid #f0f0f0; border-radius: 12px; transition: 0.3s;">
															<div
																class="d-flex align-items-center justify-content-between mb-2">
																<div class="d-flex align-items-center">
																	<svg xmlns="http://www.w3.org/2000/svg" width="16"
																		height="16" fill="#888" class="mr-2"
																		viewBox="0 0 16 16">
																		<path
																			d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10zm0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6z" />
																	</svg>
																	<small class="text-muted text-uppercase"
																		style="font-size: 11px; letter-spacing: 0.5px;">Default
																		Address</small>
																</div>
																<a href="/address"
																	style="font-size: 12px; color: #888; text-decoration: none; font-weight: 500;">Manage
																	&rarr;</a>
															</div>
															<% const allAddresses=userAddress && userAddress.address ?
																userAddress.address : []; %>
																<% const defaultAddr=allAddresses.find(a=> a.isDefault)
																	|| allAddresses[0] || null; %>
																	<% if(defaultAddr) { %>
																		<p class="mb-0 font-weight-medium"
																			style="color: #222; font-size: 15px; line-height: 1.6;">
																			<strong>
																				<%= defaultAddr.name %>
																			</strong><br>
																			<span style="color:#555;font-size:14px;">
																				<%= defaultAddr.landMark %>, <%=
																						defaultAddr.city %>, <%=
																							defaultAddr.state %> - <%=
																								defaultAddr.pincode %>
																			</span>
																		</p>
																		<% } else { %>
																			<p class="mb-0"
																				style="color: #aaa; font-size: 14px;">No
																				address added. <a href="/address"
																					style="color: #c8a165; font-weight: 500;">Add
																					one &rarr;</a></p>
																			<% } %>
														</div>
													</div>
												</div>

												<style>
													.detail-box:hover {
														background: #fff !important;
														box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05) !important;
													}
												</style>

												<!-- BUTTON (IMPROVED UX) -->
												<div class="mt-2 text-md-right text-center">
													<a href="/edit-profile"
														class="btn btn-dark px-4 py-2 shadow-sm d-inline-flex align-items-center justify-content-center edit-profile-btn"
														style="border-radius: 8px; font-weight: 500; font-size: 15px; transition: all 0.3s; gap: 8px;">
														<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
															fill="currentColor" viewBox="0 0 16 16">
															<path
																d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z" />
														</svg>
														Edit Profile
													</a>
												</div>
												<style>
													.edit-profile-btn:hover {
														background: #444 !important;
														transform: translateY(-2px);
														box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1) !important;
														color: white !important;
													}
												</style>
											</div>

										</div>
									</div>

									<!-- OVERVIEW CARDS -->
									<div class="row mb-4">
										<div class="col-md-3 col-6 mb-3 mb-md-0">
											<div class="card shadow-sm border-0 h-100 overview-card">
												<div class="card-body d-flex align-items-center">
													<div class="icon-wrap shadow-sm"
														style="width: 48px; height: 48px; border-radius: 12px; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px;">
														📦
													</div>
													<div class="ml-3">
														<p class="text-muted mb-0"
															style="font-size: 13px; font-weight: 500;">Orders</p>
														<h3 class="mb-0" style="font-weight: 700; color: #222;">0</h3>
													</div>
												</div>
											</div>
										</div>

										<div class="col-md-3 col-6 mb-3 mb-md-0">
											<div class="card shadow-sm border-0 h-100 overview-card">
												<div class="card-body d-flex align-items-center">
													<div class="icon-wrap shadow-sm"
														style="width: 48px; height: 48px; border-radius: 12px; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px;">
														💰
													</div>
													<div class="ml-3">
														<p class="text-muted mb-0"
															style="font-size: 13px; font-weight: 500;">Wallet</p>
														<h3 class="mb-0" style="font-weight: 700; color: #222;">₹0.00
														</h3>
													</div>
												</div>
											</div>
										</div>

										<div class="col-md-3 col-6 mb-3 mb-md-0">
											<div class="card shadow-sm border-0 h-100 overview-card">
												<div class="card-body d-flex align-items-center">
													<div class="icon-wrap shadow-sm"
														style="width: 48px; height: 48px; border-radius: 12px; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px;">
														🎟️
													</div>
													<div class="ml-3">
														<p class="text-muted mb-0"
															style="font-size: 13px; font-weight: 500;">Coupons</p>
														<h3 class="mb-0" style="font-weight: 700; color: #222;">0</h3>
													</div>
												</div>
											</div>
										</div>

										<div class="col-md-3 col-6 mb-3 mb-md-0">
											<div class="card shadow-sm border-0 h-100 overview-card">
												<div class="card-body d-flex align-items-center">
													<div class="icon-wrap shadow-sm"
														style="width: 48px; height: 48px; border-radius: 12px; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px;">
														⏳
													</div>
													<div class="ml-3">
														<p class="text-muted mb-0"
															style="font-size: 13px; font-weight: 500;">Pending</p>
														<h3 class="mb-0" style="font-weight: 700; color: #222;">0</h3>
													</div>
												</div>
											</div>
										</div>
									</div>

									<style>
										.overview-card {
											border-radius: 16px !important;
											background: linear-gradient(135deg, #fdfbfb 0%, #ebedee 100%) !important;
											transition: transform 0.2s, box-shadow 0.2s !important;
										}

										.overview-card:hover {
											transform: translateY(-5px) !important;
											box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08) !important;
										}
									</style>

								</div><!-- .End .tab-pane -->


							</div>
						</div><!-- End .col-lg-9 -->
					</div><!-- End .row -->
				</div><!-- End .container -->
			</div><!-- End .dashboard -->
		</div><!-- End .page-content -->
	</main><!-- End .main -->


	

	</div><!-- End .page-wrapper -->

		<button id="scroll-top" title="Back to Top">
			<i class="icon-arrow-up"></i>
		</button>

<%-include("../../views/partials/user/mobileView.ejs")%>
<%-include("../../views/partials/user/footer.ejs")%>

	    <script src="assets/js/jquery.min.js"></script>
        <script src="assets/js/bootstrap.bundle.min.js"></script>
        <script src="assets/js/jquery.hoverIntent.min.js"></script>
        <script src="assets/js/jquery.waypoints.min.js"></script>
        <script src="assets/js/superfish.min.js"></script>
        <script src="assets/js/owl.carousel.min.js"></script>
        <script src="assets/js/jquery.magnific-popup.min.js"></script>
        <!-- Main JS File -->
        <script src="assets/js/main.js"></script>
	