<%-include("../../views/partials/user/header.ejs")%>

<main class="main">
    <div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
        <div class="container">
            <h1 class="page-title">Shopping Cart<span>Shop</span></h1>
        </div><!-- End .container -->
    </div><!-- End .page-header -->
    <nav aria-label="breadcrumb" class="breadcrumb-nav">
        <div class="container">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                <li class="breadcrumb-item active" aria-current="page">Shopping Cart</li>
            </ol>
        </div><!-- End .container -->
    </nav><!-- End .breadcrumb-nav -->

    <div class="page-content">
        <div class="cart">
            <div class="container">
                <div class="row">
                    <div class="col-lg-9">
                        <table class="table table-cart table-mobile">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Size</th>
                                    <th>Color</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                <% if (cart && cart.items && cart.items.length > 0) { %>
                                    <% cart.items.forEach(item => { %>
                                        <% 
                                            // Handle cases where product was deleted/blocked after adding to cart
                                            const product = item.productId;
                                            if (!product) { return; } 
                                            const isBlockedOrDeleted = product.isDeleted || product.isBlocked;
                                            
                                            // Determine effective price 
                                            const effectivePrice = product.salePrice < product.regularPrice ? product.salePrice : product.regularPrice;
                                            const variant = product.variants ? product.variants.find(v => v.size === item.size && v.color === item.color) : null;
                                            const availableStock = variant ? variant.stock : 0;
                                            const isOutOfStock = availableStock <= 0;
                                            
                                            const maxAllowed = Math.min(availableStock, 5);
                                        %>
                                        <tr class="cart-item-row" data-product-id="<%= product._id %>" data-size="<%= item.size %>" data-color="<%= item.color %>">
                                            <td class="product-col">
                                                <div class="product">
                                                    <figure class="product-media">
                                                        <a href="/product/<%= product._id %>">
                                                            <% if (product.productImage && product.productImage.length > 0) { %>
                                                                <img src="/uploads/productImages/<%= product.productImage[0] %>" alt="<%= product.productName %>">
                                                            <% } else { %>
                                                                <img src="/assets/images/products/table/product-1.jpg" alt="No image">
                                                            <% } %>
                                                        </a>
                                                    </figure>

                                                    <h3 class="product-title">
                                                        <a href="/product/<%= product._id %>"><%= product.productName %></a>
                                                        <% if (isBlockedOrDeleted) { %>
                                                            <br><span class="text-danger" style="font-size: 1.2rem;">Product Not Available</span>
                                                        <% } else if (isOutOfStock) { %>
                                                            <br><span class="text-danger" style="font-size: 1.2rem;">Out of Stock</span>
                                                        <% } else if (item.quantity > availableStock) { %>
                                                            <br><span class="text-warning" style="font-size: 1.2rem;">Only <%= availableStock %> left in stock</span>
                                                        <% } %>
                                                    </h3><!-- End .product-title -->
                                                </div><!-- End .product -->
                                            </td>
                                            <td class="price-col">
                                                <% if (product.salePrice < product.regularPrice) { %>
                                                    ₹<%= product.salePrice %><br>
                                                    <small style="text-decoration: line-through; color: #999;">₹<%= product.regularPrice %></small>
                                                <% } else { %>
                                                    ₹<%= effectivePrice %>
                                                <% } %>
                                            </td>
                                            <td class="size-col"><%= item.size %></td>
                                            <td class="color-col"><%= item.color %></td>
                                            <td class="quantity-col">
                                                <div class="cart-product-quantity">
                                                    <input type="number" class="form-control qty-input" 
                                                           value="<%= item.quantity %>" min="1" 
                                                           data-max="<%= maxAllowed > 0 ? maxAllowed : 1 %>"
                                                           step="1" data-decimals="0" required <%= (isOutOfStock || isBlockedOrDeleted) ? 'disabled' : '' %>>
                                                </div><!-- End .cart-product-quantity -->
                                            </td>
                                            <td class="total-col item-total-price">₹<%= effectivePrice * item.quantity %></td>
                                            <td class="remove-col">
                                                <button class="btn-remove remove-item-btn"><i class="icon-close"></i></button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-5">
                                            <p>Your cart is currently empty.</p>
                                            <a href="/shop" class="btn btn-primary mt-2">Go Shopping</a>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table><!-- End .table table-mobile -->

                        <% if (cart && cart.items && cart.items.length > 0) { %>
                        <div class="cart-bottom">
                        </div><!-- End .cart-bottom -->
                        <% } %>
                    </div><!-- End .col-lg-9 -->
                    
                    <aside class="col-lg-3">
                        <div class="summary summary-cart">
                            <h3 class="summary-title">Cart Total</h3><!-- End .summary-title -->

                            <table class="table table-summary">
                                <tbody>
                                    <tr class="summary-subtotal">
                                        <td>Subtotal (<%= itemsCount %> items):</td>
                                        <td id="cart-subtotal">₹<%= subtotal %></td>
                                    </tr><!-- End .summary-subtotal -->

                                    <% if (discount > 0) { %>
                                    <tr class="summary-discount text-success">
                                        <td>
                                            Coupon Discount
                                            <% if (cart && cart.appliedCoupon) { %>
                                                <span class="font-weight-bold" style="color: #d38c64;">(<%= cart.appliedCoupon.code %>)</span>
                                            <% } %>:
                                        </td>
                                        <td>- ₹<%= discount %></td>
                                    </tr>
                                    <% } %>
                                    
                                    <tr class="summary-shipping">
                                        <td>Shipping:</td>
                                        <td>&nbsp;</td>
                                    </tr>

                                    <tr class="summary-shipping-row">
                                        <td>
                                            <div class="custom-control custom-radio">
                                                <input type="radio" id="free-shipping" name="shipping" class="custom-control-input" checked>
                                                <label class="custom-control-label" for="free-shipping">Free Shipping</label>
                                            </div><!-- End .custom-control -->
                                        </td>
                                        <td>₹0.00</td>
                                    </tr><!-- End .summary-shipping-row -->

                                    <tr class="summary-total">
                                        <td>Total:</td>
                                        <td id="cart-total">₹<%= finalAmount %></td>
                                    </tr><!-- End .summary-total -->
                                </tbody>
                            </table><!-- End .table table-summary -->
                            
                            <% 
                             let hasInvalidItems = false;
                             if (cart && cart.items) {
                                 cart.items.forEach(item => {
                                     const p = item.productId;
                                     if (!p || p.isDeleted || p.isBlocked) { hasInvalidItems = true; }
                                     else {
                                         const vData = p.variants ? p.variants.find(v => v.size === item.size && v.color === item.color) : null;
                                         if (!vData || vData.stock < item.quantity) {
                                             hasInvalidItems = true;
                                         }
                                     }
                                 });
                             }
                            %>

                            <% if (cart && cart.items && cart.items.length > 0) { %>
                                <% if (hasInvalidItems) { %>
                                    <div class="alert alert-warning p-2 mb-2" style="font-size:1.3rem;">
                                        Some items in your cart are currently out of stock or unavailable. Please remove them to proceed.
                                    </div>
                                    <a href="#" class="btn btn-outline-primary-2 btn-order btn-block disabled" style="pointer-events: none;">PROCEED TO CHECKOUT</a>
                                <% } else { %>
                                    <a href="/checkout" class="btn btn-outline-primary-2 btn-order btn-block">PROCEED TO CHECKOUT</a>
                                <% } %>
                            <% } else { %>
                                <a href="/shop" class="btn btn-outline-primary-2 btn-order btn-block">CONTINUE SHOPPING</a>
                            <% } %>
                        </div><!-- End .summary -->

                        <a href="/shop" class="btn btn-outline-dark-2 btn-block mb-3"><span>CONTINUE SHOPPING</span><i class="icon-refresh"></i></a>
                    </aside><!-- End .col-lg-3 -->
                </div><!-- End .row -->
            </div><!-- End .container -->
        </div><!-- End .cart -->
    </div><!-- End .page-content -->
</main><!-- End .main -->

<button id="scroll-top" title="Back to Top">
    <i class="icon-arrow-up"></i>
</button>

<script src="assets/js/jquery.min.js"></script>
<script src="assets/js/bootstrap.bundle.min.js"></script>
<script src="assets/js/jquery.hoverIntent.min.js"></script>
<script src="assets/js/jquery.waypoints.min.js"></script>
<script src="assets/js/superfish.min.js"></script>
<script src="assets/js/owl.carousel.min.js"></script>
<script src="assets/js/jquery.magnific-popup.min.js"></script>
<!-- Main JS File -->
<script src="assets/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function() {
        // Handle quantity change
        $('.qty-input').on('change', async function() {
            const row = $(this).closest('tr');
            const productId = row.data('product-id');
            const size = row.data('size');
            const color = row.data('color');
            const max = parseInt($(this).data('max'));
            const newQuantity = parseInt($(this).val());
            
            if (isNaN(newQuantity)) {
                $(this).val(1);
                return;
            }

            if (newQuantity > max) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Limit Reached',
                    text: max === 5 ? 'Maximum 5 units allowed per item.' : `Only ${max} units available in stock.`
                }).then(() => {
                    $(this).val(max);
                });
                return;
            }

            if (newQuantity < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Quantity Error',
                    text: 'Quantity must be at least 1'
                }).then(() => {
                    $(this).val(1);
                });
                return;
            }

            try {
                const response = await fetch('/cart/update-quantity', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId, size, color, quantity: newQuantity })
                });

                const data = await response.json();
                
                if (response.ok && data.success) {
                    // Update DOM elements dynamically instead of reloading
                    row.find('.item-total-price').text('₹' + data.itemTotal);
                    $('#cart-subtotal').text('₹' + data.subtotal);
                    $('#cart-total').text('₹' + data.finalAmount);
                    
                    // Update subtotal item count text
                    $('.summary-subtotal td:first-child').text(`Subtotal (${data.itemsCount} items):`);
                    
                    // Update header cart count badge
                    const $headerCartCount = $('.cart-dropdown a[href="/cart"] .cart-count');
                    if ($headerCartCount.length) {
                        $headerCartCount.text(data.itemsCount);
                        if (data.itemsCount > 0) {
                            $headerCartCount.css('display', 'flex');
                        } else {
                            $headerCartCount.hide();
                        }
                    }

                    // Handle coupon discount row updates
                    const discountRow = $('.summary-discount');
                    if (data.discount > 0) {
                        if (discountRow.length) {
                            discountRow.find('td:last-child').text('- ₹' + data.discount);
                        } else {
                            // If discount row didn't exist but now discount is > 0, reload to redraw
                            window.location.reload();
                        }
                    } else if (discountRow.length) {
                        // Coupon became invalid (e.g., subtotal dropped below min purchase), reload to redraw
                        window.location.reload();
                    }
                } else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Quantity Error',
                        text: data.message || 'Could not update quantity'
                    }).then(() => {
                        window.location.reload();
                    });
                }
            } catch (error) {
                console.error("Error updating quantity:", error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong.'
                }).then(() => {
                    window.location.reload();
                });
            }
        });

        // Handle item removal
        $('.remove-item-btn').on('click', async function(e) {
            e.preventDefault();
            
            const row = $(this).closest('tr');
            const productId = row.data('product-id');
            const size = row.data('size');
            const color = row.data('color');

            const confirm = await Swal.fire({
                title: 'Are you sure?',
                text: "Do you want to remove this item from your cart?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, remove it!'
            });

            if (confirm.isConfirmed) {
                try {
                    const response = await fetch('/cart/remove', {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ productId, size, color })
                    });

                    const data = await response.json();
                    
                    if (response.ok && data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Removed!',
                            text: 'Item has been removed from cart.',
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Failed',
                            text: data.message || 'Could not remove item'
                        });
                    }
                } catch (error) {
                    console.error("Error removing item:", error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong.'
                    });
                }
            }

        });
    });
</script>

<%-include("../../views/partials/user/mobileView.ejs")%>
<%-include("../../views/partials/user/footer.ejs")%>