<%- include("../partials/user/header") %>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
.otp-overlay { top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; padding: 60px 0; min-height: 60vh; }
.otp-box { background: #f7f7f7; width: 380px; padding: 40px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
.otp-box h4 { margin-bottom: 10px; font-weight: 500; }
.line { width: 60%; height: 2px; background: #c8a165; margin: 10px auto 30px; }
.otp-inputs { display: flex; justify-content: space-between; margin-bottom: 25px; }
.otp-input { width: 60px; height: 60px; text-align: center; font-size: 22px; border: none; background: #e0e0e0; outline: none; }
.otp-btn { padding: 10px 30px; border: 1px solid #c8a165; background: transparent; cursor: pointer; margin-bottom: 15px; width: 100%; }
.otp-btn:hover { background: #c8a165; color: #fff; }
.timer-text { font-size: 17px; margin-bottom: 10px; }
#timer { font-weight: bold; color: #c8a165; }
.resend-text a { color: red; text-decoration: none; font-size: 13px; }
</style>

<main class="main">
    <div class="error-content text-center" style="background-image: url('/assets/images/RARO login bg.jpg')">
        <div class="container">
            <div class="otp-overlay">
                <div class="otp-box">
                    <h4>OTP Verification</h4>
                    <div class="line"></div>

                    <form id="verifyOtpForm" action="/verifyForgotPasswordOtp" method="post">
                        <div class="otp-inputs">
                            <input type="text" maxlength="1" class="otp-input" />
                            <input type="text" maxlength="1" class="otp-input" />
                            <input type="text" maxlength="1" class="otp-input" />
                            <input type="text" maxlength="1" class="otp-input" />
                        </div>

                        <button type="submit" class="otp-btn">VERIFY →</button>

                        <p class="timer-text">
                            Time remaining: <span id="timer">01:00</span>
                        </p>

                        <p class="resend-text">
                            Don't get it? <a href="#" id="resendBtn">Resend</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include("../partials/user/footer.ejs") %>
<button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>
<%-include("../../views/partials/user/mobileView.ejs")%>

<script>
  const inputs = document.querySelectorAll(".otp-input");
  inputs.forEach((input, index) => {
    input.addEventListener("input", (e) => {
      if (e.target.value.length === 1 && index < inputs.length - 1) inputs[index + 1].focus();
    });
    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && !input.value && index > 0) inputs[index - 1].focus();
    });
  });

  let countdown;
  let timeLeft = 60;
  const timerDisplay = document.getElementById("timer");
  const resendBtn = document.getElementById("resendBtn");

  function startTimer() {
    resendBtn.style.pointerEvents = "none";
    resendBtn.style.opacity = "0.5";
    countdown = setInterval(() => {
      let m = Math.floor(timeLeft / 60);
      let s = timeLeft % 60;
      s = s < 10 ? "0" + s : s;
      timerDisplay.textContent = `${m}:${s}`;
      if (timeLeft <= 0) {
        clearInterval(countdown);
        timerDisplay.textContent = "Expired";
        resendBtn.style.pointerEvents = "auto";
        resendBtn.style.opacity = "1";
      }
      timeLeft--;
    }, 1000);
  }

  function resetTimer() {
    clearInterval(countdown);
    timeLeft = 60;
    startTimer();
  }

  startTimer();

  document.getElementById("verifyOtpForm").addEventListener("submit", function(e){
    e.preventDefault();
    let otpInput = "";
    document.querySelectorAll(".otp-input").forEach(input => otpInput += input.value);

    if(otpInput.length !== 4){
      Swal.fire({ icon:"warning", title:"Enter full OTP", text:"Please enter all 4 digits" });
      return;
    }

    $.ajax({
      type: "POST",
      url: "/verifyForgotPasswordOtp",
      data: { otp: otpInput },
      success: function(response){
        if(response.success){
          Swal.fire({ icon:"success", title:"OTP Verified Successfully", showConfirmButton:false, timer:1500 })
          .then(()=>{ window.location.href = response.redirectUrl; });
        }
      },
      error: function(xhr){
        Swal.fire({ icon:"error", title:"Invalid OTP", text: xhr.responseJSON?.message || "Please try again" });
      }
    });
  });

  resendBtn.addEventListener("click", function(e) {
    e.preventDefault();
    fetch("/resendForgotPasswordOtp", { method: "POST" })
    .then(res => res.json())
    .then(data => {
      if(data.success){
        Swal.fire({ icon: "success", title: "New OTP Sent!", timer: 1500, showConfirmButton: false });
        resetTimer();
      } else {
        Swal.fire({ icon: "error", title: "Wait", text: data.message });
      }
    })
    .catch(() => { Swal.fire({ icon: "error", title: "Something went wrong" }); });
  });
</script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/main.js"></script>
