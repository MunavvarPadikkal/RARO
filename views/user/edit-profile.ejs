<%- include("../../views/partials/user/header.ejs") %>

    <main class="main">
        <div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
            <div class="container">
                <h1 class="page-title">My Account<span>Edit Profile</span></h1>
            </div>
        </div>
        <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
            <div class="container">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/profile">Profile</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit Profile</li>
                </ol>
            </div>
        </nav>

        <div class="page-content">
            <div class="dashboard">
                <div class="container">
                    <div class="row">
                        <% var activeTab = 'edit-profile'; %>
                        <%- include("../../views/partials/user/profileSidebar.ejs", { activeTab: activeTab }) %>
                        <div class="col-md-8 col-lg-9">
                            <div class="card shadow-sm border-0 mb-4"
                                style="border-radius: 16px; overflow: hidden; background: #ffffff;">
                                <div class="card-body p-5">
                                    <h3 class="mb-4 text-center" style="font-weight: 600; color: #333;">Account Details</h3>

                                    <form id="accountDetailsForm">
                                        <label
                                            style="font-size: 13px; color: #666; margin-bottom: 5px;">Full
                                            Name*</label>
                                        <input type="text" name="name" id="editName"
                                            class="form-control mb-3"
                                            value="<%= user && user.name ? user.name : '' %>" required
                                            style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none;">

                                        <label
                                            style="font-size: 13px; color: #666; margin-bottom: 5px;">Email
                                            Address*</label>
                                        <div class="d-flex mb-3" style="gap: 8px;">
                                            <input type="email" name="email" id="editEmail"
                                                class="form-control mb-0"
                                                value="<%= user && user.email ? user.email : '' %>"
                                                style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none; flex: 1;"
                                                readonly>
                                            <button type="button" id="changeEmailBtn"
                                                class="btn btn-outline-dark"
                                                style="padding: 12px 25px; border-radius: 8px; font-weight: 500; font-size: 12px; min-width: max-content; height: 40px; cursor: pointer; letter-spacing: 0.5px; white-space: nowrap;">Change
                                                Email</button>

                                        </div>

                                        <label
                                            style="font-size: 13px; color: #666; margin-bottom: 5px;">Phone
                                            Number</label>
                                        <input type="text" name="phone" id="editPhone"
                                            class="form-control mb-3"
                                            value="<%= user && user.phone ? user.phone : '' %>"
                                            style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none;">

                                        <% if (!user.googleId) { %>
                                            <hr class="mt-4 mb-4">

                                            <div>
                                                <h5 class="mb-3"
                                                    style="font-size: 15px; font-weight: 600;">Password
                                                    Change</h5>

                                                <label
                                                    style="font-size: 13px; color: #666; margin-bottom: 5px;">Current
                                                    Password
                                                    (leave blank to leave unchanged)</label>
                                                <input type="password" name="currentPassword"
                                                    id="editCurrentPassword" class="form-control mb-3"
                                                    style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none;">

                                                <label
                                                    style="font-size: 13px; color: #666; margin-bottom: 5px;">New
                                                    Password (leave
                                                    blank to leave unchanged)</label>
                                                <input type="password" name="newPassword"
                                                    id="editNewPassword" class="form-control mb-3"
                                                    style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none;">

                                                <label
                                                    style="font-size: 13px; color: #666; margin-bottom: 5px;">Confirm
                                                    New
                                                    Password</label>
                                                <input type="password" name="confirmPassword"
                                                    id="editConfirmPassword" class="form-control mb-4"
                                                    style="background: #fafafa; border: 1px solid #ebebeb; border-radius: 8px; padding: 12px 15px; box-shadow: none;">

                                            </div>
                                            <% } %>

                                                <div class="text-center mt-2">

                                                    <button type="submit" class="btn btn-dark"
                                                        style="padding: 12px 40px; font-weight: 500; border-radius: 8px;">
                                                        <span>SAVE CHANGES</span>
                                                    </button>
                                                </div>
                                    </form>
                                </div>
                            </div>
                        </div><!-- End .col-md-8 -->
                    </div><!-- End .row -->
                </div><!-- End .container -->
            </div><!-- End .dashboard -->
        </div><!-- End .page-content -->
    </main>

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        .ce-otp-wrap {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin: 18px 0 10px;
        }

        .ce-otp-digit {
            width: 54px;
            height: 56px;
            text-align: center;
            font-size: 22px;
            border: 2px solid #ddd;
            border-radius: 8px;
            outline: none;
            background: #f7f7f7;
            transition: border-color .2s;
        }

        .ce-otp-digit:focus {
            border-color: #c8a165;
            background: #fff;
        }

        .ce-timer {
            font-size: 14px;
            color: #666;
            margin-bottom: 6px;
        }

        .ce-timer span {
            font-weight: 700;
            color: #c8a165;
        }

        .ce-resend {
            font-size: 13px;
        }

        .ce-resend a {
            color: #c8a165;
            text-decoration: none;
            font-weight: 500;
        }

        .ce-resend a.disabled {
            color: #aaa;
            pointer-events: none;
        }

        .swal2-popup {
            border-radius: 16px !important;
        }

        .swal2-confirm {
            background: #333 !important;
            border-radius: 8px !important;
        }

        .swal2-cancel {
            border-radius: 8px !important;
        }

        .swal2-input {
            border-radius: 8px !important;
            border: 1px solid #ddd !important;
            box-shadow: none !important;
            font-size: 14px !important;
        }
    </style>

    <script>
        // ── Profile form submit ───────────────────────────────────────────────
        document.getElementById('accountDetailsForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const formData = {
                name: document.getElementById('editName').value,
                phone: document.getElementById('editPhone').value,
                currentPassword: document.getElementById('editCurrentPassword')?.value || "",
                newPassword: document.getElementById('editNewPassword')?.value || "",
                confirmPassword: document.getElementById('editConfirmPassword')?.value || ""
            };
            try {
                const response = await fetch('/updateProfile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                const result = await response.json();
                if (result.success) {
                    Swal.fire('Success', result.message, 'success').then(() => { window.location.href = '/profile'; });
                } else {
                    Swal.fire('Error', result.message, 'error');
                }
            } catch (err) {
                Swal.fire('Error', 'An error occurred during profile update.', 'error');
            }
        });

        // ── Change Email ──────────────────────────────────────────────────────
        document.getElementById('changeEmailBtn').addEventListener('click', showStep1);

        // STEP 1 — collect new email + current password
        function showStep1() {
            Swal.fire({
                title: '<span style="font-size:18px;font-weight:600;">Change Email Address</span>',
                html: `
                <p style="color:#888;font-size:13px;margin-bottom:20px;">Enter your new email and current password to continue.</p>
                <label style="display:block;text-align:left;font-size:12px;color:#888;margin-bottom:4px;">New Email Address</label>
                <input id="ce-newEmail" type="email" class="swal2-input" placeholder="new@example.com"
                       style="margin-bottom:14px;">
                <label style="display:block;text-align:left;font-size:12px;color:#888;margin-bottom:4px;">Current Password</label>
                <input id="ce-password" type="password" class="swal2-input" placeholder="Your current password">
            `,
                showCancelButton: true,
                confirmButtonText: 'Send OTP &rarr;',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#333',
                focusConfirm: false,
                showLoaderOnConfirm: true,
                preConfirm: async () => {
                    const newEmail = document.getElementById('ce-newEmail').value.trim();
                    const password = document.getElementById('ce-password').value;
                    if (!newEmail || !password) {
                        Swal.showValidationMessage('Please fill in both fields');
                        return false;
                    }
                    try {
                        const res = await fetch('/change-email/request', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ newEmail, currentPassword: password })
                        });
                        const data = await res.json();
                        if (!data.success) { Swal.showValidationMessage(data.message); return false; }
                        return { newEmail };
                    } catch (err) {
                        Swal.showValidationMessage('Network error. Please try again.');
                        return false;
                    }
                }
            }).then(result => {
                if (result.isConfirmed && result.value) {
                    showStep2(result.value.newEmail);
                }
            });
        }

        // STEP 2 — OTP verification
        function showStep2(newEmail) {
            let timeLeft = 60;
            let timerInterval;

            Swal.fire({
                title: '<span style="font-size:18px;font-weight:600;">OTP Verification</span>',
                html: `
                <p style="color:#888;font-size:13px;margin-bottom:2px;">We've sent a 4-digit OTP to</p>
                <p style="font-weight:600;color:#333;font-size:14px;margin-bottom:18px;">${newEmail}</p>
                <div class="ce-otp-wrap">
                    <input type="text" maxlength="1" class="ce-otp-digit" id="ce-d1" inputmode="numeric">
                    <input type="text" maxlength="1" class="ce-otp-digit" id="ce-d2" inputmode="numeric">
                    <input type="text" maxlength="1" class="ce-otp-digit" id="ce-d3" inputmode="numeric">
                    <input type="text" maxlength="1" class="ce-otp-digit" id="ce-d4" inputmode="numeric">
                </div>
                <p class="ce-timer">Time remaining: <span id="ce-timer">01:00</span></p>
                <p class="ce-resend">Didn't receive it? <a href="#" id="ce-resendLink" class="disabled">Resend OTP</a></p>
            `,
                showCancelButton: true,
                confirmButtonText: 'Verify Email',
                cancelButtonText: '&#8592; Back',
                confirmButtonColor: '#333',
                focusConfirm: false,
                showLoaderOnConfirm: true,
                didOpen: () => {
                    // Auto-focus & tab through OTP digits
                    const digits = document.querySelectorAll('.ce-otp-digit');
                    digits.forEach((input, idx) => {
                        input.addEventListener('input', e => {
                            e.target.value = e.target.value.replace(/\D/g, '');
                            if (e.target.value && idx < digits.length - 1) digits[idx + 1].focus();
                        });
                        input.addEventListener('keydown', e => {
                            if (e.key === 'Backspace' && !input.value && idx > 0) digits[idx - 1].focus();
                        });
                    });
                    digits[0].focus();

                    // Countdown timer
                    function tick() {
                        const display = document.getElementById('ce-timer');
                        if (!display) return;
                        const m = Math.floor(timeLeft / 60);
                        const s = timeLeft % 60;
                        display.textContent = `${m}:${s < 10 ? '0' + s : s}`;
                        if (timeLeft <= 0) {
                            clearInterval(timerInterval);
                            display.textContent = 'Expired';
                            const link = document.getElementById('ce-resendLink');
                            if (link) link.classList.remove('disabled');
                        }
                        timeLeft--;
                    }
                    tick();
                    timerInterval = setInterval(tick, 1000);

                    // Resend OTP
                    document.getElementById('ce-resendLink').addEventListener('click', async function (e) {
                        e.preventDefault();
                        if (this.classList.contains('disabled')) return;
                        this.classList.add('disabled');
                        try {
                            const res = await fetch('/change-email/resend-otp', { method: 'POST' });
                            const data = await res.json();
                            if (data.success) {
                                clearInterval(timerInterval);
                                timeLeft = 60;
                                tick();
                                timerInterval = setInterval(tick, 1000);
                                // Brief confirmation flash
                                const vmEl = document.querySelector('.swal2-validation-message');
                                if (vmEl) { vmEl.style.display = 'none'; }
                                Swal.showValidationMessage('✓ New OTP sent!');
                                setTimeout(() => {
                                    const vm = document.querySelector('.swal2-validation-message');
                                    if (vm) vm.style.display = 'none';
                                }, 2500);
                            } else {
                                Swal.showValidationMessage(data.message || 'Failed to resend OTP');
                            }
                        } catch (err) {
                            Swal.showValidationMessage('Network error. Please try again.');
                        }
                    });
                },
                willClose: () => clearInterval(timerInterval),
                preConfirm: async () => {
                    const digits = document.querySelectorAll('.ce-otp-digit');
                    const otp = Array.from(digits).map(d => d.value).join('');
                    if (otp.length !== 4) {
                        Swal.showValidationMessage('Please enter all 4 digits');
                        return false;
                    }
                    try {
                        const res = await fetch('/change-email/verify-otp', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ otp })
                        });
                        const data = await res.json();
                        if (!data.success) { Swal.showValidationMessage(data.message); return false; }
                        return true;
                    } catch (err) {
                        Swal.showValidationMessage('Network error. Please try again.');
                        return false;
                    }
                }
            }).then(result => {
                if (result.isConfirmed) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Email Updated!',
                        text: 'Your email address has been changed successfully.',
                        showConfirmButton: false,
                        timer: 2000
                    }).then(() => window.location.reload());
                } else if (result.dismiss === Swal.DismissReason.cancel) {
                    showStep1(); // Back to Step 1
                }
            });
        }
    </script>

    <%- include("../../views/partials/user/footer.ejs") %>

        </div><!-- End .page-wrapper -->

        <button id="scroll-top" title="Back to Top">
            <i class="icon-arrow-up"></i>
        </button>

        <script src="assets/js/jquery.min.js"></script>
        <script src="assets/js/bootstrap.bundle.min.js"></script>
        <script src="assets/js/jquery.hoverIntent.min.js"></script>
        <script src="assets/js/jquery.waypoints.min.js"></script>
        <script src="assets/js/superfish.min.js"></script>
        <script src="assets/js/owl.carousel.min.js"></script>
        <script src="assets/js/jquery.magnific-popup.min.js"></script>
        <!-- Main JS File -->
        <script src="assets/js/main.js"></script>
        <%-include("../../views/partials/user/mobileView.ejs")%>