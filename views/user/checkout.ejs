<%- include("../../views/partials/user/header.ejs") %>

<main class="main">
    <div class="page-header text-center" style="background-image: url('/assets/images/page-header-bg.jpg')">
        <div class="container">
            <h1 class="page-title">Checkout<span>Shop</span></h1>
        </div>
    </div>

    <nav aria-label="breadcrumb" class="breadcrumb-nav">
        <div class="container">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                <li class="breadcrumb-item"><a href="/cart">Cart</a></li>
                <li class="breadcrumb-item active" aria-current="page">Checkout</li>
            </ol>
        </div>
    </nav>

    <div class="page-content">
        <div class="checkout">
            <div class="container">

                <div class="row">
                    <!-- ══════════════════════════════════════════════════════════
                         LEFT COLUMN — Address Selection + Order Items
                    ═══════════════════════════════════════════════════════════ -->
                    <div class="col-lg-9">

                        <!-- ── SECTION 1: Delivery Address ── -->
                        <h2 class="checkout-title">Select Delivery Address</h2>

                        <% if (addresses && addresses.length > 0) { %>
                            <div class="row" id="address-cards-container">
                                <% addresses.forEach((addr, index) => { %>
                                    <div class="col-md-6 mb-3">
                                        <div class="checkout-address-card <%= addr.isDefault ? 'selected' : '' %>"
                                             id="addr-card-<%= addr._id %>"
                                             onclick="selectAddress('<%= addr._id %>', this)">

                                            <div class="address-card-header">
                                                <div class="d-flex align-items-center">
                                                    <input type="radio"
                                                           name="selectedAddress"
                                                           id="addr-radio-<%= addr._id %>"
                                                           value="<%= addr._id %>"
                                                           class="address-radio mr-2"
                                                           <%= addr.isDefault ? 'checked' : '' %>>
                                                    <span class="address-type-badge"><%= addr.addressType || "Home" %></span>
                                                    <% if (addr.isDefault) { %>
                                                        <span class="default-badge ml-2">Default</span>
                                                    <% } %>
                                                </div>
                                                <a href="/address"
                                                   class="address-edit-btn"
                                                   onclick="event.stopPropagation()">
                                                    <i class="icon-edit"></i> Edit
                                                </a>
                                            </div>

                                            <div class="address-card-body">
                                                <p class="address-name"><%= addr.name %></p>
                                                <p class="address-line"><%= addr.landMark %></p>
                                                <p class="address-line"><%= addr.city %>, <%= addr.state %> — <%= addr.pincode %></p>
                                                <p class="address-phone"><i class="icon-phone"></i> <%= addr.phone %></p>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>

                            <div class="mb-4">
                                <a href="/address" class="btn btn-outline-dark-2 btn-sm">
                                    <i class="icon-plus"></i> Add New Address
                                </a>
                            </div>

                        <% } else { %>
                            <!-- No addresses saved -->
                            <div class="alert alert-warning mb-4" style="font-size: 1.4rem;">
                                <i class="icon-warning"></i>
                                You have no saved addresses.
                                <a href="/address" class="font-weight-bold">Add an address</a> to continue.
                            </div>
                        <% } %>

                        <!-- ── SECTION 2: Order Items ── -->
                        <h2 class="checkout-title mt-4">Order Summary</h2>

                        <div class="checkout-items-list">
                            <% cartItems.forEach(item => { %>
                                <div class="checkout-item-row">
                                    <div class="checkout-item-image">
                                        <% if (item.productImage) { %>
                                            <img src="/uploads/productImages/<%= item.productImage %>"
                                                 alt="<%= item.productName %>">
                                        <% } else { %>
                                            <img src="/assets/images/products/product-4.jpg"
                                                 alt="No image">
                                        <% } %>
                                    </div>
                                    <div class="checkout-item-details">
                                        <h4 class="checkout-item-name"><%= item.productName %></h4>
                                        <div class="checkout-item-meta">
                                            <span class="meta-badge">Size: <%= item.size %></span>
                                            <% if (item.color) { %>
                                                <span class="meta-badge">Color: <%= item.color %></span>
                                            <% } %>
                                            <span class="meta-badge">Qty: <%= item.quantity %></span>
                                        </div>
                                        <div class="checkout-item-pricing">
                                            <% if (item.regularPrice > item.price) { %>
                                                <span class="checkout-item-original">₹<%= item.regularPrice %></span>
                                            <% } %>
                                            <span class="checkout-item-price">₹<%= item.price %></span>
                                            <span class="checkout-item-separator">×</span>
                                            <span class="checkout-item-qty"><%= item.quantity %></span>
                                            <span class="checkout-item-separator">=</span>
                                            <span class="checkout-item-total">₹<%= item.itemTotal %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>

                    </div><!-- End .col-lg-9 -->

                    <!-- ══════════════════════════════════════════════════════════
                         RIGHT COLUMN — Price Summary + Payment + Place Order
                    ═══════════════════════════════════════════════════════════ -->
                    <aside class="col-lg-3">
                        <div class="summary">
                            <!-- ── SECTION: Coupons ── -->
                            <div class="checkout-coupon-section mb-4">
                                <h5 class="checkout-payment-title">Available Coupons</h5>
                                
                                <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                                    <div class="applied-coupon-display p-3 bg-light border rounded d-flex align-items-center justify-content-between">
                                        <div>
                                            <span class="text-brand-orange font-weight-bold"><%= appliedCoupon.code %></span>
                                            <p class="mb-0 small text-muted">Applied Successfully</p>
                                        </div>
                                        <button class="btn btn-sm btn-outline-danger" onclick="removeCoupon()">Remove</button>
                                    </div>
                                <% } else { %>
                                    <div class="d-flex align-items-center" style="gap: 10px;">
                                        <select id="available-coupons-dropdown" class="form-control form-control-sm" style="height: 38px; font-size: 1.2rem;">
                                            <option value="">-- Select a Coupon --</option>
                                            <% if (typeof availableCoupons !== 'undefined' && availableCoupons.length > 0) { %>
                                                <% availableCoupons.forEach(coupon => { %>
                                                    <option value="<%= coupon.code %>">
                                                        <%= coupon.code %> (<%= coupon.discountType === 'percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue %> Off)
                                                    </option>
                                                <% }) %>
                                            <% } else { %>
                                                <option disabled>No coupons available</option>
                                            <% } %>
                                        </select>
                                        <button class="btn btn-primary" onclick="applySelectedCoupon()" style="min-width: 70px; height: 38px; font-size: 1.2rem; margin-bottom: 14px;">Apply</button>
                                    </div>
                                <% } %>
                            </div>

                            <h3 class="summary-title">Price Details</h3>

                            <table class="table table-summary">
                                <tbody>
                                    <tr class="summary-subtotal">
                                        <td>Price (<%= itemsCount %> item<%= itemsCount > 1 ? 's' : '' %>):</td>
                                        <td>₹<%= subtotal %></td>
                                    </tr>

                                    <% if (discount > 0) { %>
                                        <tr>
                                            <td class="text-success">
                                                Coupon Discount 
                                                <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                                                    <span class="font-weight-bold" style="color: #d38c64;">(<%= appliedCoupon.code %>)</span>
                                                <% } %>:
                                            </td>
                                            <td class="text-success">− ₹<%= discount %></td>
                                        </tr>
                                    <% } %>

                                    <tr>
                                        <td>Shipping:</td>
                                        <td class="text-success">
                                            <% if (shippingCharge === 0) { %>
                                                Free
                                            <% } else { %>
                                                ₹<%= shippingCharge %>
                                            <% } %>
                                        </td>
                                    </tr>

                                    <tr class="summary-total">
                                        <td>Total Amount:</td>
                                        <td>₹<%= finalAmount %></td>
                                    </tr>
                                </tbody>
                            </table>

                            <% if (discount > 0) { %>
                                <div class="checkout-savings-banner">
                                    🎉 You save ₹<%= discount %> on this order!
                                </div>
                            <% } %>

                            <!-- ── Payment Method ── -->
                            <div class="checkout-payment-section mt-3">
                                <h5 class="checkout-payment-title">Payment Method</h5>
                                
                                <!-- ── Wallet Payment (Inside Payment Section) ── -->
                                <div class="checkout-wallet-section mb-3 p-3 bg-white border rounded">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-0"><i class="icon-wallet mr-2"></i>RARO Wallet</h6>
                                            <p class="text-muted small mb-0">Available Balance: ₹<%= walletBalance || 0 %></p>
                                        </div>
                                        <div class="custom-control custom-checkbox">
                                            <input type="checkbox" class="custom-control-input" id="use-wallet-cb" 
                                                   onchange="toggleWalletUsage()" 
                                                   <%= (walletBalance && walletBalance > 0) ? '' : 'disabled' %>>
                                            <label class="custom-control-label" for="use-wallet-cb" style="cursor: <%= (walletBalance && walletBalance > 0) ? 'pointer' : 'not-allowed' %>">Use Wallet</label>
                                        </div>
                                    </div>
                                    <% if (!walletBalance || walletBalance <= 0) { %>
                                        <div class="mt-2 small text-muted">
                                            <i class="icon-info-circle mr-1"></i> Your wallet is empty.
                                        </div>
                                    <% } %>
                                    <div id="wallet-usage-info" class="mt-2 small text-brand-orange" style="display: none;">
                                        − ₹<span id="applied-wallet-amount">0</span> will be deducted from your wallet.
                                    </div>
                                </div>
                                
                                <div class="checkout-payment-card selected-payment mb-2" onclick="selectPayment('Cash on Delivery', this)">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="cod-radio"
                                               value="Cash on Delivery" checked class="mr-2 payment-radio">
                                        <label for="cod-radio" class="mb-0" style="cursor: pointer;">
                                            <i class="icon-money" style="font-size: 1.8rem; margin-right: 8px;"></i>
                                            Cash on Delivery
                                        </label>
                                    </div>
                                    <p class="cod-note">Pay when your order arrives at your doorstep.</p>
                                </div>

                                <div class="checkout-payment-card" onclick="selectPayment('Razorpay', this)">
                                    <div class="d-flex align-items-center">
                                        <input type="radio" name="paymentMethod" id="razorpay-radio"
                                               value="Razorpay" class="mr-2 payment-radio">
                                        <label for="razorpay-radio" class="mb-0" style="cursor: pointer;">
                                            <i class="icon-credit-card" style="font-size: 1.8rem; margin-right: 8px;"></i>
                                            Online Payment (Razorpay)
                                        </label>
                                    </div>
                                    <p class="cod-note">Pay securely via Credit/Debit Card, UPI, or Netbanking.</p>
                                </div>
                            </div>

                            <!-- ── Place Order Button ── -->
                            <% if (addresses && addresses.length > 0) { %>
                                <button id="place-order-btn"
                                        class="btn btn-outline-primary-2 btn-order btn-block mt-3"
                                        onclick="submitOrder()">
                                    <span class="btn-text">Place Order</span>
                                    <span class="btn-hover-text">Confirm & Order</span>
                                </button>
                            <% } else { %>
                                <button class="btn btn-outline-primary-2 btn-order btn-block mt-3 disabled"
                                        style="pointer-events: none; opacity: 0.6;" disabled>
                                    Add Address to Continue
                                </button>
                            <% } %>

                            <a href="/cart" class="btn btn-outline-dark-2 btn-block mt-2">
                                <span>Back to Cart</span>
                                <i class="icon-long-arrow-left"></i>
                            </a>
                        </div>
                    </aside><!-- End aside.col-lg-3 -->

                </div><!-- End .row -->
            </div><!-- End .container -->
        </div><!-- End .checkout -->
    </div><!-- End .page-content -->
</main><!-- End .main -->

<button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>

<!-- ══════════════════════════════════════════════════════════════════════════
     Checkout Page Custom Styles
═══════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ── Address Cards ─────────────────────────────────────────────────────── */
    .checkout-address-card {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 16px;
        cursor: pointer;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
        background: #fff;
        height: 100%;
        user-select: none;
    }
    .checkout-address-card:hover {
        border-color: #c96;
        box-shadow: 0 4px 12px rgba(204, 153, 102, 0.15);
        transform: translateY(-2px);
    }
    .checkout-address-card.selected {
        border-color: #c96;
        box-shadow: 0 4px 16px rgba(204, 153, 102, 0.25);
        background: #fffaf5;
    }
    .address-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 10px;
    }
    .address-type-badge {
        display: inline-block;
        background: #f5f5f5;
        color: #555;
        font-size: 1.1rem;
        font-weight: 600;
        padding: 2px 10px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .default-badge {
        display: inline-block;
        background: #c96;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
    }
    .address-edit-btn {
        font-size: 1.2rem;
        color: #c96;
        text-decoration: none;
        transition: color 0.2s;
    }
    .address-edit-btn:hover { color: #a07850; }
    .address-card-body { font-size: 1.3rem; color: #444; line-height: 1.6; }
    .address-name { font-weight: 700; font-size: 1.4rem; color: #222; margin-bottom: 2px; }
    .address-line { margin-bottom: 2px; }
    .address-phone { color: #666; margin-top: 4px; }
    .address-radio { accent-color: #c96; width: 16px; height: 16px; cursor: pointer; }

    /* ── Order Items ───────────────────────────────────────────────────────── */
    .checkout-items-list {
        border: 1px solid #e9ecef;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 20px;
    }
    .checkout-item-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 16px;
        border-bottom: 1px solid #f0f0f0;
        background: #fff;
        transition: background 0.15s;
    }
    .checkout-item-row:last-child { border-bottom: none; }
    .checkout-item-row:hover { background: #fafafa; }
    .checkout-item-image {
        flex-shrink: 0;
        width: 70px;
        height: 70px;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid #eee;
    }
    .checkout-item-image img { width: 100%; height: 100%; object-fit: cover; }
    .checkout-item-details { flex: 1; }
    .checkout-item-name {
        font-size: 1.4rem;
        font-weight: 600;
        color: #333;
        margin-bottom: 6px;
    }
    .checkout-item-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 8px; }
    .meta-badge {
        font-size: 1.1rem;
        background: #f5f5f5;
        color: #666;
        padding: 2px 10px;
        border-radius: 20px;
        font-weight: 500;
    }
    .checkout-item-pricing {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 1.3rem;
    }
    .checkout-item-original {
        text-decoration: line-through;
        color: #aaa;
        font-size: 1.2rem;
    }
    .checkout-item-price { color: #c96; font-weight: 700; }
    .checkout-item-separator { color: #aaa; }
    .checkout-item-qty { color: #555; }
    .checkout-item-total { font-weight: 700; color: #333; font-size: 1.4rem; }

    /* ── Price Summary ─────────────────────────────────────────────────────── */
    .summary { position: sticky; top: 20px; }
    .checkout-savings-banner {
        background: linear-gradient(135deg, #e8f5e9, #f1f8e9);
        color: #2e7d32;
        padding: 10px 14px;
        border-radius: 8px;
        font-size: 1.3rem;
        font-weight: 600;
        border-left: 4px solid #43a047;
        margin-top: 6px;
    }

    /* ── Payment Section ───────────────────────────────────────────────────── */
    .checkout-payment-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 10px;
    }
    .checkout-payment-card {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 14px 16px;
        background: #fff;
        transition: border-color 0.2s;
    }
    .checkout-payment-card.selected-payment {
        border-color: #c96;
        background: #fffaf5;
    }
    .checkout-payment-card label {
        font-size: 1.4rem;
        font-weight: 600;
        color: #333;
        cursor: pointer;
    }
    .cod-note {
        font-size: 1.2rem;
        color: #888;
        margin: 6px 0 0 26px;
    }

    /* ── Place Order Button states ─────────────────────────────────────────── */
    #place-order-btn:disabled,
    #place-order-btn.processing {
        opacity: 0.65;
        cursor: not-allowed;
        pointer-events: none;
    }
</style>

<script src="/assets/js/jquery.min.js"></script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/jquery.hoverIntent.min.js"></script>
<script src="/assets/js/jquery.waypoints.min.js"></script>
<script src="/assets/js/superfish.min.js"></script>
<script src="/assets/js/owl.carousel.min.js"></script>
<script src="/assets/js/jquery.magnific-popup.min.js"></script>
<script src="/assets/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
    // Track which address is selected
    let selectedAddressId = null;

    // Auto-select the default (or first) address on page load
    document.addEventListener('DOMContentLoaded', function () {
        const checkedRadio = document.querySelector('.address-radio:checked');
        if (checkedRadio) {
            selectedAddressId = checkedRadio.value;
        }
    });

    function selectAddress(addressId, cardEl) {
        // Deselect all cards
        document.querySelectorAll('.checkout-address-card').forEach(c => c.classList.remove('selected'));
        // Uncheck all radios
        document.querySelectorAll('.address-radio').forEach(r => r.checked = false);

        // Select the clicked card
        cardEl.classList.add('selected');
        const radio = document.getElementById('addr-radio-' + addressId);
        if (radio) radio.checked = true;

        selectedAddressId = addressId;
    }

    let selectedPaymentMethod = 'Cash on Delivery';
    let walletBalance = <%= walletBalance || 0 %>;
    let finalAmount = <%= finalAmount %>;
    let appliedWalletAmount = 0;

    function toggleWalletUsage() {
        const checkbox = document.getElementById('use-wallet-cb');
        const infoDiv = document.getElementById('wallet-usage-info');
        const amountSpan = document.getElementById('applied-wallet-amount');
        const paymentCards = document.querySelectorAll('.checkout-payment-card');
        
        if (checkbox && checkbox.checked) {
            appliedWalletAmount = Math.min(walletBalance, finalAmount);
            amountSpan.textContent = appliedWalletAmount;
            infoDiv.style.display = 'block';

            // If wallet covers full amount, disable other options
            if (Math.round(appliedWalletAmount) >= Math.round(finalAmount)) {
                paymentCards.forEach(card => {
                    card.style.opacity = '0.5';
                    card.style.pointerEvents = 'none';
                    const radio = card.querySelector('.payment-radio');
                    if (radio) {
                        radio.checked = false;
                        radio.disabled = true;
                    }
                    card.classList.remove('selected-payment');
                });
                selectedPaymentMethod = 'Wallet';
            } else {
                paymentCards.forEach(card => {
                    card.style.opacity = '1';
                    card.style.pointerEvents = 'auto';
                    const radio = card.querySelector('.payment-radio');
                    if (radio) radio.disabled = false;
                });
                // If it was wallet but now partial, select COD by default
                if (selectedPaymentMethod === 'Wallet') {
                    const codCard = document.querySelector('.checkout-payment-card');
                    if (codCard) selectPayment('Cash on Delivery', codCard);
                }
            }
        } else {
            appliedWalletAmount = 0;
            infoDiv.style.display = 'none';
            
            // Re-enable other options
            paymentCards.forEach(card => {
                card.style.opacity = '1';
                card.style.pointerEvents = 'auto';
                const radio = card.querySelector('.payment-radio');
                if (radio) radio.disabled = false;
            });
            // Reset to default payment method if it was Wallet
            if (selectedPaymentMethod === 'Wallet') {
                const codCard = document.querySelector('.checkout-payment-card');
                if (codCard) selectPayment('Cash on Delivery', codCard);
            }
        }
    }

    function selectPayment(method, cardEl) {
        document.querySelectorAll('.checkout-payment-card').forEach(c => c.classList.remove('selected-payment'));
        cardEl.classList.add('selected-payment');
        const radio = cardEl.querySelector('.payment-radio');
        if (radio) radio.checked = true;
        selectedPaymentMethod = method;
    }

    async function placeActualOrder(paymentDetails = {}) {
        const btn = document.getElementById('place-order-btn');
        try {
            const bodyData = { 
                addressId: selectedAddressId,
                paymentMethod: selectedPaymentMethod,
                walletAmountUsed: appliedWalletAmount,
                ...paymentDetails
            };

            const response = await fetch('/checkout/place-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bodyData)
            });

            const data = await response.json();

            if (response.ok && data.success) {
                if (paymentDetails.paymentStatus === 'Failed') {
                    window.location.href = '/payment-failed/' + data.orderId;
                } else {
                    window.location.href = '/order-success/' + data.orderId;
                }
            } else {
                throw new Error(data.message || 'Could not place order.');
            }
        } catch (error) {
            console.error('Order placement error:', error);
            Swal.fire({
                icon: 'error',
                title: 'Order Failed',
                text: error.message || 'Something went wrong. Please check your connection and try again.'
            }).then(() => {
                btn.disabled = false;
                btn.classList.remove('processing');
                btn.querySelector('.btn-text').textContent = 'Place Order';
            });
        }
    }

    async function submitOrder() {
        if (!selectedAddressId) {
            Swal.fire({
                icon: 'warning',
                title: 'No Address Selected',
                text: 'Please select a delivery address before placing your order.'
            });
            return;
        }

        const btn = document.getElementById('place-order-btn');
        btn.disabled = true;
        btn.classList.add('processing');
        btn.querySelector('.btn-text').textContent = 'Processing...';

        // 0. Full Wallet Payment Case
        // Use a small epsilon or round to avoid floating point precision issues
        if (Math.round(appliedWalletAmount) >= Math.round(finalAmount)) {
            selectedPaymentMethod = 'Wallet';
            return placeActualOrder({ paymentStatus: 'Paid' });
        }

        if (selectedPaymentMethod === 'Razorpay') {
            try {
                // 1. Create Razorpay Order
                const createRes = await fetch('/checkout/create-razorpay-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ walletAmountUsed: appliedWalletAmount })
                });
                
                const createData = await createRes.json();
                if (!createRes.ok || !createData.success) {
                    throw new Error(createData.message || "Failed to initiate payment");
                }

                // 2. Open Razorpay Modal
                const options = {
                    key: "<%= razorpayKeyId %>", 
                    amount: createData.razorpayOrder.amount,
                    currency: "INR",
                    name: "RARO Shop",
                    description: "Order Payment",
                    order_id: createData.razorpayOrder.id,
                    handler: function (response) {
                        // Payment Successful
                        placeActualOrder({
                            razorpayPaymentId: response.razorpay_payment_id,
                            razorpayOrderId: response.razorpay_order_id,
                            razorpaySignature: response.razorpay_signature
                        });
                    },
                    prefill: {
                        name: "<%= user.name %>",
                        email: "<%= user.email %>",
                        contact: "<%= user.phone || '' %>"
                    },
                    theme: {
                        color: "#cc9966"
                    },
                    modal: {
                        ondismiss: function() {
                            // User closed the modal
                            btn.disabled = false;
                            btn.classList.remove('processing');
                            btn.querySelector('.btn-text').textContent = 'Place Order';
                        }
                    }
                };

                const rzp = new Razorpay(options);
                rzp.on('payment.failed', function (response){
                    // Create a Failed order
                    placeActualOrder({
                        paymentStatus: 'Failed',
                        razorpayPaymentId: response.error.metadata ? response.error.metadata.payment_id : null,
                        razorpayOrderId: response.error.metadata ? response.error.metadata.order_id : createData.razorpayOrder.id
                    });
                });
                rzp.open();

            } catch (error) {
                console.error("Razorpay error:", error);
                Swal.fire({
                    icon: 'error',
                    title: 'Payment Error',
                    text: error.message || 'Could not initiate Razorpay. Please try again later.'
                });
                btn.disabled = false;
                btn.classList.remove('processing');
                btn.querySelector('.btn-text').textContent = 'Place Order';
            }
        } else {
            // Cash on Delivery
            placeActualOrder();
        }
    }

    async function applySelectedCoupon() {
        const code = $('#available-coupons-dropdown').val();
        if (!code) {
            Swal.fire({ icon: 'warning', title: 'No Coupon Selected', text: 'Please select a coupon from the dropdown.' });
            return;
        }
        await submitCoupon(code);
    }

    async function submitCoupon(code) {
        try {
            const res = await fetch('/cart/apply-coupon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code })
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Applied!',
                    text: data.message,
                    showConfirmButton: false,
                    timer: 1500
                }).then(() => window.location.reload());
            } else {
                Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
            }
        } catch (err) {
            console.error("Coupon apply error:", err);
            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.' });
        }
    }

    async function removeCoupon() {
        try {
            const res = await fetch('/cart/remove-coupon', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Removed!',
                    text: data.message,
                    showConfirmButton: false,
                    timer: 1500
                }).then(() => window.location.reload());
            } else {
                Swal.fire({ icon: 'error', title: 'Failed', text: data.message });
            }
        } catch (err) {
            console.error("Coupon remove error:", err);
            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong.' });
        }
    }
</script>

