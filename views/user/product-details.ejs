<%-include("../../views/partials/user/header.ejs")%>

        <main class="main">
            <nav aria-label="breadcrumb" class="breadcrumb-nav border-0 mb-0">
                <div class="container d-flex align-items-center">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="/">Home</a></li>
                        <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
                        <li class="breadcrumb-item"><a href="/shop?category=<%= product.category._id %>"><%= product.category.name %></a></li>
                        <li class="breadcrumb-item active" aria-current="page"><%= product.productName %></li>
                    </ol>

                    <nav class="product-pager ml-auto" aria-label="Product">
                        <a class="product-pager-link product-pager-prev" href="#" aria-label="Previous" tabindex="-1">
                            <i class="icon-angle-left"></i>
                            <span>Prev</span>
                        </a>

                        <a class="product-pager-link product-pager-next" href="#" aria-label="Next" tabindex="-1">
                            <span>Next</span>
                            <i class="icon-angle-right"></i>
                        </a>
                    </nav><!-- End .pager-nav -->
                </div><!-- End .container -->
            </nav><!-- End .breadcrumb-nav -->

            <div class="page-content">
                <div class="container">
                    <div class="product-details-top">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="product-gallery product-gallery-vertical">
                                    <div class="row">
                                        <figure class="product-main-image">
                                            <img id="product-zoom" src="<%= product.productImage[0] %>" data-zoom-image="<%= product.productImage[0] %>" alt="<%= product.productName %>">

                                            <a href="#" id="btn-product-gallery" class="btn-product-gallery">
                                                <i class="icon-arrows"></i>
                                            </a>
                                        </figure><!-- End .product-main-image -->

                                        <div id="product-zoom-gallery" class="product-image-gallery">
                                            <% product.productImage.forEach((img, index) => { %>
                                                <a class="product-gallery-item <%= index === 0 ? 'active' : '' %>" href="#" data-image="<%= img %>" data-zoom-image="<%= img %>">
                                                    <img src="<%= img %>" alt="<%= product.productName %> view <%= index+1 %>">
                                                </a>
                                            <% }) %>
                                        </div><!-- End .product-image-gallery -->
                                    </div><!-- End .row -->
                                </div><!-- End .product-gallery -->
                            </div><!-- End .col-md-6 -->

                            <div class="col-md-6">
                                <div class="product-details">
                                    <h1 class="product-title"><%= product.productName %></h1><!-- End .product-title -->

                                    <div class="ratings-container">
                                        <div class="ratings">
                                            <div class="ratings-val" style="width: <%= (avgRating / 5) * 100 %>%;"></div><!-- End .ratings-val -->
                                        </div><!-- End .ratings -->
                                        <a class="ratings-text" href="#product-review-link" id="review-link">( <%= reviews.length %> Reviews )</a>
                                    </div><!-- End .rating-container -->

                                    <div class="product-price">
                                        <% if (product.salePrice < product.regularPrice) { %>
                                            <span class="new-price">₹<%= product.salePrice %></span>
                                            <span class="old-price" style="text-decoration: line-through; color: #cccccc; margin-left:10px;">₹<%= product.regularPrice %></span>
                                            <% if (product.productOffer > 0) { %>
                                                <span class="badge badge-success" style="margin-left: 15px; background: #c96; color: white; padding: 5px 10px; border-radius: 4px; font-size: 1.2rem; font-weight: 500;"><%= Math.round((product.productOffer / product.regularPrice) * 100) %>% OFF</span>
                                            <% } %>
                                        <% } else { %>
                                            ₹<%= product.regularPrice %>
                                        <% } %>
                                    </div><!-- End .product-price -->

                                    <div class="product-content">
                                        <p><%= product.description %></p>
                                    </div><!-- End .product-content -->

                                    <div class="details-filter-row details-row-size">
                                        <label for="color">Color:</label>
                                        <div class="select-custom">
                                            <select name="color" id="color" class="form-control" required>
                                                <option value="" selected disabled>Select a color</option>
                                                <% 
                                                const uniqueColors = [...new Set(product.variants.map(v => v.color))];
                                                uniqueColors.forEach(col => { 
                                                %>
                                                    <option value="<%= col %>"><%= col %></option>
                                                <% }); %>
                                            </select>
                                        </div><!-- End .select-custom -->
                                    </div><!-- End .details-filter-row -->

                                    <% 
                                      let totalStock = product.variants.reduce((acc, curr) => acc + curr.stock, 0);
                                    %>

                                    <div class="details-filter-row details-row-size">
                                        <label for="size">Size:</label>
                                        <div class="select-custom">
                                            <select name="size" id="size" class="form-control" disabled>
                                                <option value="" selected disabled>Select a color first</option>
                                            </select>
                                        </div><!-- End .select-custom -->
                                    </div><!-- End .details-filter-row -->

                                    <div id="stock-display" class="mb-2" style="font-size: 1.4rem;">
                                        <!-- Real-time stock status injected here -->
                                    </div>

                                     <div class="details-filter-row details-row-size">
                                         <label for="qty">Qty:</label>
                                         <div class="product-details-quantity">
                                             <div class="input-group input-spinner" style="display: flex; align-items: center; border: 1px solid #dadada; border-radius: 4px; overflow: hidden; max-width: 120px;">
                                                 <div class="input-group-prepend">
                                                     <button style="min-width: 35px; border: none; background: #f9f9f9; cursor: pointer;" class="btn btn-decrement btn-spinner" type="button">
                                                         <i class="icon-minus"></i>
                                                     </button>
                                                 </div>
                                                 <input type="number" id="qty" style="width: 50px; text-align: center; border: none; padding: 5px 0; font-weight: 500;" class="form-control" value="1" min="1" max="1" step="1" readonly required>
                                                 <div class="input-group-append">
                                                     <button style="min-width: 35px; border: none; background: #f9f9f9; cursor: pointer;" class="btn btn-increment btn-spinner" type="button">
                                                         <i class="icon-plus"></i>
                                                     </button>
                                                 </div>
                                             </div>
                                         </div><!-- End .product-details-quantity -->
                                     </div><!-- End .details-filter-row -->

                                    <div class="product-details-action">
                                        <a href="#" id="addToCartBtn" data-product-id="<%= product._id %>" class="btn-product btn-cart"><span>add to cart</span></a>

                                        <div class="details-action-wrapper">
                                            <a href="#" class="btn-product btn-wishlist btn-add-wishlist" data-product-id="<%= product._id %>" title="Wishlist"><span>Add to Wishlist</span></a>
                                        </div><!-- End .details-action-wrapper -->
                                    </div><!-- End .product-details-action -->

                                    <div class="product-details-footer">
                                        <div class="product-cat">
                                            <span>Category:</span>
                                            <a href="/shop?category=<%= product.category._id %>"><%= product.category.name %></a>
                                        </div><!-- End .product-cat -->

                                        <div class="social-icons social-icons-sm">
                                            <span class="social-label">Share:</span>
                                            <a href="#" class="social-icon" title="Facebook" target="_blank"><i class="icon-facebook-f"></i></a>
                                            <a href="#" class="social-icon" title="Twitter" target="_blank"><i class="icon-twitter"></i></a>
                                            <a href="#" class="social-icon" title="Instagram" target="_blank"><i class="icon-instagram"></i></a>
                                            <a href="#" class="social-icon" title="Pinterest" target="_blank"><i class="icon-pinterest"></i></a>
                                        </div>
                                    </div><!-- End .product-details-footer -->
                                </div><!-- End .product-details -->
                            </div><!-- End .col-md-6 -->
                        </div><!-- End .row -->
                    </div><!-- End .product-details-top -->

                    <div class="product-details-tab">
                        <ul class="nav nav-pills justify-content-center" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active" id="product-desc-link" data-toggle="tab" href="#product-desc-tab" role="tab" aria-controls="product-desc-tab" aria-selected="true">Description</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="product-info-link" data-toggle="tab" href="#product-info-tab" role="tab" aria-controls="product-info-tab" aria-selected="false">Additional information</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" id="product-review-link" data-toggle="tab" href="#product-review-tab" role="tab" aria-controls="product-review-tab" aria-selected="false">Reviews (<%= reviews.length %>)</a>
                            </li>
                        </ul>
                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="product-desc-tab" role="tabpanel" aria-labelledby="product-desc-link">
                                <div class="product-desc-content">
                                    <h3>Product Information</h3>
                                    <p><%= product.description %></p>
                                    
                                    <% if (product.highlights && product.highlights.length > 0) { %>
                                        <h3>Highlights</h3>
                                        <ul>
                                            <% product.highlights.forEach(h => { %>
                                                <li><%= h %></li>
                                            <% }) %>
                                        </ul>
                                    <% } %>
                                </div><!-- End .product-desc-content -->
                            </div><!-- .End .tab-pane -->
                            <div class="tab-pane fade" id="product-info-tab" role="tabpanel" aria-labelledby="product-info-link">
                                <div class="product-desc-content">
                                    <h3>Information</h3>
                                    <p style="white-space: pre-wrap;"><%= product.additionalInfo || 'No additional information available for this product.' %></p>
                                </div><!-- End .product-desc-content -->
                            </div><!-- .End .tab-pane -->
                            <div class="tab-pane fade" id="product-review-tab" role="tabpanel" aria-labelledby="product-review-link">
                                <div class="reviews">
                                    <h3>Reviews (<%= reviews.length %>)</h3>
                                    
                                    <% if (reviews.length === 0) { %>
                                        <p>No reviews yet. Be the first to review this product!</p>
                                    <% } else { %>
                                        <% reviews.forEach(review => { %>
                                            <div class="review">
                                                <div class="row no-gutters">
                                                    <div class="col-auto">
                                                        <h4><a href="#"><%= review.user.name %></a></h4>
                                                        <div class="ratings-container">
                                                            <div class="ratings">
                                                                <div class="ratings-val" style="width: <%= (review.rating / 5) * 100 %>%;"></div>
                                                            </div>
                                                        </div>
                                                        <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString() %></span>
                                                    </div>
                                                    <div class="col">
                                                        <div class="review-content">
                                                            <p><%= review.comment %></p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    <% } %>
                                    
                                    <!-- Add Review Form -->
                                    <% if (user) { %>
                                        <div class="reply mt-4">
                                            <div class="heading">
                                                <h3 class="title">Leave A Review</h3>
                                            </div>
                                            <form action="/product/<%= product._id %>/review" method="POST">
                                                <div class="row">
                                                    <div class="col-12">
                                                        <label for="rating">Rating <span class="text-danger">*</span></label>
                                                        <select name="rating" id="rating" class="form-control" required style="max-width: 200px;">
                                                            <option value="" selected disabled>Select Rating</option>
                                                            <option value="5">5 - Excellent</option>
                                                            <option value="4">4 - Good</option>
                                                            <option value="3">3 - Average</option>
                                                            <option value="2">2 - Poor</option>
                                                            <option value="1">1 - Terrible</option>
                                                        </select>
                                                    </div>
                                                    <div class="col-12 mt-2">
                                                        <label for="comment">Your Comment <span class="text-danger">*</span></label>
                                                        <textarea name="comment" id="comment" cols="30" rows="4" class="form-control" required placeholder="Write your review here..."></textarea>
                                                    </div>
                                                </div>
                                                <button type="submit" class="btn btn-outline-primary-2 mt-2">
                                                    <span>SUBMIT REVIEW</span>
                                                    <i class="icon-long-arrow-right"></i>
                                                </button>
                                            </form>
                                        </div>
                                    <% } else { %>
                                        <div class="alert alert-info mt-4">
                                            Please <a href="/signin">sign in</a> to leave a review.
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div><!-- End .tab-content -->
                    </div><!-- End .product-details-tab -->

                    <h2 class="title text-center mb-4">You May Also Like</h2><!-- End .title text-center -->

                    <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl" 
                        data-owl-options='{
                            "nav": false, 
                            "dots": true,
                            "margin": 20,
                            "loop": false,
                            "responsive": {
                                "0": { "items":1 },
                                "480": { "items":2 },
                                "768": { "items":3 },
                                "992": { "items":4 },
                                "1200": { "items":4, "nav": true, "dots": false }
                            }
                        }'>
                        <% if (relatedProducts && relatedProducts.length > 0) { %>
                            <% relatedProducts.forEach(rel => { %>
                                <div class="product product-7 text-center">
                                    <figure class="product-media">
                                        <% if (rel.salePrice < rel.regularPrice) { %>
                                            <span class="product-label label-sale">Sale</span>
                                        <% } %>
                                        <a href="/product/<%= rel._id %>">
                                            <% if (rel.productImage && rel.productImage.length > 0) { %>
                                                <img src="<%= rel.productImage[0] %>" alt="<%= rel.productName %>" class="product-image">
                                            <% } else { %>
                                                <img src="/assets/images/products/product-4.jpg" alt="No image" class="product-image">
                                            <% } %>
                                        </a>

                                        <div class="product-action-vertical">
                                            <a href="#" class="btn-product-icon btn-wishlist btn-expandable"><span>add to wishlist</span></a>
                                        </div>

                                        <div class="product-action">
                                            <a href="/product/<%= rel._id %>" class="btn-product btn-cart"><span>view details</span></a>
                                        </div>
                                    </figure>

                                    <div class="product-body">
                                        <div class="product-cat">
                                            <a href="/shop?category=<%= product.category._id %>"><%= product.category.name %></a>
                                        </div>
                                        <h3 class="product-title"><a href="/product/<%= rel._id %>"><%= rel.productName %></a></h3>
                                        <div class="product-price">
                                            <% if (rel.salePrice < rel.regularPrice) { %>
                                                <span class="new-price">₹<%= rel.salePrice %></span>
                                                <span class="old-price">₹<%= rel.regularPrice %></span>
                                            <% } else { %>
                                                ₹<%= rel.regularPrice %>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center w-100">No related products found.</p>
                        <% } %>
                    </div><!-- End .owl-carousel -->
                </div><!-- End .container -->
            </div><!-- End .page-content -->
        </main><!-- End .main -->

<button id="scroll-top" title="Back to Top">
    <i class="icon-arrow-up"></i>
</button>

<script src="/assets/js/jquery.min.js"></script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/jquery.hoverIntent.min.js"></script>
<script src="/assets/js/jquery.waypoints.min.js"></script>
<script src="/assets/js/superfish.min.js"></script>
<script src="/assets/js/owl.carousel.min.js"></script>
<script src="/assets/js/jquery.magnific-popup.min.js"></script>
<script src="/assets/js/wNumb.js"></script>
<script src="/assets/js/nouislider.min.js"></script>
<script src="/assets/js/jquery.elevateZoom.min.js"></script>
<!-- Main JS File -->
<script src="/assets/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function() {
        if ($.fn.elevateZoom && $('#product-zoom').length > 0) {
            // Re-initialize zoom to ensure it binds correctly after all scripts and images load
            $('#product-zoom').elevateZoom({
                gallery: 'product-zoom-gallery',
                galleryActiveClass: 'active',
                zoomType: "inner",
                cursor: "crosshair",
                zoomWindowFadeIn: 400,
                zoomWindowFadeOut: 400,
                responsive: true
            });
        }

        // Variant Data Injection
        const variants = <%- JSON.stringify(product.variants) %>;

        // --- Dependent Dropdown Logic ---
        $('#color').on('change', function() {
            const selectedColor = $(this).val();
            const $sizeSelect = $('#size');
            const $stockDisplay = $('#stock-display');

            // Reset Size select
            $sizeSelect.prop('disabled', false).html('<option value="" selected disabled>Select a size</option>');
            $stockDisplay.html('');
            
            // Filter sizes for selected color
            const availableSizes = variants.filter(v => v.color === selectedColor);
            
            availableSizes.forEach(v => {
                const stockText = v.stock > 0 ? '' : ' (Out of Stock)';
                const disabled = v.stock > 0 ? '' : 'disabled';
                $sizeSelect.append(`<option value="${v.size}" ${disabled}>${v.size}${stockText}</option>`);
            });

            // If only one size available and it has stock, auto-select it? Maybe not, let user pick.
        });

        // --- Improved Quantity Counter Logic ---
        $('.btn-spinner').on('click', function() {
            const $btn = $(this);
            const $input = $('#qty');
            const currentVal = parseInt($input.val());
            const max = parseInt($input.attr('max'));
            
            if ($btn.hasClass('btn-increment')) {
                if (currentVal < max) {
                    $input.val(currentVal + 1);
                } else if (max > 0) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Limit Reached',
                        text: `Only ${max} units available in stock.`
                    });
                }
            } else if ($btn.hasClass('btn-decrement')) {
                if (currentVal > 1) {
                    $input.val(currentVal - 1);
                }
            }
        });

        $('#size').on('change', function() {
            const selectedColor = $('#color').val();
            const selectedSize = $(this).val();
            const $stockDisplay = $('#stock-display');
            const $qtyInput = $('#qty');
            const $addBtn = $('#addToCartBtn');

            const variant = variants.find(v => v.color === selectedColor && v.size === selectedSize);
            
            if (variant) {
                if (variant.stock > 0) {
                    const stockClass = variant.stock < 5 ? 'text-danger' : 'text-success';
                    const stockText = variant.stock < 5 ? `Only ${variant.stock} units left!` : `${variant.stock} units in stock`;
                    $stockDisplay.html(`<span class="${stockClass} font-weight-bold">${stockText}</span>`);
                    $qtyInput.attr('max', variant.stock).val(1);
                    $addBtn.removeClass('disabled bg-secondary text-white border-0').css({'pointer-events': '', 'opacity': ''}).find('span').text('add to cart');
                } else {
                    $stockDisplay.html('<span class="text-danger font-weight-bold">Out of stock</span>');
                    $qtyInput.attr('max', 0).val(0);
                    $addBtn.addClass('disabled bg-secondary text-white border-0').css({'pointer-events': 'none', 'opacity': '0.6'}).find('span').text('out of stock');
                }
            }
        });

        $('#addToCartBtn').on('click', async function(e) {
            e.preventDefault();
            const productId = $(this).data('product-id');
            const color = $('#color').val();
            const size = $('#size').val();
            const quantity = $('#qty').val();

            if (!color || !size) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Selection Required',
                    text: 'Please select both color and size before adding to cart.'
                });
                return;
            }

            if (quantity < 1) {
                Swal.fire({
                    icon: 'error',
                    title: 'Invalid Quantity',
                    text: 'Quantity must be at least 1'
                });
                return;
            }

            try {
                const response = await fetch('/cart/add', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify({ productId, color, size, quantity })
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    // Spontaneously update cart count in header
                    const $headerCartCount = $('.cart-dropdown a[href="/cart"] .cart-count');
                    if ($headerCartCount.length) {
                        $headerCartCount.text(data.itemsCount);
                        $headerCartCount.css('display', 'flex'); // Ensure it's visible
                    }

                    Swal.fire({
                        icon: 'success',
                        title: 'Added to Cart',
                        text: data.message,
                        showConfirmButton: false,
                        timer: 1500
                    });
                } else {
                    if (response.status === 401 || (typeof data.message === 'string' && data.message.toLowerCase().includes('login'))) {
                        Swal.fire({
                            icon: 'info',
                            title: 'Please Login',
                            text: 'You need to be logged in to add items to your cart.',
                            showCancelButton: true,
                            confirmButtonText: 'Login Now'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/signin';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Notice',
                            text: data.message || 'Failed to add item to cart.'
                        });
                    }
                }
            } catch (error) {
                console.error("Error adding to cart:", error);
                
                // Only show this for actual technical/network errors
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong. Please try again later.'
                });
            }
        });

        $(document).on('click', '.btn-add-wishlist', async function(e) {
            e.preventDefault();
            const productId = $(this).data('product-id');

            try {
                const response = await fetch('/wishlist/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });

                const data = await response.json();

                if (response.ok && data.success) {
                    // Spontaneously update wishlist count in header
                    const $wishlistCount = $('.cart-dropdown a[href="/wishlist"] .cart-count');
                    if ($wishlistCount.length) {
                        $wishlistCount.text(data.wishlistCount);
                        $wishlistCount.css('display', 'flex'); // Ensure it becomes visible
                    }

                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true,
                        didOpen: (toast) => {
                            toast.addEventListener('mouseenter', Swal.stopTimer)
                            toast.addEventListener('mouseleave', Swal.resumeTimer)
                        }
                    });

                    Toast.fire({
                        icon: 'success',
                        title: data.message
                    });
                } else {
                    if (response.status === 401 || (typeof data.message === 'string' && data.message.toLowerCase().includes('login'))) {
                        Swal.fire({
                            icon: 'info',
                            title: 'Please Login',
                            text: 'You need to be logged in to save items to your wishlist.',
                            showCancelButton: true,
                            confirmButtonText: 'Login Now'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/signin';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: data.message || 'Could not add to wishlist.'
                        });
                    }
                }
            } catch (error) {
                console.error("Wishlist error:", error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong.'
                });
            }
        });
    });
</script>

<%-include("../../views/partials/user/mobileView.ejs")%>
<%-include("../../views/partials/user/footer.ejs")%>