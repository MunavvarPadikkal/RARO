<%-include("../../views/partials/user/header.ejs")%>
<link rel="stylesheet" href="assets/css/plugins/nouislider/nouislider.css">
<style>
    .btn-wishlist.in-wishlist::before {
        color: #ef837b !important;
        content: '\f233' !important; /* Filled heart if available, or just color */
    }
    .btn-wishlist.in-wishlist {
        color: #ef837b !important;
    }
</style>

<main class="main">
    <div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
        <div class="container">
            <h1 class="page-title">Shop<span>Products</span></h1>
        </div><!-- End .container -->
    </div><!-- End .page-header -->

    <nav aria-label="breadcrumb" class="breadcrumb-nav mb-2">
        <div class="container">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/shop">Shop</a></li>
            </ol>
        </div><!-- End .container -->
    </nav><!-- End .breadcrumb-nav -->

    <div class="page-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-9">
                    <div class="toolbox">
                        <div class="toolbox-left">
                            <div class="toolbox-info">
                                Showing <span><%= products.length %> of <%= totalProducts %></span> Products
                                <% if(search) { %> for "<%= search %>" <% } %>
                            </div><!-- End .toolbox-info -->
                        </div><!-- End .toolbox-left -->

                        <div class="toolbox-right">
                            <div class="toolbox-sort">
                                <label for="sortby">Sort by:</label>
                                <div class="select-custom">
                                    <select name="sortby" id="sortby" class="form-control" onchange="window.location.href=updateQueryStringParameter(window.location.href, 'sort', this.value)">
                                        <option value="newest" <%= selectedSort === 'newest' ? 'selected' : '' %>>Newest</option>
                                        <option value="price-asc" <%= selectedSort === 'price-asc' ? 'selected' : '' %>>Price (Low to High)</option>
                                        <option value="price-desc" <%= selectedSort === 'price-desc' ? 'selected' : '' %>>Price (High to Low)</option>
                                        <option value="name-asc" <%= selectedSort === 'name-asc' ? 'selected' : '' %>>Name (A-Z)</option>
                                        <option value="name-desc" <%= selectedSort === 'name-desc' ? 'selected' : '' %>>Name (Z-A)</option>
                                    </select>
                                </div>
                            </div><!-- End .toolbox-sort -->
                            <div class="toolbox-layout">
                                <%
                                    let getLayoutUrl = (l) => {
                                        let baseQs = `search=${encodeURIComponent(search || '')}&category=${selectedCategory || ''}&sort=${selectedSort || ''}`;
                                        if (minPrice !== undefined && minPrice !== 0) baseQs += `&minPrice=${minPrice}`;
                                        if (maxPrice !== undefined && maxPrice !== 2000) baseQs += `&maxPrice=${maxPrice}`;
                                        if (selectedSizes && selectedSizes.length > 0) baseQs += `&size=${selectedSizes.join(',')}`;
                                        return `/shop?${baseQs}&layout=${l}&page=1`;
                                    };
                                %>
                                <a href="<%= getLayoutUrl('list') %>" class="btn-layout <%= selectedLayout === 'list' ? 'active' : '' %>">
                                    <svg width="16" height="10">
                                        <rect x="0" y="0" width="4" height="4" />
                                        <rect x="6" y="0" width="10" height="4" />
                                        <rect x="0" y="6" width="4" height="4" />
                                        <rect x="6" y="6" width="10" height="4" />
                                    </svg>
                                </a>

                                <a href="<%= getLayoutUrl('2col') %>" class="btn-layout <%= selectedLayout === '2col' ? 'active' : '' %>">
                                    <svg width="10" height="10">
                                        <rect x="0" y="0" width="4" height="4" />
                                        <rect x="6" y="0" width="4" height="4" />
                                        <rect x="0" y="6" width="4" height="4" />
                                        <rect x="6" y="6" width="4" height="4" />
                                    </svg>
                                </a>

                                <a href="<%= getLayoutUrl('3col') %>" class="btn-layout <%= selectedLayout === '3col' ? 'active' : '' %>">
                                    <svg width="16" height="10">
                                        <rect x="0" y="0" width="4" height="4" />
                                        <rect x="6" y="0" width="4" height="4" />
                                        <rect x="12" y="0" width="4" height="4" />
                                        <rect x="0" y="6" width="4" height="4" />
                                        <rect x="6" y="6" width="4" height="4" />
                                        <rect x="12" y="6" width="4" height="4" />
                                    </svg>
                                </a>

                                <a href="<%= getLayoutUrl('4col') %>" class="btn-layout <%= selectedLayout === '4col' ? 'active' : '' %>">
                                    <svg width="22" height="10">
                                        <rect x="0" y="0" width="4" height="4" />
                                        <rect x="6" y="0" width="4" height="4" />
                                        <rect x="12" y="0" width="4" height="4" />
                                        <rect x="18" y="0" width="4" height="4" />
                                        <rect x="0" y="6" width="4" height="4" />
                                        <rect x="6" y="6" width="4" height="4" />
                                        <rect x="12" y="6" width="4" height="4" />
                                        <rect x="18" y="6" width="4" height="4" />
                                    </svg>
                                </a>
                            </div><!-- End .toolbox-layout -->
                        </div><!-- End .toolbox-right -->
                    </div><!-- End .toolbox -->

                    <div class="products mb-3">
                        <% if(products && products.length > 0) { %>
                            <div class="row justify-content-center">
                                <% products.forEach(product => { %>
                                    <% 
                                        let isNew = (Date.now() - new Date(product.createdAt).getTime()) < 7 * 24 * 60 * 60 * 1000;
                                        let hasDiscount = product.salePrice < product.regularPrice;
                                    %>
                                    <% if (selectedLayout === 'list') { %>
                                        <div class="col-12">
                                            <div class="product product-list">
                                                <div class="row">
                                                    <div class="col-6 col-lg-3">
                                                        <figure class="product-media">
                                                            <% if(isNew) { %>
                                                                <span class="product-label label-new">New</span>
                                                            <% } else if(product.productOffer > 0) { %>
                                                                <span class="product-label label-sale"><%= Math.round((product.productOffer / product.regularPrice) * 100) %>% OFF</span>
                                                            <% } else if(hasDiscount) { %>
                                                                <span class="product-label label-sale">Sale</span>
                                                            <% } %>
                                                            <a href="/product/<%= product._id %>">
                                                                <% if (product.productImage && product.productImage.length > 0) { %>
                                                                    <img src="/uploads/productImages/<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
                                                                <% } else { %>
                                                                    <img src="assets/images/products/product-4.jpg" alt="No image" class="product-image">
                                                                <% } %>
                                                            </a>
                                                        </figure>
                                                    </div>

                                                    <div class="col-6 col-lg-3 order-lg-last">
                                                        <div class="product-list-action">
                                                            <div class="product-price">
                                                                <% if (hasDiscount) { %>
                                                                    <span class="new-price">₹<%= product.salePrice %></span>
                                                                    <span class="old-price" style="text-decoration: line-through; margin-left: 10px; color: #ccc;">₹<%= product.regularPrice %></span>
                                                                <% } else { %>
                                                                    ₹<%= product.regularPrice %>
                                                                <% } %>
                                                            </div>
                                                            <div class="product-action">
                                                                <a href="popup/quickView.html" class="btn-product btn-quickview" title="Quick view"><span>quick view</span></a>
                                                            </div>
                                                            <a href="/product/<%= product._id %>" class="btn-product btn-cart"><span>select options</span></a>
                                                        </div>
                                                    </div>

                                                    <div class="col-lg-6">
                                                        <div class="product-body product-action-inner">
                                                            <a href="#" class="btn-product btn-wishlist btn-add-wishlist <%= wishlistProductIds.includes(product._id.toString()) ? 'in-wishlist' : '' %>" data-product-id="<%= product._id %>" title="Add to wishlist" style="font-size: 1.8rem;"><span>add to wishlist</span></a>
                                                            <div class="product-cat">
                                                                <a href="/shop?category=<%= product.category._id %>"><%= product.category.name %></a>
                                                            </div>
                                                            <h3 class="product-title"><a href="/product/<%= product._id %>"><%= product.productName %></a></h3>
                                                            
                                                            <div class="product-content">
                                                                <p><%= product.description ? product.description.substring(0, 100) + '...' : '' %></p>
                                                            </div>
                                                            
                                                            <div class="product-nav product-nav-thumbs">
                                                                <% if (product.productImage && product.productImage.length > 0) { %>
                                                                    <% product.productImage.slice(0,3).forEach((img, i) => { %>
                                                                        <a href="#" class="<%= i === 0 ? 'active' : '' %>">
                                                                            <img src="/uploads/productImages/<%= img %>" alt="<%= product.productName %>">
                                                                        </a>
                                                                    <% }) %>
                                                                <% } %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    <% } else { %>
                                        <% 
                                        let columnClass = "col-6 col-md-4 col-lg-4";
                                        if (selectedLayout === '2col') {
                                            columnClass = "col-6";
                                        } else if (selectedLayout === '3col') {
                                            columnClass = "col-6 col-md-4 col-lg-4";
                                        } else if (selectedLayout === '4col') {
                                            columnClass = "col-6 col-md-4 col-lg-4 col-xl-3";
                                        }
                                        %>
                                        <div class="<%= columnClass %>">
                                            <div class="product product-7 text-center">
                                                <figure class="product-media">
                                                    <% if(isNew) { %>
                                                        <span class="product-label label-new">New</span>
                                                    <% } else if(product.productOffer > 0) { %>
                                                        <span class="product-label label-sale"><%= Math.round((product.productOffer / product.regularPrice) * 100) %>% OFF</span>
                                                    <% } else if(hasDiscount) { %>
                                                        <span class="product-label label-sale">Sale</span>
                                                    <% } %>

                                                    <a href="/product/<%= product._id %>">
                                                        <% if (product.productImage && product.productImage.length > 0) { %>
                                                            <img src="/uploads/productImages/<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
                                                        <% } else { %>
                                                            <img src="assets/images/products/product-4.jpg" alt="No image" class="product-image">
                                                        <% } %>
                                                    </a>

                                                    <div class="product-action-vertical">
                                                        <a href="#" class="btn-product-icon btn-wishlist btn-expandable btn-add-wishlist <%= wishlistProductIds.includes(product._id.toString()) ? 'in-wishlist' : '' %>" data-product-id="<%= product._id %>" style="font-size: 1.8rem;"><span>add to wishlist</span></a>
                                                    </div><!-- End .product-action-vertical -->

                                                    <div class="product-action">
                                                        <a href="/product/<%= product._id %>" class="btn-product btn-cart"><span>select options</span></a>
                                                    </div><!-- End .product-action -->
                                                </figure><!-- End .product-media -->

                                                <div class="product-body">
                                                    <div class="product-cat">
                                                        <a href="/shop?category=<%= product.category._id %>"><%= product.category.name %></a>
                                                    </div><!-- End .product-cat -->
                                                    <h3 class="product-title"><a href="/product/<%= product._id %>"><%= product.productName %></a></h3><!-- End .product-title -->
                                                    <div class="product-price">
                                                        <% if (product.salePrice < product.regularPrice) { %>
                                                            <span class="new-price">₹<%= product.salePrice %></span>
                                                            <span class="old-price">₹<%= product.regularPrice %></span>
                                                        <% } else { %>
                                                            ₹<%= product.regularPrice %>
                                                        <% } %>
                                                    </div><!-- End .product-price -->

                                                    <div class="product-nav product-nav-thumbs">
                                                        <% if (product.productImage && product.productImage.length > 0) { %>
                                                            <% product.productImage.slice(0,3).forEach((img, i) => { %>
                                                                <a href="#" class="<%= i === 0 ? 'active' : '' %>">
                                                                    <img src="/uploads/productImages/<%= img %>" alt="<%= product.productName %>">
                                                                </a>
                                                            <% }) %>
                                                        <% } %>
                                                    </div><!-- End .product-nav -->
                                                </div><!-- End .product-body -->
                                            </div><!-- End .product -->
                                        </div><!-- End .col-sm-6 col-lg-4 -->
                                    <% } %>
                                <% }) %>
                            </div><!-- End .row -->
                        <% } else { %>
                            <div class="text-center py-5">
                                <h3>No products found</h3>
                                <p>Try adjusting your search or filter.</p>
                                <a href="/shop" class="btn btn-outline-primary-2 mt-2">Clear Filters</a>
                            </div>
                        <% } %>
                    </div><!-- End .products -->

                    <% if (totalPages > 1) { %>
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                <% 
                                    let queryParams = `search=${search}&category=${selectedCategory}&sort=${selectedSort}&minPrice=${minPrice}&maxPrice=${maxPrice}&size=${selectedSizes.join(',')}&layout=${selectedLayout}`;
                                %>
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link page-link-prev" href="/shop?page=<%= currentPage - 1 %>&<%= queryParams %>" aria-label="Previous">
                                        <span aria-hidden="true"><i class="icon-long-arrow-left"></i></span>Prev
                                    </a>
                                </li>
                                
                                <% for(let i = 1; i <= totalPages; i++) { %>
                                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                        <a class="page-link" href="/shop?page=<%= i %>&<%= queryParams %>"><%= i %></a>
                                    </li>
                                <% } %>

                                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                    <a class="page-link page-link-next" href="/shop?page=<%= currentPage + 1 %>&<%= queryParams %>" aria-label="Next">
                                        Next <span aria-hidden="true"><i class="icon-long-arrow-right"></i></span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div><!-- End .col-lg-9 -->

                <aside class="col-lg-3 order-lg-first">
                    <div class="sidebar sidebar-shop">
                        <div class="widget widget-clean">
                            <label>Filters:</label>
                            <a href="/shop" class="sidebar-filter-clear">Clear All</a>
                        </div><!-- End .widget widget-clean -->



                        <div class="widget widget-collapsible">
                            <h3 class="widget-title">
                                <a data-toggle="collapse" href="#widget-1" role="button" aria-expanded="true" aria-controls="widget-1">
                                    Category
                                </a>
                            </h3><!-- End .widget-title -->

                            <div class="collapse show" id="widget-1">
                                <div class="widget-body">
                                    <div class="filter-items filter-items-count">
                                        <% categories.forEach((cat, index) => { %>
                                            <div class="filter-item">
                                                <div class="custom-control custom-radio">
                                                    <input type="radio" name="category" class="custom-control-input" id="cat-<%= index %>" value="<%= cat._id %>" <%= selectedCategory === cat._id.toString() ? 'checked' : '' %> onchange="window.location.href=updateQueryStringParameter(updateQueryStringParameter(window.location.href, 'category', this.value), 'page', 1)">
                                                    <label class="custom-control-label" style="cursor: pointer" for="cat-<%= index %>"><%= cat.name %></label>
                                                </div><!-- End .custom-checkbox -->
                                            </div><!-- End .filter-item -->
                                        <% }) %>
                                    </div><!-- End .filter-items -->
                                </div><!-- End .widget-body -->
                            </div><!-- End .collapse -->
                        </div><!-- End .widget -->

                        <div class="widget widget-collapsible">
                            <h3 class="widget-title">
                                <a data-toggle="collapse" href="#widget-size" role="button" aria-expanded="true" aria-controls="widget-size">
                                    Size
                                </a>
                            </h3>
                            <div class="collapse show" id="widget-size">
                                <div class="widget-body">
                                    <div class="filter-items">
                                        <% ['S', 'M', 'L'].forEach((s, index) => { %>
                                            <div class="filter-item">
                                                <div class="custom-control custom-checkbox">
                                                    <input type="checkbox" class="custom-control-input size-checkbox" id="size-<%= index %>" value="<%= s %>" <%= selectedSizes.includes(s) ? 'checked' : '' %> onchange="updateSizeFilter()">
                                                    <label class="custom-control-label" style="cursor: pointer" for="size-<%= index %>"><%= s %></label>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="widget widget-collapsible">
                            <h3 class="widget-title">
                                <a data-toggle="collapse" href="#widget-price" role="button" aria-expanded="true" aria-controls="widget-price">
                                    Price Range
                                </a>
                            </h3>
                            <div class="collapse show" id="widget-price">
                                <div class="widget-body">
                                    <div class="filter-price">
                                        <div class="filter-price-text mb-2">
                                            Price Range: <span id="filter-price-range"></span>
                                        </div>
                                        <div id="price-slider"></div>
                                        <div class="mt-5" style="display: flex; justify-content: flex-end;">
                                            <button class="btn btn-outline-primary-2 btn-sm" onclick="updatePriceFilter()">Filter</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!-- End .sidebar sidebar-shop -->
                </aside><!-- End .col-lg-3 -->
            </div><!-- End .row -->
        </div><!-- End .container -->
    </div><!-- End .page-content -->
</main><!-- End .main -->

</div><!-- End .page-wrapper -->

<button id="scroll-top" title="Back to Top">
    <i class="icon-arrow-up"></i>
</button>

<script>
// Helper function to update URL query params without reloading initially
function updateQueryStringParameter(uri, key, value) {
  var re = new RegExp("([?&])" + key + "=.*?(&|$)", "i");
  var separator = uri.indexOf('?') !== -1 ? "&" : "?";
  if (uri.match(re)) {
    return uri.replace(re, '$1' + key + "=" + value + '$2');
  }
  else {
    return uri + separator + key + "=" + value;
  }
}
</script>

<script src="assets/js/jquery.min.js"></script>
<script src="assets/js/bootstrap.bundle.min.js"></script>
<script src="assets/js/jquery.hoverIntent.min.js"></script>
<script src="assets/js/jquery.waypoints.min.js"></script>
<script src="assets/js/superfish.min.js"></script>
<script src="assets/js/owl.carousel.min.js"></script>
<script src="assets/js/jquery.magnific-popup.min.js"></script>
<script src="assets/js/wNumb.js"></script>
<script src="assets/js/nouislider.min.js"></script>
<!-- Main JS File -->
<script src="assets/js/main.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function() {
        var slider = document.getElementById('price-slider');
        if (slider && typeof noUiSlider === 'object') {
            noUiSlider.create(slider, {
                start: [<%= minPrice %>, <%= maxPrice %>],
                connect: true,
                step: 10,
                margin: 10,
                range: {
                    'min': 0,
                    'max': 2000
                },
                tooltips: true,
                format: wNumb({
                    decimals: 0,
                    prefix: '₹'
                })
            });

            // Update the text display
            slider.noUiSlider.on('update', function(values, handle) {
                $('#filter-price-range').text(values.join(' - '));
            });
        }
    });

    function updateSizeFilter() {
        let sizes = [];
        document.querySelectorAll('.size-checkbox:checked').forEach(cb => {
            sizes.push(cb.value);
        });
        
        let newUrl = window.location.href;
        if (sizes.length > 0) {
            newUrl = updateQueryStringParameter(newUrl, 'size', sizes.join(','));
        } else {
            var re = new RegExp("([?&])" + 'size' + "=.*?(&|$)", "i");
            newUrl = newUrl.replace(re, '$1' + '$2').replace(/[?&]$/, '');
        }
        
        newUrl = updateQueryStringParameter(newUrl, 'page', 1);
        window.location.href = newUrl;
    }

    function updatePriceFilter() {
        var slider = document.getElementById('price-slider');
        if(slider && slider.noUiSlider) {
            var vals = slider.noUiSlider.get();
            let minp = parseInt(vals[0].replace(/[^0-9]/g, ''));
            let maxp = parseInt(vals[1].replace(/[^0-9]/g, ''));
            
            let newUrl = updateQueryStringParameter(window.location.href, 'minPrice', minp);
            newUrl = updateQueryStringParameter(newUrl, 'maxPrice', maxp);
            newUrl = updateQueryStringParameter(newUrl, 'page', 1);
            window.location.href = newUrl;
        }
    }

    $(document).ready(function() {
        $(document).on('click', '.btn-add-wishlist', async function(e) {
            e.preventDefault();
            const productId = $(this).data('product-id');

            try {
                const response = await fetch('/wishlist/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ productId })
                });

                const data = await response.json();
                const $btn = $(this);

                if (response.ok && data.success) {
                    $btn.addClass('in-wishlist');
                    
                    // Update wishlist count in header
                    const $wishlistCount = $('.cart-dropdown a[href="/wishlist"] .cart-count');
                    if ($wishlistCount.length) {
                        let currentCount = parseInt($wishlistCount.text()) || 0;
                        if (data.message.toLowerCase().includes('added')) {
                            $wishlistCount.text(currentCount + 1);
                            $wishlistCount.css('display', 'flex'); // Ensure it becomes visible
                        }
                    }

                    const Toast = Swal.mixin({
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000,
                        timerProgressBar: true,
                        didOpen: (toast) => {
                            toast.addEventListener('mouseenter', Swal.stopTimer)
                            toast.addEventListener('mouseleave', Swal.resumeTimer)
                        }
                    });

                    Toast.fire({
                        icon: 'success',
                        title: data.message
                    });
                } else {
                    if (response.status === 401 || (typeof data.message === 'string' && data.message.toLowerCase().includes('login'))) {
                        Swal.fire({
                            icon: 'info',
                            title: 'Please Login',
                            text: 'You need to be logged in to save items to your wishlist.',
                            showCancelButton: true,
                            confirmButtonText: 'Login Now'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/signin';
                            }
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Oops...',
                            text: data.message || 'Could not add to wishlist.'
                        });
                    }
                }
            } catch (error) {
                console.error("Wishlist error:", error);
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Something went wrong.'
                });
            }
        });
    });
</script>

<%-include("../../views/partials/user/mobileView.ejs")%>
<%-include("../../views/partials/user/footer.ejs")%>
