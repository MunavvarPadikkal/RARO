<%- include("../partials/user/header.ejs") %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        .referral-hero {
            background: linear-gradient(135deg, #1c1c1c 0%, #2d2d2d 100%);
            border-radius: 20px;
            padding: 40px;
            color: #fff;
            position: relative;
            overflow: hidden;
            margin-bottom: 30px;
        }
        .referral-hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(200, 161, 101, 0.15) 0%, transparent 70%);
            border-radius: 50%;
        }
        .referral-hero::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(200, 161, 101, 0.1) 0%, transparent 70%);
            border-radius: 50%;
        }
        .referral-hero h3 {
            font-weight: 700;
            font-size: 1.6rem;
            margin-bottom: 8px;
        }
        .referral-hero .subtitle {
            color: #aaa;
            font-size: 14px;
            margin-bottom: 25px;
        }

        .referral-code-box {
            background: rgba(255, 255, 255, 0.08);
            border: 1px dashed rgba(200, 161, 101, 0.5);
            border-radius: 14px;
            padding: 18px 24px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            position: relative;
            z-index: 1;
        }
        .referral-code-box .code {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: 2px;
            color: #c8a165;
        }
        .copy-btn {
            background: #c8a165;
            color: #fff;
            border: none;
            padding: 10px 22px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .copy-btn:hover {
            background: #b8914f;
            transform: translateY(-1px);
        }
        .copy-btn.copied {
            background: #2ecc71;
        }

        .share-link-box {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 14px 20px;
            margin-top: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            position: relative;
            z-index: 1;
        }
        .share-link-box .link-text {
            color: #ccc;
            font-size: 13px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 1;
        }
        .share-link-btn {
            background: transparent;
            border: 1px solid rgba(200, 161, 101, 0.5);
            color: #c8a165;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            white-space: nowrap;
        }
        .share-link-btn:hover {
            background: rgba(200, 161, 101, 0.1);
        }

        .stat-card {
            background: #fdfdfd;
            border: 1px solid #f0f0f0;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            transition: all 0.3s;
        }
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
        }
        .stat-card .stat-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 20px;
        }
        .stat-card .stat-value {
            font-size: 1.6rem;
            font-weight: 700;
            color: #222;
        }
        .stat-card .stat-label {
            font-size: 12px;
            color: #999;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 4px;
        }

        .referral-table-container {
            background: #fff;
            border: 1px solid #f0f0f0;
            border-radius: 16px;
            overflow: hidden;
        }
        .referral-table-header {
            padding: 20px 24px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .referral-table-header h5 {
            font-weight: 600;
            color: #333;
            margin: 0;
        }
        .referral-table {
            width: 100%;
            border-collapse: collapse;
        }
        .referral-table th {
            padding: 14px 24px;
            font-size: 12px;
            font-weight: 600;
            color: #888;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
            background: #fafafa;
            border-bottom: 1px solid #f0f0f0;
        }
        .referral-table td {
            padding: 16px 24px;
            font-size: 14px;
            color: #444;
            border-bottom: 1px solid #f5f5f5;
        }
        .referral-table tr:last-child td {
            border-bottom: none;
        }
        .referral-table tr:hover {
            background: #fafafa;
        }

        .status-badge {
            display: inline-block;
            padding: 5px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        .status-pending {
            background: #fff3e0;
            color: #e65100;
        }
        .status-completed {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }
        .empty-state i {
            font-size: 48px;
            color: #e0e0e0;
            margin-bottom: 16px;
        }
        .empty-state h6 {
            color: #888;
            font-weight: 500;
            margin-bottom: 8px;
        }
        .empty-state p {
            color: #bbb;
            font-size: 13px;
        }

        .promo-banner {
            background: linear-gradient(135deg, #fef9f4 0%, #fdf2ea 100%);
            border: 1px solid #f0dcc8;
            border-radius: 14px;
            padding: 18px 24px;
            margin-bottom: 24px;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .promo-banner .promo-icon {
            font-size: 28px;
        }
        .promo-banner .promo-text {
            font-size: 14px;
            color: #6d4c2e;
            font-weight: 500;
        }
        .promo-banner .promo-text strong {
            color: #c8a165;
        }

        @media (max-width: 768px) {
            .referral-hero {
                padding: 24px;
            }
            .referral-code-box {
                flex-direction: column;
                text-align: center;
            }
            .share-link-box {
                flex-direction: column;
            }
        }
    </style>

    <main class="main">
        <div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
            <div class="container">
                <h1 class="page-title">My Account<span>Invite & Earn</span></h1>
            </div>
        </div>
        <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
            <div class="container">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/profile">Profile</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Referrals</li>
                </ol>
            </div>
        </nav>

        <div class="page-content">
            <div class="dashboard">
                <div class="container">
                    <div class="row">
                        <% var activeTab = 'invite'; %>
                        <%- include("../../views/partials/user/profileSidebar.ejs", { activeTab: activeTab }) %>

                        <div class="col-md-8 col-lg-9">

                            <!-- Promo Banner -->
                            <div class="promo-banner">
                                <span class="promo-icon">🎁</span>
                                <div class="promo-text">
                                    Invite friends and earn <strong>₹<%= settings.referrerReward %></strong> for each successful referral!
                                    Your friend gets <strong>₹<%= settings.referredReward %></strong> after their first order.
                                </div>
                            </div>

                            <!-- Referral Hero Card -->
                            <div class="referral-hero">
                                <h3>Your Referral Code</h3>
                                <p class="subtitle">Share your code with friends and earn rewards when they complete their first order.</p>

                                <div class="referral-code-box">
                                    <span class="code" id="referralCode"><%= referralCode %></span>
                                    <button class="copy-btn" id="copyCodeBtn" onclick="copyToClipboard('referralCode', this, 'Code')">
                                        <i class="fa-regular fa-copy"></i> Copy Code
                                    </button>
                                </div>

                                <div class="share-link-box">
                                    <span class="link-text" id="referralLink"></span>
                                    <button class="share-link-btn" onclick="copyToClipboard('referralLink', this, 'Link')">
                                        <i class="fa-solid fa-link"></i> Copy Link
                                    </button>
                                </div>
                                <script>
                                    // Build referral link dynamically using window.location
                                    document.getElementById('referralLink').textContent = 
                                        window.location.origin + '/register?ref=<%= referralCode %>';
                                </script>
                            </div>

                            <!-- Stats Cards -->
                            <div class="row mb-4">
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #eef2ff;">👥</div>
                                        <div class="stat-value"><%= stats.totalReferrals %></div>
                                        <div class="stat-label">Total Referrals</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #e8f5e9;">✅</div>
                                        <div class="stat-value"><%= stats.completedReferrals %></div>
                                        <div class="stat-label">Completed</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #fff3e0;">⏳</div>
                                        <div class="stat-value"><%= stats.pendingReferrals %></div>
                                        <div class="stat-label">Pending</div>
                                    </div>
                                </div>
                                <div class="col-6 col-md-3 mb-3">
                                    <div class="stat-card">
                                        <div class="stat-icon" style="background: #fef3e2;">💰</div>
                                        <div class="stat-value">₹<%= stats.totalEarnings %></div>
                                        <div class="stat-label">Total Earned</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Referral History Table -->
                            <div class="referral-table-container">
                                <div class="referral-table-header">
                                    <h5>Referral History</h5>
                                    <span style="font-size: 13px; color: #999;"><%= referrals.length %> referral<%= referrals.length !== 1 ? 's' : '' %></span>
                                </div>

                                <% if (referrals.length > 0) { %>
                                    <table class="referral-table">
                                        <thead>
                                            <tr>
                                                <th>Referred User</th>
                                                <th>Status</th>
                                                <th>Reward</th>
                                                <th>Date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% referrals.forEach(ref => { %>
                                                <tr>
                                                    <td>
                                                        <div style="font-weight: 600; color: #333;"><%= ref.referredUserId ? ref.referredUserId.name : 'Unknown' %></div>
                                                        <div style="font-size: 12px; color: #999;"><%= ref.referredUserId ? ref.referredUserId.email : '' %></div>
                                                    </td>
                                                    <td>
                                                        <% if (ref.status === 'completed') { %>
                                                            <span class="status-badge status-completed">Completed</span>
                                                        <% } else { %>
                                                            <span class="status-badge status-pending">Pending</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <% if (ref.status === 'completed') { %>
                                                            <span style="font-weight: 600; color: #2e7d32;">+₹<%= ref.rewardReferrer %></span>
                                                        <% } else { %>
                                                            <span style="color: #999;">₹<%= ref.rewardReferrer %> (pending)</span>
                                                        <% } %>
                                                    </td>
                                                    <td>
                                                        <span style="color: #666;"><%= new Date(ref.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                                        <% if (ref.completedAt) { %>
                                                            <div style="font-size: 11px; color: #2e7d32;">Completed: <%= new Date(ref.completedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></div>
                                                        <% } %>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                <% } else { %>
                                    <div class="empty-state">
                                        <i class="fa-solid fa-user-plus"></i>
                                        <h6>No referrals yet</h6>
                                        <p>Share your referral code with friends to start earning rewards!</p>
                                    </div>
                                <% } %>
                            </div>

                        </div><!-- End .col-lg-9 -->
                    </div><!-- End .row -->
                </div><!-- End .container -->
            </div><!-- End .dashboard -->
        </div><!-- End .page-content -->
    </main>

    </div><!-- End .page-wrapper -->

    <button id="scroll-top" title="Back to Top">
        <i class="icon-arrow-up"></i>
    </button>

    <%-include("../../views/partials/user/mobileView.ejs")%>
    <%-include("../../views/partials/user/footer.ejs")%>

    <script src="assets/js/jquery.min.js"></script>
    <script src="assets/js/bootstrap.bundle.min.js"></script>
    <script src="assets/js/jquery.hoverIntent.min.js"></script>
    <script src="assets/js/jquery.waypoints.min.js"></script>
    <script src="assets/js/superfish.min.js"></script>
    <script src="assets/js/owl.carousel.min.js"></script>
    <script src="assets/js/main.js"></script>

    <script>
        function copyToClipboard(elementId, button, label) {
            const text = document.getElementById(elementId).innerText.trim();
            navigator.clipboard.writeText(text).then(() => {
                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
                button.classList.add('copied');
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('copied');
                }, 2000);
            }).catch(() => {
                // Fallback
                const textarea = document.createElement('textarea');
                textarea.value = text;
                document.body.appendChild(textarea);
                textarea.select();
                document.execCommand('copy');
                document.body.removeChild(textarea);

                const originalHTML = button.innerHTML;
                button.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
                button.classList.add('copied');
                setTimeout(() => {
                    button.innerHTML = originalHTML;
                    button.classList.remove('copied');
                }, 2000);
            });
        }
    </script>
