<%- include("../../views/partials/user/header.ejs") %>

<main class="main">
    <div class="page-content pt-5 pb-5">
        <div class="container">

            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">

                    <!-- ── Failure Card ── -->
                    <div class="order-failure-card relative">
                        
                        <!-- Animated failure icon -->
                        <div class="failure-icon-wrapper">
                            <div class="failure-icon-circle">
                                <svg class="failure-crossmark" viewBox="0 0 52 52">
                                    <circle class="failure-crossmark-circle" cx="26" cy="26" r="25" fill="none"/>
                                    <path class="failure-crossmark-cross" fill="none" d="M16 16 36 36 M36 16 16 36"/>
                                </svg>
                            </div>
                        </div>

                        <h1 class="failure-heading">Payment Failed!</h1>
                        <p class="failure-subtext">Oops, <strong><%= user.name %></strong>. We were unable to process your payment.</p>
                        
                        <div class="alert alert-danger mb-4" style="font-size: 1.4rem;">
                            Don't worry! Your order has been saved. You can retry the payment to complete your purchase. 
                            <strong>Note: Stock is not reserved until payment is successful.</strong>
                        </div>

                        <!-- ── Order Meta ── -->
                        <div class="order-meta-grid">
                            <div class="order-meta-item">
                                <span class="meta-label">Order ID</span>
                                <span class="meta-value order-id-value" title="<%= order.orderId %>">
                                    #<%= order.orderId %>
                                </span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Order Date</span>
                                <span class="meta-value">
                                    <%= new Date(order.createdOn).toLocaleDateString('en-IN', {
                                        day: 'numeric', month: 'long', year: 'numeric'
                                    }) %>
                                </span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Payment</span>
                                <span class="meta-value"><%= order.paymentMethod %></span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Status</span>
                                <span class="meta-value order-status-badge">Failed</span>
                            </div>
                        </div>

                        <!-- ── Ordered Items ── -->
                        <div class="failure-section">
                            <h3 class="failure-section-title">Items Ordered</h3>
                            <div class="failure-items-list">
                                <% order.orderedItems.forEach(item => { %>
                                    <div class="failure-item-row">
                                        <div class="failure-item-img">
                                            <% if (item.productImage) { %>
                                                <img src="/uploads/productImages/<%= item.productImage %>"
                                                     alt="<%= item.productName %>">
                                            <% } else { %>
                                                <img src="/assets/images/products/product-4.jpg" alt="Product">
                                            <% } %>
                                        </div>
                                        <div class="failure-item-info">
                                            <p class="failure-item-name"><%= item.productName %></p>
                                            <p class="failure-item-meta">
                                                Size: <strong><%= item.size %></strong>
                                                <% if (item.color) { %> &nbsp;·&nbsp; Color: <strong><%= item.color %></strong><% } %>
                                                &nbsp;·&nbsp; Qty: <strong><%= item.quantity %></strong>
                                            </p>
                                        </div>
                                        <div class="failure-item-price">₹<%= item.itemTotal %></div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>

                        <!-- ── Price Summary ── -->
                        <div class="failure-section">
                            <h3 class="failure-section-title">Price Breakdown</h3>
                            <table class="failure-price-table">
                                <tr>
                                    <td>Subtotal</td>
                                    <td>₹<%= order.subtotal %></td>
                                </tr>
                                <% if (order.discount > 0) { %>
                                    <tr class="discount-row">
                                        <td>Coupon Discount</td>
                                        <td>− ₹<%= order.discount %></td>
                                    </tr>
                                <% } %>
                                <tr>
                                    <td>Shipping</td>
                                    <td><%= order.shippingCharge === 0 ? 'Free' : '₹' + order.shippingCharge %></td>
                                </tr>
                                <tr class="total-row">
                                    <td><strong>Total Amount</strong></td>
                                    <td><strong>₹<%= order.finalAmount %></strong></td>
                                </tr>
                            </table>
                        </div>

                        <!-- ── Action Buttons ── -->
                        <div class="failure-actions">
                            <button class="btn btn-primary" onclick="retryPayment('<%= order._id %>')">
                                <i class="icon-refresh"></i> Retry Payment
                            </button>
                            <a href="/orders" class="btn btn-outline-dark-2">
                                <i class="icon-list"></i> View My Orders
                            </a>
                        </div>

                    </div><!-- End .order-failure-card -->

                </div>
            </div><!-- End .row -->
        </div><!-- End .container -->
    </div><!-- End .page-content -->
</main>

<button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>

<!-- ══════════════════════════════════════════════════════════════════════════
     Order Failure Page Styles
═══════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ── Card ──────────────────────────────────────────────────────────────── */
    .order-failure-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        padding: 48px 40px;
        text-align: center;
    }
    @media (max-width: 576px) {
        .order-failure-card { padding: 32px 20px; }
    }

    /* ── Animated Crossmark ────────────────────────────────────────────────── */
    .failure-icon-wrapper { margin-bottom: 24px; }
    .failure-icon-circle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 90px;
        height: 90px;
    }
    .failure-crossmark {
        width: 90px;
        height: 90px;
        border-radius: 50%;
    }
    .failure-crossmark-circle {
        stroke: #e53935;
        stroke-width: 2;
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-miterlimit: 10;
        animation: strokeCircle 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }
    .failure-crossmark-cross {
        stroke: #e53935;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: strokeCross 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.5s forwards;
    }
    @keyframes strokeCircle {
        100% { stroke-dashoffset: 0; }
    }
    @keyframes strokeCross {
        100% { stroke-dashoffset: 0; }
    }

    /* ── Headings ──────────────────────────────────────────────────────────── */
    .failure-heading {
        font-size: 3.2rem;
        font-weight: 800;
        color: #e53935;
        margin-bottom: 8px;
    }
    .failure-subtext {
        font-size: 1.5rem;
        color: #666;
        margin-bottom: 32px;
    }

    /* ── Order Meta Grid ───────────────────────────────────────────────────── */
    .order-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        background: #fffafa;
        border: 1px solid #ffebee;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 32px;
        text-align: left;
    }
    @media (max-width: 480px) {
        .order-meta-grid { grid-template-columns: 1fr; }
    }
    .order-meta-item { display: flex; flex-direction: column; gap: 4px; }
    .meta-label {
        font-size: 1.1rem;
        font-weight: 600;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .meta-value { font-size: 1.4rem; font-weight: 600; color: #333; }
    .order-id-value {
        font-family: monospace;
        font-size: 1.3rem;
        color: #e53935;
        cursor: help;
    }
    .order-status-badge {
        display: inline-block;
        background: #ffebee;
        color: #c62828;
        padding: 2px 12px;
        border-radius: 20px;
        font-size: 1.2rem;
        font-weight: 700;
    }

    /* ── Sections ──────────────────────────────────────────────────────────── */
    .failure-section {
        text-align: left;
        margin-bottom: 28px;
        border-top: 1px solid #f0f0f0;
        padding-top: 24px;
    }
    .failure-section-title {
        font-size: 1.7rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 16px;
    }

    /* ── Items List ────────────────────────────────────────────────────────── */
    .failure-items-list { display: flex; flex-direction: column; gap: 12px; }
    .failure-item-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px;
        border: 1px solid #f0f0f0;
        border-radius: 10px;
        background: #fafafa;
    }
    .failure-item-img {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        flex-shrink: 0;
        border: 1px solid #eee;
    }
    .failure-item-img img { width: 100%; height: 100%; object-fit: cover; }
    .failure-item-info { flex: 1; }
    .failure-item-name { font-size: 1.4rem; font-weight: 600; color: #333; margin-bottom: 3px; }
    .failure-item-meta { font-size: 1.2rem; color: #777; margin: 0; }
    .failure-item-price { font-size: 1.4rem; font-weight: 700; color: #c96; white-space: nowrap; }

    /* ── Price Table ───────────────────────────────────────────────────────── */
    .failure-price-table { width: 100%; border-collapse: collapse; font-size: 1.4rem; }
    .failure-price-table td { padding: 8px 4px; color: #444; }
    .failure-price-table td:last-child { text-align: right; font-weight: 600; }
    .failure-price-table .discount-row td { color: #2e7d32; }
    .failure-price-table .total-row td {
        font-size: 1.6rem;
        color: #222;
        border-top: 2px solid #eee;
        padding-top: 12px;
    }

    /* ── Action Buttons ────────────────────────────────────────────────────── */
    .failure-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #f0f0f0;
    }
    .failure-actions .btn { min-width: 180px; }
</style>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    async function retryPayment(orderId) {
        try {
            // 1. Fetch Razorpay order details for retry
            const res = await fetch(`/checkout/retry-payment/${orderId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const data = await res.json();
            
            if (!data.success) {
                return Swal.fire('Error', data.message || 'Could not initiate retry', 'error');
            }

            // 2. Open Razorpay Checkout
            const options = {
                key: data.key,
                amount: data.amount * 100,
                currency: "INR",
                name: "RARO Shop",
                description: "Retry Order Payment",
                order_id: data.razorpayOrderId,
                handler: async function (response) {
                    // 3. Verify Payment
                    try {
                        const verifyRes = await fetch('/checkout/verify-retry', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                orderId: orderId,
                                razorpayPaymentId: response.razorpay_payment_id,
                                razorpayOrderId: response.razorpay_order_id,
                                razorpaySignature: response.razorpay_signature
                            })
                        });
                        const verifyData = await verifyRes.json();
                        
                        if (verifyData.success) {
                            window.location.href = `/order-success/${orderId}`;
                        } else {
                            Swal.fire('Error', verifyData.message || 'Verification failed', 'error');
                        }
                    } catch (e) {
                        Swal.fire('Error', 'Server error during verification', 'error');
                    }
                },
                prefill: {
                    name: "<%= user.name %>",
                    email: "<%= user.email %>",
                    contact: "<%= user.phone || '' %>"
                },
                theme: { color: "#cc9966" }
            };

            const rzp = new Razorpay(options);
            rzp.on('payment.failed', function (response){
                Swal.fire('Payment Failed', response.error.description, 'error');
            });
            rzp.open();

        } catch (error) {
            console.error(error);
            Swal.fire('Error', 'Could not open payment window', 'error');
        }
    }
</script>

