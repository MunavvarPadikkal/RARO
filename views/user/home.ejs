                                        </a>
                                        <div class="product-action-vertical">
                                            <a href="#" class="btn-product-icon btn-wishlist btn-add-wishlist <%= wishlistProductIds.includes(product._id.toString()) ? 'in-wishlist' : '' %>" data-product-id="<%= product._id %>" title="Add to wishlist"><span>add to wishlist</span></a>
                                        </div>
                                    </figure>
                                    <div class="product-body">
                                        <h3 class="product-title"><a href="/product/<%= product._id %>"><%= product.productName %></a></h3>
                                        <div class="product-price">₹<%= product.salePrice %></div>
                                    </div>
                                    <div class="product-action">
                                        <a href="/product/<%= product._id %>" class="btn-product btn-cart"><span>view details</span></a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center w-100 py-5">No Men's products found.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Customized Products Tab -->
                <div class="tab-pane p-0 fade" id="trendy-decor-tab" role="tabpanel" aria-labelledby="trendy-decor-link">
                    <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl" 
                        data-owl-options='{"nav": false, "dots": true, "margin": 20, "loop": false, "responsive": {"0": {"items":2}, "480": {"items":2}, "768": {"items":3}, "992": {"items":4}, "1200": {"items":4, "nav": true, "dots": false}}}'>
                        <% if(customizedProducts && customizedProducts.length > 0) { %>
                            <% customizedProducts.forEach(product => { %>
                                <div class="product product-11 text-center">
                                    <figure class="product-media">
                                        <a href="/product/<%= product._id %>">
                                            <img src="<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
                                        </a>
                                        <div class="product-action-vertical">
                                            <a href="#" class="btn-product-icon btn-wishlist btn-add-wishlist <%= wishlistProductIds.includes(product._id.toString()) ? 'in-wishlist' : '' %>" data-product-id="<%= product._id %>" title="Add to wishlist"><span>add to wishlist</span></a>
                                        </div>
                                    </figure>
                                    <div class="product-body">
                                        <h3 class="product-title"><a href="/product/<%= product._id %>"><%= product.productName %></a></h3>
                                        <div class="product-price">₹<%= product.salePrice %></div>
                                    </div>
                                    <div class="product-action">
                                        <a href="/product/<%= product._id %>" class="btn-product btn-cart"><span>view details</span></a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-center w-100 py-5">No Customized products found.</p>
                        <% } %>
                    </div>
                </div>

                <!-- Oversized Products Tab -->
                <div class="tab-pane p-0 fade" id="trendy-light-tab" role="tabpanel" aria-labelledby="trendy-light-link">
                    <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl" 
                        data-owl-options='{"nav": false, "dots": true, "margin": 20, "loop": false, "responsive": {"0": {"items":2}, "480": {"items":2}, "768": {"items":3}, "992": {"items":4}, "1200": {"items":4, "nav": true, "dots": false}}}'>
                        <% if(oversizedProducts && oversizedProducts.length > 0) { %>
                            <% oversizedProducts.forEach(product => { %>
                                <div class="product product-11 text-center">
                                    <figure class="product-media">
                                        <a href="/product/<%= product._id %>">
                                            <img src="<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
