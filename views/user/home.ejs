<%-include("../../views/partials/user/header.ejs")%>


    <main class="main">
        <style>
            .btn-wishlist.in-wishlist::before {
                color: #ef837b !important;
                content: '\f233' !important;
            }
            .btn-wishlist.in-wishlist {
                color: #ef837b !important;
            }

            /* ── Dynamic Banner Carousel ─────────────────────────────── */
            .banner-carousel-section {
                position: relative;
                width: 100%;
                overflow: hidden;
            }
            .banner-carousel-section .carousel-item {
                aspect-ratio: 16 / 9;
                max-height: 700px;
                background-color: #1a1a1a;
            }
            .banner-carousel-section .carousel-item img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                max-height: 700px;
            }
            .banner-carousel-section .carousel-item::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(90deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 40%, transparent 100%);
                pointer-events: none;
                z-index: 2;
            }
            .banner-overlay {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                display: flex;
                align-items: center;
                z-index: 5;
                padding: 0 10%;
            }
            .banner-overlay .banner-subtitle {
                font-weight: 600;
                font-size: 1.2rem; /* Scaled back from 1.4rem */
                letter-spacing: .4em;
                text-transform: uppercase;
                margin-bottom: 1.5rem;
                color: #fff;
                opacity: 0;
                transform: translateY(30px);
                animation: bannerFadeUp 0.8s cubic-bezier(0.2, 1, 0.3, 1) forwards 0.2s;
                text-shadow: 0 2px 10px rgba(0,0,0,0.3);
            }
            .banner-overlay .banner-title {
                color: #fff;
                font-weight: 800;
                letter-spacing: -0.02em;
                margin-bottom: 3rem;
                font-size: 6rem; /* Scaled back to a balanced size */
                line-height: 0.95;
                max-width: 800px;
                opacity: 0;
                transform: translateY(30px);
                animation: bannerFadeUp 0.8s cubic-bezier(0.2, 1, 0.3, 1) forwards 0.4s;
                text-transform: uppercase;
                text-shadow: 0 10px 30px rgba(0,0,0,0.4);
            }
            .banner-overlay .banner-desc {
                display: none; /* Reference image doesn't show desc */
            }
            .banner-overlay .banner-btn {
                display: inline-flex;
                align-items: center;
                padding: 1rem 3.2rem; /* Slightly reduced */
                background: transparent;
                color: #fff;
                font-weight: 500;
                font-size: 1.1rem; /* Scaled back from 1.2rem */
                text-transform: uppercase;
                border: 1px solid #fff;
                border-radius: 0;
                transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
                opacity: 0;
                transform: translateY(20px);
                animation: bannerFadeUp 0.8s cubic-bezier(0.2, 1, 0.3, 1) forwards 0.6s;
                letter-spacing: 0.2em;
                text-decoration: none;
            }
            .banner-overlay .banner-btn .btn-arrow {
                display: inline-block;
                margin-left: 15px;
                font-size: 1.2rem;
                line-height: 1;
                transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            }
            .banner-overlay .banner-btn:hover {
                background: #c96;
                color: #fff;
                border-color: #c96;
            }
            .banner-overlay .banner-btn:hover .btn-arrow {
                transform: translateX(8px);
            }

            /* Responsive Banner Adjustments */
            @media screen and (max-width: 1200px) {
                .banner-overlay .banner-title { font-size: 4.8rem; max-width: 550px; }
            }
            @media screen and (max-width: 992px) {
                .banner-overlay .banner-title { font-size: 3.8rem; max-width: 450px; }
                .banner-overlay .banner-subtitle { font-size: 1rem; letter-spacing: 0.3em; }
            }
            @media screen and (max-width: 768px) {
                .banner-overlay .banner-title { 
                    font-size: 3.8rem; 
                    max-width: 300px; 
                    margin-bottom: 2rem; 
                    line-height: 1.1;
                }
                .banner-overlay .banner-subtitle { font-size: 1rem; letter-spacing: 0.2em; margin-bottom: 1.2rem; }
                .banner-overlay .banner-btn { padding: 0.8rem 2.5rem; font-size: 1rem; }
                .banner-carousel-section .carousel-item { aspect-ratio: 1 / 1; max-height: 550px; }
            }
            @media screen and (max-width: 480px) {
                .banner-overlay { padding: 0 5%; }
                .banner-overlay .banner-title { 
                    font-size: 3.2rem; 
                    max-width: 260px; 
                    line-height: 1.1;
                }
                .banner-overlay .banner-subtitle { font-size: 0.9rem; letter-spacing: 0.15em; }
                .banner-carousel-section .carousel-item { aspect-ratio: 1 / 1.1; }
            }

            /* ── Shop by Categories — Premium Grid ──────────────────── */
            .raro-categories-section {
                padding: 6rem 0;
                background: #ffffff;
            }
            .raro-categories-section .section-eyebrow {
                display: block;
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.35em;
                text-transform: uppercase;
                color: #c96;
                margin-bottom: 0.8rem;
            }
            .raro-categories-section .section-heading {
                font-size: 2.6rem;
                font-weight: 700;
                color: #222;
                letter-spacing: -0.02em;
                margin-bottom: 0.5rem;
                line-height: 1.1;
            }
            .raro-categories-section .section-subtext {
                font-size: 0.95rem;
                color: #888;
                letter-spacing: 0.02em;
                margin-bottom: 0;
            }
            .raro-categories-section .section-header {
                text-align: center;
                margin-bottom: 3.5rem;
            }
            .raro-categories-section .section-divider {
                width: 40px;
                height: 2px;
                background: #c96;
                margin: 1.2rem auto 1.5rem;
            }

            /* Grid Layout */
            .cat-grid {
                display: grid;
                grid-template-columns: 1.4fr 1fr 1fr;
                grid-template-rows: 340px 280px;
                gap: 10px;
            }

            /* Featured card spans full height */
            .cat-card--featured {
                grid-column: 1;
                grid-row: 1 / 3;
            }

            /* Individual Card */
            .cat-card {
                position: relative;
                overflow: hidden;
                display: block;
                text-decoration: none;
                cursor: pointer;
                background: #111;
            }
            .cat-card:hover { text-decoration: none; }

            .cat-card__img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.65s cubic-bezier(0.165, 0.84, 0.44, 1);
                will-change: transform;
            }
            .cat-card:hover .cat-card__img {
                transform: scale(1.06);
            }

            /* Dark gradient overlay */
            .cat-card__overlay {
                position: absolute;
                inset: 0;
                background: linear-gradient(
                    to top,
                    rgba(0,0,0,0.75) 0%,
                    rgba(0,0,0,0.2) 50%,
                    transparent 100%
                );
                transition: opacity 0.4s ease;
                z-index: 1;
            }
            .cat-card:hover .cat-card__overlay {
                opacity: 0.9;
            }

            /* Card Content */
            .cat-card__content {
                position: absolute;
                bottom: 0;
                left: 0;
                width: 100%;
                padding: 2rem 1.8rem;
                z-index: 2;
                display: flex;
                flex-direction: column;
                align-items: flex-start;
            }
            .cat-card--featured .cat-card__content {
                padding: 2.5rem 2.2rem;
            }

            .cat-card__label {
                font-size: 0.7rem;
                font-weight: 600;
                letter-spacing: 0.3em;
                text-transform: uppercase;
                color: #c96;
                margin-bottom: 0.5rem;
                display: block;
            }
            .cat-card__title {
                font-size: 1.7rem;
                font-weight: 700;
                color: #fff;
                letter-spacing: -0.01em;
                line-height: 1.15;
                margin: 0 0 1.2rem;
            }
            .cat-card--featured .cat-card__title {
                font-size: 2.4rem;
            }

            .cat-card__cta {
                display: inline-flex;
                align-items: center;
                gap: 10px;
                font-size: 0.8rem;
                font-weight: 600;
                letter-spacing: 0.25em;
                text-transform: uppercase;
                color: #fff;
                border-bottom: 1px solid rgba(255,255,255,0.4);
                padding-bottom: 3px;
                transition: all 0.3s ease;
            }
            .cat-card__cta-arrow {
                display: inline-block;
                transition: transform 0.3s ease;
            }
            .cat-card:hover .cat-card__cta {
                color: #c96;
                border-bottom-color: #c96;
            }
            .cat-card:hover .cat-card__cta-arrow {
                transform: translateX(6px);
            }

            /* Responsive Grid */
            @media screen and (max-width: 1024px) {
                .cat-grid {
                    grid-template-columns: 1fr 1fr;
                    grid-template-rows: 340px 280px 280px;
                }
                .cat-card--featured {
                    grid-column: 1 / 3;
                    grid-row: 1;
                }
            }
            @media screen and (max-width: 640px) {
                .raro-categories-section { padding: 4rem 0; }
                .raro-categories-section .section-heading { font-size: 2rem; }
                .cat-grid {
                    grid-template-columns: 1fr;
                    grid-template-rows: none;
                    gap: 8px;
                }
                .cat-card--featured, .cat-card {
                    grid-column: auto;
                    grid-row: auto;
                }
                .cat-card {
                    aspect-ratio: 4 / 3;
                }
                .cat-card--featured {
                    aspect-ratio: 3 / 2;
                }
                .cat-card__title { font-size: 1.5rem; }
                .cat-card--featured .cat-card__title { font-size: 1.9rem; }
                .cat-card__content { padding: 1.5rem; }
            }

            @keyframes bannerFadeUp {
                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }
            /* Control Arrows & Indicators styling */
            .carousel-control-prev, .carousel-control-next {
                width: 60px;
                height: 60px;
                background: transparent;
                color: #fff;
                border: none;
                border-radius: 0;
                opacity: 0.6;
                top: 50%;
                transform: translateY(-50%);
                z-index: 10;
                transition: all 0.3s ease;
            }
            .carousel-control-prev:hover, .carousel-control-next:hover {
                opacity: 1;
                transform: translateY(-50%) scale(1.1);
            }
            .carousel-control-prev { left: 20px; }
            .carousel-control-next { right: 20px; }
            
            .carousel-control-prev-icon, .carousel-control-next-icon {
                filter: none;
                width: 32px;
                height: 32px;
            }
            .carousel-control-prev-icon { filter: brightness(0) invert(1); }
            .carousel-control-next-icon { filter: brightness(0) invert(1); }

            @media screen and (max-width: 768px) {
                .carousel-control-prev, .carousel-control-next {
                    width: 40px;
                    height: 40px;
                }
                .carousel-control-prev-icon, .carousel-control-next-icon {
                    width: 24px;
                    height: 24px;
                }
                .carousel-control-prev { left: 10px; }
                .carousel-control-next { right: 10px; }
            }
            .carousel-indicators li {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                margin: 0 5px;
                background-color: #ccc;
            }
            .carousel-indicators .active {
                background-color: #333;
                width: 8px;
            }
            @media screen and (min-width: 768px) {
                .banner-overlay .banner-title { font-size: 4rem; }
                .banner-overlay .banner-subtitle { font-size: 1.2rem; }
                .banner-overlay .banner-btn { font-size: 1.1rem; padding: 1rem 3.5rem; }
            }
            @media screen and (min-width: 992px) {
                .banner-overlay { padding: 2rem 6rem; }
                .banner-overlay .banner-title { font-size: 5.5rem; }
                .banner-overlay .banner-subtitle { font-size: 1.3rem; }
                .banner-overlay .banner-btn { font-size: 1.2rem; padding: 1.1rem 4rem; }
            }
            @media screen and (min-width: 1200px) {
                .banner-overlay .banner-title { font-size: 6.5rem; max-width: 900px; }
                .banner-overlay .banner-subtitle { font-size: 1.4rem; }
                .banner-overlay .banner-btn { font-size: 1.3rem; padding: 1.2rem 4.5rem; }
                .banner-carousel-section .carousel-item {
                    height: auto;
                    max-height: 700px;
                }
                .banner-carousel-section .carousel-item img {
                    height: auto;
                    max-height: 700px;
                }
            }
            @media screen and (min-width: 1600px) {
                .banner-overlay .banner-title { font-size: 7.5rem; max-width: 1100px; }
                .banner-overlay .banner-subtitle { font-size: 1.6rem; }
                .banner-overlay .banner-btn { font-size: 1.4rem; padding: 1.3rem 5rem; }
            }

            /* Static hero fallback styles */
            .hero-full { position: relative; }
        </style>

        <% if (banners && banners.length > 0) { %>
        <!-- Dynamic Banner Carousel -->
        <section class="banner-carousel-section">
            <div id="heroBannerCarousel" class="carousel slide" data-ride="carousel" data-interval="5000" data-pause="hover">

                <!-- Indicators -->
                <% if (banners.length > 1) { %>
                <ol class="carousel-indicators">
                    <% banners.forEach((b, idx) => { %>
                        <li data-target="#heroBannerCarousel" data-slide-to="<%= idx %>" 
                            class="<%= idx === 0 ? 'active' : '' %>"></li>
                    <% }) %>
                </ol>
                <% } %>

                <!-- Slides -->
                <div class="carousel-inner">
                    <% banners.forEach((banner, idx) => { %>
                    <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                        <img src="<%= banner.imageUrl %>" alt="<%= banner.title %>" loading="<%= idx === 0 ? 'eager' : 'lazy' %>">
                        <div class="banner-overlay">
                            <div class="container">
                                <% if (banner.subtitle) { %>
                                    <div class="banner-subtitle"><%= banner.subtitle %></div>
                                <% } %>
                                <h2 class="banner-title"><%= banner.title %></h2>
                                <% if (banner.description) { %>
                                    <p class="banner-desc"><%= banner.description %></p>
                                <% } %>
                                <% if (banner.buttonText) { %>
                                    <a href="<%= banner.buttonLink || '/shop' %>" class="banner-btn">
                                        <%= banner.buttonText %>
                                        <span class="btn-arrow">&rarr;</span>
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- Controls -->
                <% if (banners.length > 1) { %>
                <a class="carousel-control-prev" href="#heroBannerCarousel" role="button" data-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="sr-only">Previous</span>
                </a>
                <a class="carousel-control-next" href="#heroBannerCarousel" role="button" data-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="sr-only">Next</span>
                </a>
                <% } %>
            </div>
        </section>
        <% } else { %>
        <!-- Fallback: Static Hero -->
        <section class="hero-full">
                <img src="assets/images/RARO Hero image.png" alt="Hero Image" class="hero-img">
        </section>
        <% } %>



        <div class="container">
            <div class="heading heading-center mb-3">
                <h2 class="title-lg">Trendy Products</h2><!-- End .title -->

                <ul class="nav nav-pills justify-content-center" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="trendy-all-link" data-toggle="tab" href="#trendy-all-tab"
                            role="tab" aria-controls="trendy-all-tab" aria-selected="true">All</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="trendy-fur-link" data-toggle="tab" href="#trendy-fur-tab" role="tab"
                            aria-controls="trendy-fur-tab" aria-selected="false">Men</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="trendy-decor-link" data-toggle="tab" href="#trendy-decor-tab" role="tab"
                            aria-controls="trendy-decor-tab" aria-selected="false">Customized</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="trendy-light-link" data-toggle="tab" href="#trendy-light-tab" role="tab"
                            aria-controls="trendy-light-tab" aria-selected="false">Oversized</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="trendy-min-link" data-toggle="tab" href="#trendy-min-tab" role="tab"
                            aria-controls="trendy-min-tab" aria-selected="false">Minimal</a>
                    </li>
                </ul>
            </div><!-- End .heading -->

            <div class="tab-content tab-content-carousel">
                <!-- All Products Tab -->
                <div class="tab-pane p-0 fade show active" id="trendy-all-tab" role="tabpanel" aria-labelledby="trendy-all-link">
                    <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl" 
                        data-owl-options='{"nav": false, "dots": true, "margin": 20, "loop": false, "responsive": {"0": {"items":2}, "480": {"items":2}, "768": {"items":3}, "992": {"items":4}, "1200": {"items":4, "nav": true, "dots": false}}}'>
                        <% if(products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <div class="product product-11 text-center">
                                    <figure class="product-media">
                                        <a href="/product/<%= product._id %>">
                                            <img src="<%= product.productImage[0] %>" alt="<%= product.productName %>" class="product-image">
                                            <% if(product.productImage[1]) { %>
                                                <img src="<%= product.productImage[1] %>" alt="<%= product.productName %>" class="product-image-hover">
                                            <% } %>
                                        </a>
                                        <div class="product-action-vertical">
                                            <a href="#" class="btn-product-icon btn-wishlist btn-add-wishlist <%= wishlistProductIds.includes(product._id.toString()) ? 'in-wishlist' : '' %>" data-product-id="<%= product._id %>" title="Add to wishlist"><span>add to wishlist</span></a>
                                        </div>
                                    </figure>
                                    <div class="product-body">
                                        <h3 class="product-title"><a href="/product/<%= product._id %>"><%= product.productName %></a></h3>
                                        <div class="product-price">₹<%= product.salePrice %></div>
                                    </div>
                                    <div class="product-action">
                                        <a href="/product/<%= product._id %>" class="btn-product btn-cart"><span>view details</span></a>
                                    </div>
                                </div>
                            <% }) %>
                        <% } %>
                    </div>
                </div>

                <!-- Men Products Tab -->
                <div class="tab-pane p-0 fade" id="trendy-fur-tab" role="tabpanel" aria-labelledby="trendy-fur-link">
                    <div class="owl-carousel owl-simple carousel-equal-height carousel-with-shadow" data-toggle="owl" 
                        data-owl-options='{"nav": false, "dots": true, "margin": 20, "loop": false, "responsive": {"0": {"items":2}, "480": {"items":2}, "768": {"items":3}, "992": {"items":4}, "1200": {"items":4, "nav": true, "dots": false}}}'>
                        <% if(menProducts && menProducts.length > 0) { %>
