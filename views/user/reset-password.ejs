<%- include("../partials/user/header") %>
<style>
.otp-overlay { top: 0; left: 0; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; padding: 60px 0; min-height: 60vh; }
.otp-box { background: #f7f7f7; width: 380px; padding: 40px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
.otp-box h4 { margin-bottom: 10px; font-weight: 500; }
.line { width: 60%; height: 2px; background: #c8a165; margin: 10px auto 30px; }
.otp-btn { padding: 10px 30px; border: 1px solid #c8a165; background: transparent; cursor: pointer; margin-bottom: 15px; width: 100%; }
.otp-btn:hover { background: #c8a165; color: #fff; }
</style>
<main class="main">
    <div class="error-content text-center" style="background-image: url('/assets/images/RARO login bg.jpg')">
        <div class="container">
            <div class="otp-overlay">
                <div class="otp-box">
                    <h4>Set New Password</h4>
                    <div class="line"></div>

                    <% if (locals.message && message.length > 0) { %>
                        <div class="alert alert-danger text-center" style="padding: 10px; font-size: 14px; margin-bottom: 20px;">
                            <%= message %>
                        </div>
                    <% } %>

                    <form method="post" action="/resetPassword" id="resetPasswordForm">
                        <div class="form-group mb-3 text-left" style="text-align: left;">
                            <label for="password" style="font-size: 14px; color: #666; margin-bottom: 5px; display: block;">Enter New Password *</label>
                            <input type="password" class="form-control" id="password" name="password" required style="border: 1px solid #ddd; background: #fff; padding: 10px 15px;">
                        </div>

                        <div class="form-group mb-3 text-left" style="text-align: left;">
                            <label for="confirmpassword" style="font-size: 14px; color: #666; margin-bottom: 5px; display: block;">Confirm New Password *</label>
                            <input type="password" class="form-control" id="confirmpassword" name="confirmpassword" required style="border: 1px solid #ddd; background: #fff; padding: 10px 15px;">
                        </div>

                        <div id="password-error" class="text-danger mb-3" style="display: none; font-size: 13px;"></div>

                        <button type="submit" class="otp-btn">RESET →</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
<%- include("../partials/user/footer.ejs") %>
<button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>
<%-include("../../views/partials/user/mobileView.ejs")%>
<script src="/assets/js/jquery.min.js"></script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script>
    document.getElementById('resetPasswordForm').addEventListener('submit', function(e) {
        const password = document.getElementById('password').value;
        const confirm = document.getElementById('confirmpassword').value;
        const err = document.getElementById('password-error');
        
        if (password.length < 6) {
            e.preventDefault();
            err.textContent = "Password must be at least 6 characters long.";
            err.style.display = 'block';
            return;
        }
        
        if (password !== confirm) {
            e.preventDefault();
            err.textContent = "Passwords do not match!";
            err.style.display = 'block';
        }
    });
</script>
<script src="/assets/js/main.js"></script>
