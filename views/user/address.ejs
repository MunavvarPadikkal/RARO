<%-include("../../views/partials/user/header.ejs")%>

    <style>
        .address-card {
            border: 1px solid #ebebeb;
            border-radius: 12px;
            transition: 0.3s;
            background: #fff;
            height: 100%;
            position: relative;
            padding: 25px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.02);
        }

        .address-card:hover {
            border-color: #333;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        }

        .address-card-default {
            border-color: #c8a165;
            box-shadow: 0 2px 12px rgba(200, 161, 101, 0.15);
        }

        .address-card-default:hover {
            border-color: #b08a4a;
        }

        .set-default-btn:hover {
            background: #c8a165 !important;
            color: #fff !important;
            border-color: #c8a165 !important;
        }

        .swal-glass {
            background: rgba(255, 255, 255, 0.95) !important;
            backdrop-filter: blur(10px) !important;
            border-radius: 16px !important;
        }

        .swal-custom-backdrop {
            backdrop-filter: blur(5px) !important;
            background: rgba(0, 0, 0, 0.4) !important;
        }

        .swal2-html-container {
            overflow: visible !important;
            text-align: center;
        }

        /* Custom Swal Input Fields */
        .swal-form-group {
            margin-bottom: 15px;
        }

        .swal-form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #444;
            margin-bottom: 5px;
        }

        .swal-form-control {
            width: 100%;
            padding: 10px 14px;
            background: #fafafa;
            border: 1px solid #ebebeb;
            border-radius: 8px;
            font-size: 14px;
            box-sizing: border-box;
        }

        .swal-form-control:focus {
            outline: none;
            border-color: #333;
        }

        /* Remove number input spinners */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            appearance: none;
            margin: 0;
        }

        input[type=number] {
            -moz-appearance: textfield;
            appearance: textfield;
        }

        /* Custom Radio Styling */
        .custom-control-input:checked~.custom-control-label::before {
            background-color: #c8a165;
            border-color: #c8a165;
        }

        .custom-radio .custom-control-label {
            font-size: 13px;
            font-weight: 500;
            color: #666;
            cursor: pointer;
        }
    </style>

    <main class="main">
        <div class="page-header text-center" style="background-image: url('assets/images/page-header-bg.jpg')">
            <div class="container">
                <h1 class="page-title">My Account<span>Manage Addresses</span></h1>
            </div>
        </div>
        <nav aria-label="breadcrumb" class="breadcrumb-nav mb-3">
            <div class="container">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/profile">Profile</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Addresses</li>
                </ol>
            </div>
        </nav>

        <div class="page-content">
            <div class="container">
                <div class="row align-items-center mb-4">
                    <div class="col-8">
                        <h5 style="font-weight: 600; color: #333; margin:0;">Saved Addresses</h5>
                    </div>
                    <div class="col-4 text-right">
                        <button class="btn btn-dark" onclick="openAddAddressModal()"
                            style="border-radius: 8px; font-weight: 500;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                class="mr-2" viewBox="0 0 16 16">
                                <path
                                    d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z" />
                            </svg> Add Address
                        </button>
                    </div>
                </div>

                <div class="row">
                    <% if(userAddress && userAddress.address && userAddress.address.length> 0) { %>
                        <% userAddress.address.forEach(item=> { %>
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="address-card<%= item.isDefault ? ' address-card-default' : '' %>">

                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="custom-control custom-radio">
                                            <input type="radio" id="default-<%= item._id %>" name="defaultAddress"
                                                class="custom-control-input" <%=item.isDefault ? 'checked' : '' %>
                                            onclick="setDefault('<%= item._id %>')">
                                                <label class="custom-control-label"
                                                    for="default-<%= item._id %>">Default</label>
                                        </div>
                                        <span class="badge badge-dark"
                                            style="font-size: 11px; padding: 6px 12px; border-radius: 20px; font-weight: 500;">
                                            <%= item.addressType %>
                                        </span>
                                    </div>

                                    <h5 class="mb-1" style="font-weight: 600; font-size: 16px;">
                                        <%= item.name %>
                                    </h5>
                                    <p class="mb-1" style="font-size: 14px; color: #666;">
                                        <%= item.phone %>
                                            <% if(item.altPhone && item.altPhone !=='N/A' ) { %> / <%= item.altPhone %>
                                                    <% } %>
                                    </p>

                                    <p class="mb-3" style="font-size: 14px; color: #555; line-height: 1.6;">
                                        <%= item.landMark %>, <%= item.city %><br>
                                                <%= item.state %> - <strong>
                                                        <%= item.pincode %>
                                                    </strong>
                                    </p>

                                    <div class="d-flex flex-wrap" style="gap: 8px;">
                                        <button class="btn btn-outline-dark btn-sm w-50"
                                            style="border-radius: 6px; font-weight: 600; flex: 1; min-width: 70px;"
                                            onclick="openEditAddressModal('<%= item._id %>', '<%= item.addressType %>', '<%= item.name %>', '<%= item.city %>', '<%= item.landMark %>', '<%= item.state %>', '<%= item.pincode %>', '<%= item.phone %>', '<%= item.altPhone %>')">
                                            Edit
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm w-50"
                                            style="border-radius: 6px; font-weight: 600; flex: 1; min-width: 70px;"
                                            onclick="deleteAddress('<%= item._id %>')">
                                            Delete
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="col-12 text-center py-5">
                                        <div style="font-size: 50px; margin-bottom: 10px;">🏠</div>
                                        <h4 style="font-weight: 600; color: #333;">No Addresses Saved</h4>
                                        <p style="color: #666;">Start by adding a new address for faster checkout!</p>
                                    </div>
                                    <% } %>
                </div>

                <div class="text-center mt-3">
                    <a href="/profile" class="btn btn-outline-dark"
                        style="border-radius: 8px; font-weight: 500; font-size: 14px; padding: 10px 25px;">Back to
                        Profile</a>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const formHtml = `
        <div class="row mt-3">
            <div class="col-md-6 swal-form-group">
                <label class="swal-form-label">Address Type</label>
                <select id="addrType" class="swal-form-control">
                    <option value="Home">Home</option>
                    <option value="Work">Work</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div class="col-md-6 swal-form-group">
                <label class="swal-form-label">House Name</label>
                <input type="text" id="addrName" class="swal-form-control" placeholder="Jasmine villa">
            </div>
            <div class="col-md-6 swal-form-group">
                <label class="swal-form-label">Phone Number</label>
                <input type="number" id="addrPhone" class="swal-form-control" placeholder="10 Digits">
            </div>
            <div class="col-md-6 swal-form-group">
                <label class="swal-form-label">Alt Phone</label>
                <input type="number" id="addrAlt" class="swal-form-control" placeholder="Optional">
            </div>
            <div class="col-12 swal-form-group">
                <label class="swal-form-label">Landmark / Street Address</label>
                <input type="text" id="addrLandmark" class="swal-form-control" placeholder="123 Street Name">
            </div>
            <div class="col-md-4 swal-form-group">
                <label class="swal-form-label">City</label>
                <input type="text" id="addrCity" class="swal-form-control" placeholder="City">
            </div>
            <div class="col-md-4 swal-form-group">
                <label class="swal-form-label">State</label>
                <input type="text" id="addrState" class="swal-form-control" placeholder="State">
            </div>
            <div class="col-md-4 swal-form-group">
                <label class="swal-form-label">Pincode</label>
                <input type="number" id="addrPin" class="swal-form-control" placeholder="000000">
            </div>
        </div>
    `;

        function validatePopupForm() {
            const type = document.getElementById('addrType').value.trim();
            const name = document.getElementById('addrName').value.trim();
            const phone = document.getElementById('addrPhone').value.trim();
            const altPhone = document.getElementById('addrAlt').value.trim();
            const landmark = document.getElementById('addrLandmark').value.trim();
            const city = document.getElementById('addrCity').value.trim();
            const state = document.getElementById('addrState').value.trim();
            const pin = document.getElementById('addrPin').value.trim();

            if (!name || !phone || !landmark || !city || !state || !pin) {
                Swal.showValidationMessage('Please fill all mandatory fields!');
                return false;
            }

            if (phone.length !== 10) {
                Swal.showValidationMessage('Phone number must be exactly 10 digits!');
                return false;
            }

            if (pin.length !== 6) {
                Swal.showValidationMessage('Pincode must be exactly 6 digits!');
                return false;
            }

            return {
                addressType: type, name: name, phone: phone, altPhone: altPhone || 'N/A',
                landMark: landmark, city: city, state: state, pincode: pin
            };
        }

        function openAddAddressModal() {
            Swal.fire({
                title: '<h4 style="margin:0;font-weight:600;color:#222;">Add New Address</h4>',
                html: formHtml,
                width: '600px',
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'Save Address',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#1a1a1a',
                customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' },
                preConfirm: validatePopupForm
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const req = await fetch('/addAddress', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(result.value)
                        });
                        const res = await req.json();

                        if (res.success) {
                            Swal.fire({ title: 'Success', text: res.message, icon: 'success', customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' } })
                                .then(() => window.location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    } catch (e) { console.error(e); }
                }
            });
        }

        function openEditAddressModal(id, type, name, city, landmark, state, pin, phone, altPhone) {
            Swal.fire({
                title: '<h4 style="margin:0;font-weight:600;color:#222;">Edit Address</h4>',
                html: formHtml,
                width: '600px',
                focusConfirm: false,
                showCancelButton: true,
                confirmButtonText: 'Update Details',
                cancelButtonText: 'Cancel',
                confirmButtonColor: '#1a1a1a',
                customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' },
                didOpen: () => {
                    document.getElementById('addrType').value = type;
                    document.getElementById('addrName').value = name;
                    document.getElementById('addrCity').value = city;
                    document.getElementById('addrLandmark').value = landmark;
                    document.getElementById('addrState').value = state;
                    document.getElementById('addrPin').value = pin;
                    document.getElementById('addrPhone').value = phone;
                    document.getElementById('addrAlt').value = altPhone === 'N/A' ? '' : altPhone;
                },
                preConfirm: validatePopupForm
            }).then(async (result) => {
                if (result.isConfirmed) {
                    const payload = result.value;
                    payload.addressId = id;

                    try {
                        const req = await fetch('/editAddress', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const res = await req.json();

                        if (res.success) {
                            Swal.fire({ title: 'Updated', text: res.message, icon: 'success', customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' } })
                                .then(() => window.location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    } catch (e) { console.error(e); }
                }
            });
        }

        function deleteAddress(id) {
            Swal.fire({
                title: 'Are you sure?',
                text: "This remote address will be lost!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const req = await fetch('/deleteAddress?id=' + id, { method: 'DELETE' });
                        const res = await req.json();

                        if (res.success) {
                            Swal.fire({ title: 'Deleted!', text: res.message, icon: 'success', customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' } })
                                .then(() => window.location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    } catch (e) { console.error(e); }
                }
            });
        }

        async function setDefault(addressId) {
            try {
                const req = await fetch('/setDefaultAddress', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ addressId })
                });
                const res = await req.json();
                if (res.success) {
                    Swal.fire({
                        title: 'Updated!', text: res.message, icon: 'success', timer: 1500, showConfirmButton: false,
                        customClass: { popup: 'swal-glass', backdrop: 'swal-custom-backdrop' }
                    }).then(() => window.location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            } catch (e) {
                console.error(e);
                Swal.fire('Error', 'Something went wrong', 'error');
            }
        }
    </script>

    <%-include("../../views/partials/user/footer.ejs")%>
        <%-include("../../views/partials/user/mobileView.ejs")%>