<%- include("../../views/partials/user/header.ejs") %>

<main class="main">
    <div class="page-content pt-5 pb-5">
        <div class="container">

            <div class="row justify-content-center">
                <div class="col-lg-8 col-md-10">

                    <!-- ── Success Card ── -->
                    <div class="order-success-card relative">
                        <!-- Invoice Download Button -->
                        <div class="invoice-download-btn-wrapper">
                            <button id="downloadInvoice" class="btn-invoice-download">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"></path>
                                    <polyline points="7 10 12 15 17 10"></polyline>
                                    <line x1="12" y1="15" x2="12" y2="3"></line>
                                </svg>
                                Download Invoice
                            </button>
                        </div>

                        <!-- Animated success icon -->
                        <div class="success-icon-wrapper">
                            <div class="success-icon-circle">
                                <svg class="success-checkmark" viewBox="0 0 52 52">
                                    <circle class="success-checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
                                    <path class="success-checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                                </svg>
                            </div>
                        </div>

                        <h1 class="success-heading">Order Placed!</h1>
                        <p class="success-subtext">Thank you, <strong><%= user.name %></strong>! Your order has been confirmed.</p>

                        <!-- ── Order Meta ── -->
                        <div class="order-meta-grid">
                            <div class="order-meta-item">
                                <span class="meta-label">Order ID</span>
                                <span class="meta-value order-id-value" title="<%= order.orderId %>">
                                    #<%= order.orderId %>
                                </span>
                                </span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Order Date</span>
                                <span class="meta-value">
                                    <%= new Date(order.createdOn).toLocaleDateString('en-IN', {
                                        day: 'numeric', month: 'long', year: 'numeric'
                                    }) %>
                                </span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Payment</span>
                                <span class="meta-value"><%= order.paymentMethod %></span>
                            </div>
                            <div class="order-meta-item">
                                <span class="meta-label">Status</span>
                                <span class="meta-value order-status-badge"><%= order.orderStatus %></span>
                            </div>
                        </div>

                        <!-- ── Ordered Items ── -->
                        <div class="success-section">
                            <h3 class="success-section-title">Items Ordered</h3>
                            <div class="success-items-list">
                                <% order.orderedItems.forEach(item => { %>
                                    <div class="success-item-row">
                                        <div class="success-item-img">
                                            <% if (item.productImage) { %>
                                                <img src="/uploads/productImages/<%= item.productImage %>"
                                                     alt="<%= item.productName %>">
                                            <% } else { %>
                                                <img src="/assets/images/products/product-4.jpg" alt="Product">
                                            <% } %>
                                        </div>
                                        <div class="success-item-info">
                                            <p class="success-item-name"><%= item.productName %></p>
                                            <p class="success-item-meta">
                                                Size: <strong><%= item.size %></strong>
                                                <% if (item.color) { %> &nbsp;·&nbsp; Color: <strong><%= item.color %></strong><% } %>
                                                &nbsp;·&nbsp; Qty: <strong><%= item.quantity %></strong>
                                            </p>
                                        </div>
                                        <div class="success-item-price">₹<%= item.itemTotal %></div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>

                        <!-- ── Price Summary ── -->
                        <div class="success-section">
                            <h3 class="success-section-title">Price Breakdown</h3>
                            <table class="success-price-table">
                                <tr>
                                    <td>Subtotal</td>
                                    <td>₹<%= order.subtotal %></td>
                                </tr>
                                <% if (order.discount > 0) { %>
                                    <tr class="discount-row">
                                        <td>Coupon Discount</td>
                                        <td>− ₹<%= order.discount %></td>
                                    </tr>
                                <% } %>
                                <tr>
                                    <td>Shipping</td>
                                    <td><%= order.shippingCharge === 0 ? 'Free' : '₹' + order.shippingCharge %></td>
                                </tr>
                                <tr class="total-row">
                                    <td><strong>Total Paid</strong></td>
                                    <td><strong>₹<%= order.finalAmount %></strong></td>
                                </tr>
                            </table>
                        </div>

                        <!-- ── Delivery Address ── -->
                        <div class="success-section">
                            <h3 class="success-section-title">Delivering To</h3>
                            <div class="success-address-box">
                                <div class="d-flex align-items-center mb-2">
                                    <span class="address-type-pill"><%= order.shippingAddress.addressType %></span>
                                </div>
                                <p class="success-addr-name"><%= order.shippingAddress.name %></p>
                                <p class="success-addr-line">
                                    <%= order.shippingAddress.landMark ? order.shippingAddress.landMark + ', ' : '' %>
                                    <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %> — <%= order.shippingAddress.pincode %>
                                </p>
                                <p class="success-addr-phone">📞 <%= order.shippingAddress.phone %></p>
                            </div>
                        </div>

                        <!-- ── Action Buttons ── -->
                            <a href="/orders" class="btn btn-outline-primary-2">
                                <i class="icon-list"></i> View My Orders
                            </a>
                            <a href="/shop" class="btn btn-outline-dark-2">
                                <i class="icon-shopping-cart"></i> Continue Shopping
                            </a>
                        </div>

                    </div><!-- End .order-success-card -->

                </div>
            </div><!-- End .row -->
        </div><!-- End .container -->
    </div><!-- End .page-content -->
</main>

<button id="scroll-top" title="Back to Top"><i class="icon-arrow-up"></i></button>

<!-- ══════════════════════════════════════════════════════════════════════════
     Order Success Page Styles
═══════════════════════════════════════════════════════════════════════════ -->
<style>
    /* ── Card ──────────────────────────────────────────────────────────────── */
    .order-success-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        padding: 48px 40px;
        text-align: center;
    }
    @media (max-width: 576px) {
        .order-success-card { padding: 32px 20px; }
    }

    /* ── Animated Checkmark ────────────────────────────────────────────────── */
    .success-icon-wrapper { margin-bottom: 24px; }
    .success-icon-circle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 90px;
        height: 90px;
    }
    .success-checkmark {
        width: 90px;
        height: 90px;
        border-radius: 50%;
    }
    .success-checkmark-circle {
        stroke: #43a047;
        stroke-width: 2;
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        stroke-miterlimit: 10;
        animation: strokeCircle 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }
    .success-checkmark-check {
        stroke: #43a047;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: strokeCheck 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.5s forwards;
    }
    @keyframes strokeCircle {
        100% { stroke-dashoffset: 0; }
    }
    @keyframes strokeCheck {
        100% { stroke-dashoffset: 0; }
    }

    /* ── Headings ──────────────────────────────────────────────────────────── */
    .success-heading {
        font-size: 3.2rem;
        font-weight: 800;
        color: #222;
        margin-bottom: 8px;
    }
    .success-subtext {
        font-size: 1.5rem;
        color: #666;
        margin-bottom: 32px;
    }

    /* ── Order Meta Grid ───────────────────────────────────────────────────── */
    .order-meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        background: #f9f9f9;
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 32px;
        text-align: left;
    }
    @media (max-width: 480px) {
        .order-meta-grid { grid-template-columns: 1fr; }
    }
    .order-meta-item { display: flex; flex-direction: column; gap: 4px; }
    .meta-label {
        font-size: 1.1rem;
        font-weight: 600;
        color: #999;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .meta-value { font-size: 1.4rem; font-weight: 600; color: #333; }
    .order-id-value {
        font-family: monospace;
        font-size: 1.3rem;
        color: #c96;
        cursor: help;
    }
    .order-status-badge {
        display: inline-block;
        background: #e8f5e9;
        color: #2e7d32;
        padding: 2px 12px;
        border-radius: 20px;
        font-size: 1.2rem;
        font-weight: 700;
    }

    /* ── Sections ──────────────────────────────────────────────────────────── */
    .success-section {
        text-align: left;
        margin-bottom: 28px;
        border-top: 1px solid #f0f0f0;
        padding-top: 24px;
    }
    .success-section-title {
        font-size: 1.7rem;
        font-weight: 700;
        color: #333;
        margin-bottom: 16px;
    }

    /* ── Items List ────────────────────────────────────────────────────────── */
    .success-items-list { display: flex; flex-direction: column; gap: 12px; }
    .success-item-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px;
        border: 1px solid #f0f0f0;
        border-radius: 10px;
        background: #fafafa;
    }
    .success-item-img {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        flex-shrink: 0;
        border: 1px solid #eee;
    }
    .success-item-img img { width: 100%; height: 100%; object-fit: cover; }
    .success-item-info { flex: 1; }
    .success-item-name { font-size: 1.4rem; font-weight: 600; color: #333; margin-bottom: 3px; }
    .success-item-meta { font-size: 1.2rem; color: #777; margin: 0; }
    .success-item-price { font-size: 1.4rem; font-weight: 700; color: #c96; white-space: nowrap; }

    /* ── Price Table ───────────────────────────────────────────────────────── */
    .success-price-table { width: 100%; border-collapse: collapse; font-size: 1.4rem; }
    .success-price-table td { padding: 8px 4px; color: #444; }
    .success-price-table td:last-child { text-align: right; font-weight: 600; }
    .success-price-table .discount-row td { color: #2e7d32; }
    .success-price-table .total-row td {
        font-size: 1.6rem;
        color: #222;
        border-top: 2px solid #eee;
        padding-top: 12px;
    }

    /* ── Delivery Address Box ──────────────────────────────────────────────── */
    .success-address-box {
        background: #f9f9f9;
        border-left: 4px solid #c96;
        border-radius: 8px;
        padding: 16px 20px;
    }
    .address-type-pill {
        background: #c96;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
        padding: 2px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .success-addr-name { font-size: 1.5rem; font-weight: 700; color: #222; margin: 8px 0 4px; }
    .success-addr-line { font-size: 1.3rem; color: #555; margin-bottom: 4px; }
    .success-addr-phone { font-size: 1.3rem; color: #777; margin: 0; }

    /* ── Action Buttons ────────────────────────────────────────────────────── */
    .success-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid #f0f0f0;
    }
    .success-actions .btn { min-width: 180px; }

    .invoice-download-btn-wrapper {
        position: absolute;
        top: 25px;
        right: 25px;
    }
    .btn-invoice-download {
        background-color: #43a047;
        color: #fff !important;
        border: none;
        padding: 8px 14px;
        border-radius: 6px;
        font-size: 1.2rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(67, 160, 71, 0.1);
        cursor: pointer;
    }
    .btn-invoice-download:hover {
        background-color: #388e3c;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(67, 160, 71, 0.25);
    }
    .btn-invoice-download i {
        font-size: 1.6rem;
    }
    @media (max-width: 576px) {
        .invoice-download-btn-wrapper {
            position: static;
            margin-bottom: 20px;
            text-align: right;
        }
    }

    /* ── Hidden Invoice Template for PDF ── */
    #invoiceTemplate {
        display: none;
    }

    /* Styles specifically for the PDF content when rendered */
    .pdf-container {
        padding: 40px;
        font-family: 'Inter', sans-serif;
        color: #333;
        background: #fff;
    }
    .pdf-header {
        display: flex;
        justify-content: space-between;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 20px;
        margin-bottom: 30px;
    }
    .pdf-logo { font-size: 28px; font-weight: 800; color: #222; }
    .pdf-title { font-size: 24px; font-weight: 700; color: #c96; }
    .pdf-info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 40px;
        margin-bottom: 40px;
    }
    .pdf-info-box h4 {
        font-size: 14px;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 10px;
        border-bottom: 1px solid #eee;
        padding-bottom: 5px;
    }
    .pdf-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 30px;
    }
    .pdf-table th {
        background: #f9f9f9;
        text-align: left;
        padding: 12px;
        font-size: 13px;
        font-weight: 700;
        border-bottom: 2px solid #eee;
    }
    .pdf-table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
        font-size: 13px;
    }
    .pdf-footer {
        margin-top: 50px;
        text-align: center;
        color: #999;
        font-size: 12px;
        border-top: 1px solid #eee;
        padding-top: 20px;
    }
</style>

<!-- ─────────────────────────────────────────────────────────────────────────────
     Invoice Template (Hidden)
     ───────────────────────────────────────────────────────────────────────────── -->
<style>
  .logo-section {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }
        .invoice-text-logo {
    font-size: 33px;
    font-weight: 750;
    color: #222;
    margin-bottom: 1px;
    text-transform: uppercase;
        }
        .tagline {
            margin: 0;
            color: #888;
            font-size: 15px;
            letter-spacing: 1px;
            font-weight: 400;
            white-space: nowrap;
        }
</style>

<div id="invoiceTemplate">
    <div class="pdf-container">
        <div class="pdf-header">
            
            <div class="logo-section">
                    <div class="invoice-text-logo">RARO</div>
                    <p class="tagline">Wear What's Rare</p>
            </div>
            
            <div style="text-align: right;">
                <div class="pdf-title">INVOICE</div>
                <p style="margin: 5px 0; font-weight: 600;">#INV-<%= order.orderId.substring(0, 8).toUpperCase() %></p>
                <p style="margin: 0; color: #666;"><%= new Date(order.createdOn).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
            </div>
        </div>

        <div class="pdf-info-grid">
            <div class="pdf-info-box">
                <h4>Billed To</h4>
                <p style="margin: 5px 0; font-weight: 700; font-size: 15px;"><%= order.shippingAddress.name %></p>
                <p style="margin: 0; line-height: 1.5; color: #555;">
                    <%= order.shippingAddress.landMark ? order.shippingAddress.landMark + ', ' : '' %>
                    <%= order.shippingAddress.city %>, <%= order.shippingAddress.state %><br>
                    <%= order.shippingAddress.pincode %><br>
                    Phone: <%= order.shippingAddress.phone %>
                </p>
            </div>
            <div class="pdf-info-box">
                <h4>Payment Method</h4>
                <p style="margin: 5px 0; font-weight: 600;"><%= order.paymentMethod %></p>
                <p style="margin: 5px 0; color: #666;">Status: <%= order.orderStatus %></p>
            </div>
        </div>

        <table class="pdf-table">
            <thead>
                <tr>
                    <th>Item Description</th>
                    <th style="text-align: center;">Size</th>
                    <th style="text-align: center;">Qty</th>
                    <th style="text-align: right;">Price</th>
                    <th style="text-align: right;">Total</th>
                </tr>
            </thead>
            <tbody>
                <% order.orderedItems.forEach(item => { %>
                    <tr>
                        <td>
                            <div style="font-weight: 600;"><%= item.productName %></div>
                            <div style="font-size: 11px; color: #888;"><%= item.color %></div>
                        </td>
                        <td style="text-align: center;"><%= item.size %></td>
                        <td style="text-align: center;"><%= item.quantity %></td>
                        <td style="text-align: right;">₹<%= (item.itemTotal / item.quantity).toFixed(2) %></td>
                        <td style="text-align: right; font-weight: 600;">₹<%= item.itemTotal %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <div style="display: flex; justify-content: flex-end;">
            <table style="width: 250px; font-size: 14px; border-collapse: collapse;">
                <tr>
                    <td style="padding: 8px 0; color: #666;">Subtotal</td>
                    <td style="padding: 8px 0; text-align: right;">₹<%= order.subtotal %></td>
                </tr>
                <% if (order.discount > 0) { %>
                <tr>
                    <td style="padding: 8px 0; color: #2e7d32;">Coupon Discount</td>
                    <td style="padding: 8px 0; text-align: right; color: #2e7d32;">− ₹<%= order.discount %></td>
                </tr>
                <% } %>
                <tr>
                    <td style="padding: 8px 0; color: #666;">Shipping</td>
                    <td style="padding: 8px 0; text-align: right;"><%= order.shippingCharge === 0 ? 'Free' : '₹' + order.shippingCharge %></td>
                </tr>
                <tr style="border-top: 2px solid #c96;">
                    <td style="padding: 15px 0; font-weight: 800; font-size: 18px;">Total Amount</td>
                    <td style="padding: 15px 0; text-align: right; font-weight: 800; font-size: 18px; color: #c96;">₹<%= order.finalAmount %></td>
                </tr>
            </table>
        </div>

        <div class="pdf-footer">
            <p>Thank you for shopping with RARO. This is a computer generated invoice.</p>
            <p>www.raro-fashion.com | support@raro-fashion.com</p>
        </div>
    </div>
</div>

<!-- html2pdf JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
    document.getElementById('downloadInvoice').addEventListener('click', function() {
        const element = document.getElementById('invoiceTemplate');
        
        // Temporarily show the template for capturing
        element.style.display = 'block';
        
        const options = {
            margin:       0,
            filename:     'Invoice_<%= order.invoiceNumber || order.orderId %>.pdf',
            image:        { type: 'jpeg', quality: 0.98 },
            html2canvas:  { scale: 2, useCORS: true },
            jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };

        html2pdf().from(element).set(options).save().then(() => {
            // Hide it back
            element.style.display = 'none';
        });
    });
</script>

<script src="/assets/js/jquery.min.js"></script>
<script src="/assets/js/bootstrap.bundle.min.js"></script>
<script src="/assets/js/jquery.hoverIntent.min.js"></script>
<script src="/assets/js/jquery.waypoints.min.js"></script>
<script src="/assets/js/superfish.min.js"></script>
<script src="/assets/js/owl.carousel.min.js"></script>
<script src="/assets/js/jquery.magnific-popup.min.js"></script>
<script src="/assets/js/main.js"></script>

