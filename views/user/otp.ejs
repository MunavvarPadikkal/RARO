<%-include("../../views/partials/user/header.ejs")%>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
    /* Overlay to center box */
.otp-overlay {
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* OTP Card */
.otp-box {
  background: #f7f7f7;
  width: 380px;
  padding: 40px;
  text-align: center;
  box-shadow: 0 10px 25px rgba(0,0,0,0.1);
}

.otp-box h3 {
  margin-bottom: 10px;
  font-weight: 500;
}

.line {
  width: 60%;
  height: 2px;
  background: #c8a165;
  margin: 10px auto 30px;
}

/* OTP Inputs */
.otp-inputs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 25px;
}

.otp-input {
  width: 60px;
  height: 60px;
  text-align: center;
  font-size: 22px;
  border: none;
  background: #e0e0e0;
  outline: none;
}

/* Button */
.otp-btn {
  padding: 10px 30px;
  border: 1px solid #c8a165;
  background: transparent;
  cursor: pointer;
  margin-bottom: 15px;
}
/* Hover Effect */
.otp-btn:hover {
  background: #c8a165;
  color: #fff;
}
/* Timer */
.timer-text {
  font-size: 17px;
  margin-bottom: 10px;
}

#timer {
  font-weight: bold;
  color: #c8a165;
}

/* Resend */
.resend-text a {
  color: red;
  text-decoration: none;
  font-size: 13px;
}
</style>

<main class="main">
  <nav aria-label="breadcrumb" class="breadcrumb-nav border-0 mb-0">
    <div class="container">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/signin">Login</a></li>
        <li class="breadcrumb-item active" aria-current="page">OTP</li>
      </ol>
    </div>
    <!-- End .container -->
  </nav>
  <!-- End .breadcrumb-nav -->

  <div
    class="error-content text-center"
    style="background-image: url(&quot;assets/images/RARO login bg.jpg&quot;)"
  >
    <div class="container">
      <div class="otp-overlay">
        <div class="otp-box">
          <h4>OTP Verification</h4>
          <div class="line"></div>

          <form id="otpForm" action="/verify-otp" method="post" >
            <div class="otp-inputs">
              <input type="text" maxlength="1" class="otp-input" />
              <input type="text" maxlength="1" class="otp-input" />
              <input type="text" maxlength="1" class="otp-input" />
              <input type="text" maxlength="1" class="otp-input" />
            </div>

            <button type="submit" class="otp-btn">Login →</button>

            <p class="timer-text">
              Time remaining: <span id="timer">01:00</span>
            </p>

            <p class="resend-text">
              Don't get it? <a href="#" id="resendBtn">Resend</a>
            </p>
          </form>
        </div>
      </div>
    </div>
    <!-- End .container -->
  </div>
</main>
<!-- End .main -->

<%-include("../../views/partials/user/footer.ejs")%>

<button id="scroll-top" title="Back to Top">
  <i class="icon-arrow-up"></i>
</button>

<%-include("../../views/partials/user/mobileView.ejs")%>

<script>

  const inputs = document.querySelectorAll(".otp-input");

  inputs.forEach((input, index) => {

    // Move forward when typing
    input.addEventListener("input", (e) => {
      if (e.target.value.length === 1) {
        if (index < inputs.length - 1) {
          inputs[index + 1].focus();
        }
      }
    });

    // Move backward on backspace
    input.addEventListener("keydown", (e) => {
      if (e.key === "Backspace" && !input.value) {
        if (index > 0) {
          inputs[index - 1].focus();
        }
      }
    });

  });

  let countdown;
  let timeLeft = 60;

  const timerDisplay = document.getElementById("timer");
  const resendBtn = document.getElementById("resendBtn");

  function startTimer() {

    resendBtn.style.pointerEvents = "none";
    resendBtn.style.opacity = "0.5";

    countdown = setInterval(() => {

      let minutes = Math.floor(timeLeft / 60);
      let seconds = timeLeft % 60;
      seconds = seconds < 10 ? "0" + seconds : seconds;

      timerDisplay.textContent = `${minutes}:${seconds}`;

      if (timeLeft <= 0) {
        clearInterval(countdown);
        timerDisplay.textContent = "Expired";
        resendBtn.style.pointerEvents = "auto";
        resendBtn.style.opacity = "1";
      }

      timeLeft--;

    }, 1000);
  }

  function resetTimer() {
    clearInterval(countdown);
    timeLeft = 60;
    startTimer();
  }

  startTimer();

</script>

<script>
  document.getElementById("otpForm").addEventListener("submit", function(e){
  e.preventDefault();   // stop normal form submit

  const inputs = document.querySelectorAll(".otp-input");

  let otpInput = "";
  inputs.forEach(input => {
    otpInput += input.value;
  });

  console.log("OTP sending:", otpInput);

  if(otpInput.length !== 4){
    Swal.fire({
      icon:"warning",
      title:"Enter full OTP",
      text:"Please enter all 4 digits"
    });
    return;
  }

  $.ajax({
    type:"POST",
    url:"/verify-otp",
    data:{ otp: otpInput },
    success: function(response){
      if(response.success){
        Swal.fire({
          icon:"success",
          title:"OTP Verified Successfully",
          showConfirmButton:false,
          timer:1500,
        }).then(()=>{
          window.location.href = response.redirectUrl;
        })
      }
    },
    error: function(xhr){
      Swal.fire({
        icon:"error",
        title:"Invalid OTP",
        text: xhr.responseJSON?.message || "Please try again"
      })
    }
  });
});

resendBtn.addEventListener("click", function(e) {
  e.preventDefault();

  fetch("/resend-otp", {
    method: "POST"
  })
  .then(res => res.json())
  .then(data => {
    if(data.success){

      Swal.fire({
        icon: "success",
        title: "New OTP Sent!",
        timer: 1500,
        showConfirmButton: false
      });

      resetTimer();

    } else {
      Swal.fire({
        icon: "error",
        title: "Wait",
        text: data.message
      });
    }
  })
  .catch(() => {
    Swal.fire({
      icon: "error",
      title: "Something went wrong"
    });
  });

});

</script>
