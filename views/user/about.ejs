<%-include("../../views/partials/user/header.ejs")%>

<main class="main">
    <nav aria-label="breadcrumb" class="breadcrumb-nav border-0 mb-0">
        <div class="container">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">About Us</li>
            </ol>
        </div><!-- End .container -->
    </nav><!-- End .breadcrumb-nav -->

    <div class="container">
        <div class="page-header page-header-big text-center" style="background-image: url('/assets/images/about/hero.png'); background-position: center; background-size: cover; height: 500px; display: flex; align-items: center; justify-content: center;">
            <div style="background: rgba(0,0,0,0.4); padding: 40px; border-radius: 10px;">
                <h1 class="page-title text-white">About us<span class="text-white">Who we are</span></h1>
            </div>
        </div><!-- End .page-header -->
    </div><!-- End .container -->

    <div class="page-content pb-0">
        <div class="container">
            <div class="row">
                <div class="col-lg-6 mb-3 mb-lg-0">
                    <h2 class="title">Our Vision</h2><!-- End .title -->
                    <p>At RARO, we believe that fashion is more than just clothing—it's a statement of individuality. Our mission is to bridge the gap between contemporary street style and premium craftsmanship. We curate collections that resonate with the modern trendsetter, ensuring every piece tells a story of quality and design excellence.</p>
                    <p>From minimal aesthetics to customized statements, we are dedicated to providing apparel that makes you feel confident and unique.</p>
                </div><!-- End .col-lg-6 -->

                <div class="col-lg-6">
                    <h2 class="title">Our Mission</h2><!-- End .title -->
                    <p>To redefine the fashion landscape by offering high-quality, trendy, and accessible apparel that empowers self-expression. We strive for sustainability in our processes and innovation in our designs, making RARO your ultimate destination for modern fashion.</p>
                </div><!-- End .col-lg-6 -->
            </div><!-- End .row -->

            <div class="mb-5"></div><!-- End .mb-4 -->
        </div><!-- End .container -->

        <div class="bg-light-2 pt-6 pb-5 mb-6 mb-lg-8">
            <div class="container">
                <div class="row">
                    <div class="col-lg-5 mb-3 mb-lg-0">
                        <h2 class="title">Our Story</h2><!-- End .title -->
                        <p class="lead text-primary mb-3">Crafting the Future of Fashion Since 2023</p><!-- End .lead text-primary -->
                        <p class="mb-2">RARO started with a simple idea: why should premium fashion be out of reach? We began as a small collective of designers in Kerala, passionate about creating t-shirts that weren't just mass-produced, but carefully thought out.</p>
                        <p>Today, RARO is a growing community. We've expanded our horizons while staying true to our roots—focusing on quality fabrics, perfect fits, and designs that stand the test of time.</p>
                    </div><!-- End .col-lg-5 -->

                    <div class="col-lg-6 offset-lg-1">
                        <div class="about-images">
                            <img src="/assets/images/about/story.png" alt="Our Story Image" class="about-img-front" style="border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                        </div><!-- End .about-images -->
                    </div><!-- End .col-lg-6 -->
                </div><!-- End .row -->
            </div><!-- End .container -->
        </div><!-- End .bg-light-2 -->

        <div class="container">
            <div class="row">
                <div class="col-lg-4">
                    <div class="icon-box icon-box-sm text-center">
                        <span class="icon-box-icon">
                            <i class="icon-puzzle-piece"></i>
                        </span>
                        <div class="icon-box-content">
                            <h3 class="icon-box-title">Design Quality</h3><!-- End .icon-box-title -->
                            <p>Every design is meticulously crafted to ensure a unique and premium aesthetic.</p>
                        </div><!-- End .icon-box-content -->
                    </div><!-- End .icon-box -->
                </div><!-- End .col-lg-4 -->

                <div class="col-lg-4">
                    <div class="icon-box icon-box-sm text-center">
                        <span class="icon-box-icon">
                            <i class="icon-life-ring"></i>
                        </span>
                        <div class="icon-box-content">
                            <h3 class="icon-box-title">Professional Support</h3><!-- End .icon-box-title -->
                            <p>Our dedicated team is always here to help you with your shopping experience.</p>
                        </div><!-- End .icon-box-content -->
                    </div><!-- End .icon-box -->
                </div><!-- End .col-lg-4 -->

                <div class="col-lg-4">
                    <div class="icon-box icon-box-sm text-center">
                        <span class="icon-box-icon">
                            <i class="icon-heart-o"></i>
                        </span>
                        <div class="icon-box-content">
                            <h3 class="icon-box-title">Made With Love</h3><!-- End .icon-box-title -->
                            <p>We pour our passion into every stitch, ensuring you receive only the best.</p>
                        </div><!-- End .icon-box-content -->
                    </div><!-- End .icon-box -->
                </div><!-- End .col-lg-4 -->
            </div><!-- End .row -->
        </div><!-- End .container -->

        <div class="mb-2"></div><!-- End .mb-2 -->

        <div class="bg-image pt-7 pb-8" style="background-image: url('/assets/images/backgrounds/cta/bg-6.jpg');">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-md-10 col-lg-9 col-xl-7">
                        <div class="row no-gutters flex-column flex-sm-row align-items-sm-center">
                            <div class="col">
                                <h3 class="cta-title text-white">Join Our Community</h3><!-- End .cta-title -->
                                <p class="cta-desc text-white">Subscribe to get the latest updates and exclusive offers.</p><!-- End .cta-desc -->
                            </div><!-- End .col -->

                            <div class="col-auto">
                                <a href="/signin" class="btn btn-outline-white"><span>SIGN UP</span><i class="icon-long-arrow-right"></i></a>
                            </div><!-- End .col-auto -->
                        </div><!-- End .row no-gutters -->
                    </div><!-- End .col-md-10 col-lg-9 -->
                </div><!-- End .row -->
            </div><!-- End .container -->
        </div><!-- End .bg-image -->
    </div><!-- End .page-content -->
</main><!-- End .main -->

<%-include("../../views/partials/user/footer.ejs")%>
